        function handleRadioChange() {

            var compounder = $('#compounderRadio').is(':checked');
            var tpm = $('#tpmRadio').is(':checked');
            var comp_group = "";

            if (compounder) {
                comp_group = "COMPOUNDER"
            } else {
                if (tpm) {
                    comp_group = "TPM"
                }
            }

            if (comp_group === 'COMPOUNDER') {
                $('.tpmInfo').hide();
                $('.compInfo').show();
            } else {
                if (comp_group === 'TPM') {
                    $('.compInfo').hide();
                    $('.tpmInfo').show();
                } else {
                    $('.compInfo').hide();
                    $('.tpmInfo').hide();
                }
            }

            $("#compGroupHidden").val(comp_group);
            fillProdGroup($(".ddl_prodgroup"));
            fillMachine();


        }

        // show formula modal
        function showModal(count, type) {
            $("#current_count").val(count);
            $("#current_type").val(type);

            //put value if already selected
            if (type == "TPM") {
                $("#txt_modal_1").val($("#item_formula_tpm_" + count).val());
            } else {
                if (type == "COMP") {
                    $("#txt_modal_1").val($("#item_formula_comp_" + count).val());
                }
            }

            $("#calmodalregression").modal("show");
        }

        //ddl_prodgroup
        function fillProdGroup(selectElements) {

            $.ajax({
                type: 'POST',
                url: '@Url.Action("fillProdGroup", "MM_REGRESSION")',
                success: function (data) {

                    selectElements.each(function () {
                        var ddl_prodgroup = $(this);

                        var selectedValues = [];
                        var selectedData = ddl_prodgroup.data('selected');

                        if (selectedData) {
                            if (typeof selectedData === 'string' && selectedData.includes(',')) {
                                selectedValues = selectedData.split(',');
                            } else {
                                selectedValues.push(String(selectedData));
                            }
                        }

                        ddl_prodgroup.html("");
                        for (var i = 0; i < data.length; i++) {
                            var isSelected = selectedValues.includes(data[i].Value) ? 'selected' : '';
                            var items = '<option value="' + data[i].Value + '" ' + isSelected + '>' + data[i].Text + '</option>';
                            ddl_prodgroup.append(items);
                        }
                        ddl_prodgroup.multiselect("rebuild");
                    });
                    
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    console.log(jqXHR.responseText);
                }
            });
        }

        //ddl_machine
        function fillMachine() {
            var ddlpropitemtpm = $("#ddlpropitemtpm").val();

            $.getJSON('@Url.Action("fillMachine", "MM_REGRESSION")?propitemid=' + ddlpropitemtpm, function (data) {
                if (data != null && !jQuery.isEmptyObject(data))
                {
                    $("#item-table tr").each(function () {
                        var ddl_machine = $(this).find(".ddl_machine");

                        if (ddl_machine != undefined) {
                            var currentSelected = ddl_machine.val();
                            ddl_machine.empty();
                            $.each(data, function (index, datas) {
                                ddl_machine.append($('<option/>', {
                                    value: datas.Value,
                                    text: datas.Text
                                }));
                            });
                            ddl_machine.val(currentSelected);
                        }
                    });
                };
            });
        }

