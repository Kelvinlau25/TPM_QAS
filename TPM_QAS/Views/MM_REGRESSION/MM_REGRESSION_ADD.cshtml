
@using TPM_QAS.Models
@model RegressionModel
@{
    ViewBag.Title = "REGRESSION MM - Add";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@using (Html.BeginForm("MM_REGRESSION_ADD", "MM_REGRESSION", FormMethod.Post, new { encType = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <div class="row g-0 px-3 tr-listing-header">
        <div class="col-sm-6 align-self-center">
            <p class="text-muted m-0 tr-listing-header-title">New Form - Regression</p>
        </div>
    </div>

    <div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

    <div class="page-container px-3 overflow-auto">
        <div class="tr-btm-btn-margin">
            <div class="card mt-3 mb-2 card-height height-override">
                <div class="card-body">
                    <div class="row align-items-baseline">
                        <div class="col"><h6 class="card-title text-muted">Regression</h6></div>
                        <div class="col text-end"></div>
                    </div>

                    <hr />

                    @Html.HiddenFor(model => model.MM_REGRESSION_H_ID)
                    @Html.HiddenFor(model => model.COMP_GROUP, new { id = "compGroupHidden" })

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Company Group <span class="text-danger">*</span><span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-check form-check-inline">
                                @Html.RadioButtonFor(m => m.COMP_GROUP, "COMPOUNDER", new { id = "compounderRadio", @class = "form-check-input", onchange = "handleRadioChange()" })
                                <label class="form-check-label" for="compounderRadio">Compounder</label>
                            </div>
                            <div class="form-check form-check-inline">
                                @Html.RadioButtonFor(m => m.COMP_GROUP, "TPM", new { id = "tpmRadio", @class = "form-check-input", onchange = "handleRadioChange()" })
                                <label class="form-check-label" for="tpmRadio">TPM</label>
                            </div>
                        </div>
                    </div>


                    <div class="compInfo" style="display:none">

                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted"><span>Compounder </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                @Html.DropDownListFor(Model => Model.COMPOUNDER, Model.DropdownCompounder, "Select an option..", new { id = "ddlcompounder", @class = "ddloption form-control form-select", required = "required" })
                            </div>
                        </div>

                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted"><span>Main Property </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                @Html.DropDownListFor(Model => Model.PROPERTIES_COMP, Model.DropdownProperty, "Select an option..", new { id = "ddlpropertycomp", @class = "ddloption form-control form-select", required = "required", onchange = "this.form.submit() + this.options['action'].value;" })
                            </div>
                        </div>

                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted"><span>Property Item </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                @Html.DropDownListFor(Model => Model.PROP_ITEM_ID, Model.DropdownPropItem, "Select an option..", new { id = "ddlpropitemcomp", @class = "ddloption form-control form-select", required = "required" })
                            </div>
                        </div>

                        <div class="row row-cols-2 mt-4">
                            <div class="col align-self-center">
                                <h6 class="text-muted" style="float: left">Details</h6>
                            </div>
                            <div class="col">
                                <div class="row row-cols-auto justify-content-end g-1">
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-danger" id="removeBtn2" type="button">
                                            Remove
                                        </button>
                                    </div>
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-primary" id="addBtn2" type="button">
                                            Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2 mx-1">
                            <table id="item2-table" class="detailTable" style="width:100%">
                                <thead>
                                    <tr class="toolbar-row">
                                        <th style="width: 3%; text-align: center;">
                                            <input id="trCheckbox2" type="checkbox" class="dt-checkboxes select2-all form-check-input" style="margin-top:5.5px; display:none">
                                        </th>
                                        <th>Product Group</th>
                                        <th>Formula</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var count2 = 0; }
                                    @if (Model.RegressionLstModel != null && Model.RegressionLstModel.Count > 0)
                                    {
                                        foreach (var item in Model.RegressionLstModel)
                                        {
                                            count2++;
                                            <tr id="R2_@count2" data-did="@count2">
                                                <td class="text-center">
                                                    <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk2_@count2" onClick="handleCheckbox2Click(this)">
                                                </td>
                                                <td class="text-left"><select id="item_prodgroupid_comp_@count2" multiple="multiple" class="multiselectpicker select-ddl-item form-control ddl_prodgroup" data-selected="@item.MM_PRODGROUP_H_ID_COMP_STRING"></select></td>
                                                <td>
                                                    <input type="text" class="required-field-comp form-control" id="item_formula_comp_@count2" value="@item.FORMULA_COMP" placeholder="" onclick="showModal(@count2, 'COMP')" readonly>
                                                </td>
                                                <td class="d-none">
                                                    <input type="text" class="form-control" id="item2_stat_@count2" value="0">
                                                    <input type="text" class="form-control" id="item2_dbid_@count2" value="0">
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                            <input type="hidden" id="item2-count" value="@count2" />
                        </div>

                    </div>

                    <div class="tpmInfo" style="display:none">

                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted">Production Line <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-4">
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.PROD_LINE, "CE", new { id = "ceRadio", @class = "form-check-input" })
                                    <label class="form-check-label" for="ceRadio">CE</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.PROD_LINE, "CAP", new { id = "capRadio", @class = "form-check-input" })
                                    <label class="form-check-label" for="capRadio">CAP</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    @Html.RadioButtonFor(m => m.PROD_LINE, "EXT_COMP", new { id = "extcompounderRadio", @class = "form-check-input" })
                                    <label class="form-check-label" for="capRadio">EXT COMPOUNDER</label>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted"><span>Main Property </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                @Html.DropDownListFor(Model => Model.PROPERTIES_TPM, Model.DropdownProperty, "Select an option..", new { id = "ddlpropertytpm", @class = "ddloption form-control form-select", required = "required", onchange = "this.form.submit() + this.options['action'].value;" })
                            </div>
                        </div>

                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted"><span>Property Item </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                @Html.DropDownListFor(Model => Model.PROP_ITEM_ID, Model.DropdownPropItem, "Select an option..", new { id = "ddlpropitemtpm", @class = "ddloption form-control form-select", required = "required", onchange = "resetTPMDetails()" })
                            </div>
                        </div>

                        <div class="row row-cols-2 mt-4">
                            <div class="col align-self-center">
                                <h6 class="text-muted" style="float: left">Details</h6>
                            </div>
                            <div class="col">
                                <div class="row row-cols-auto justify-content-end g-1">
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-danger" id="removeBtn" type="button">
                                            Remove
                                        </button>
                                    </div>
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-primary" id="addBtn" type="button">
                                            Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2 mx-1">
                            <table id="item-table" class="detailTable" style="width:100%">
                                <thead>
                                    <tr class="toolbar-row">
                                        <th style="width: 3%; text-align: center;">
                                            <input id="trCheckbox" type="checkbox" class="dt-checkboxes select-all form-check-input" style="margin-top:5.5px; display:none">
                                        </th>
                                        <th>Product Group</th>
                                        <th>Machine Name</th>
                                        <th>Formula</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var count = 0; }
                                    @if (Model.RegressionLstModel != null && Model.RegressionLstModel.Count > 0)
                                    {
                                        foreach (var item in Model.RegressionLstModel)
                                        {
                                            count++;
                                            <tr id="R_@count" data-did="@count">
                                                <td class="text-center">
                                                    <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_@count" onClick="handleCheckboxClick(this)">
                                                </td>
                                                <td class="text-left"><select id="item_prodgroupid_tpm_@count" multiple="multiple" class="multiselectpicker select-ddl-item form-control ddl_prodgroup" data-selected="@item.MM_PRODGROUP_H_ID_TPM_STRING"></select></td>
                                                <td class="text-left"><select id="item_machinenameid_tpm_@count" class="form-control ddl_machine"><option value="@item.MACHINE_NAME_ID" selected></option></select></td>
                                                <td>
                                                    <input type="text" class="required-field-tpm form-control" id="item_formula_tpm_@count" value="@item.FORMULA_TPM" placeholder="" onclick="showModal(@count, 'TPM')" readonly>
                                                </td>
                                                <td class="d-none">
                                                    <input type="text" class="form-control" id="item_stat_@count" value="0">
                                                    <input type="text" class="form-control" id="item_dbid_@count" value="0">
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                            <input type="hidden" id="item-count" value="@count" />
                        </div>

                    </div>

                </div>
            </div>

            <div class="row row-cols-auto justify-content-end g-1 tr-btm-btn-area" style="padding-right: 20px">
                <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary mx-1 my-button" data-bs-toggle="modal" data-bs-target="#back-confirmation-modal">Back</button></div>
                <div class="col"><button hidden id="btnDraft" type="button" class="btn btn-sm btn-primary">Save As Draft</button></div>
                <div class="col"><button id="btnSubmit" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal">Submit</button></div>
            </div>
        </div>
    </div>

}

@*formula modal*@
<div class="modal fade" id="calmodalregression" tabindex="-1" role="dialog" data-backdrop="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="float:left;">Formula</h5>
            </div>
            <hr />

            <input type="hidden" id="current_count" />
            <input type="hidden" id="current_type" />

            <div class="modal-body" id="searchSourceBody">
                <div class="container-fluid">
                    <div class="row align-items-center">
                        <div class="col-sm-2">
                            <p class="text-muted">Variable <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-5">
                            <button type="button" class="btn btn-outline-dark varian" id="btnvar1" value="var1" onclick='varClickVar("var1"); return false;'>var1</button>
                            @*<button type="button" class="btn btn-outline-dark varinput" id="btnvar2" value="var2" onclick='varClickVar("var2"); return false;'>2</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnvar3" value="var3" onclick='varClickVar("var3"); return false;'>3</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnvar4" value="var4" onclick='varClickVar("var4"); return false;'>4</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnvar5" value="var5" onclick='varClickVar("var5"); return false;'>5</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnvar6" value="var6" onclick='varClickVar("var6"); return false;'>6</button>*@
                        </div>
                    </div>

                    <div class="row align-items-center">
                        <div class="col-sm-2">
                            <p class="text-muted">Symbol <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-5">
                            <button type="button" class="btn btn-outline-dark varinput" id="btnsym1" value="(" onclick='varClickSymbol("("); return false;'>(</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnsym2" value=")" onclick='varClickSymbol(")"); return false;'>)</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnsym3" value="+" onclick='varClickSymbol("+"); return false;'>+</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnsym4" value="-" onclick='varClickSymbol("-"); return false;'>-</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnsym5" value="*" onclick='varClickSymbol("*"); return false;'>*</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnsym6" value="/" onclick='varClickSymbol("/"); return false;'>/</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnsym7" value="." onclick='varClickNumber("."); return false;'>.</button>
                        </div>
                    </div>

                    <div class="row align-items-center">
                        <div class="col-sm-2">
                            <p class="text-muted">Number <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-7">
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum1" value="1" onclick='varClickNumber("1"); return false;'>1</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum2" value="2" onclick='varClickNumber("2"); return false;'>2</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum3" value="3" onclick='varClickNumber("3"); return false;'>3</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum4" value="4" onclick='varClickNumber("4"); return false;'>4</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum5" value="5" onclick='varClickNumber("5"); return false;'>5</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum6" value="6" onclick='varClickNumber("6"); return false;'>6</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum7" value="7" onclick='varClickNumber("7"); return false;'>7</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum8" value="8" onclick='varClickNumber("8"); return false;'>8</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum9" value="9" onclick='varClickNumber("9"); return false;'>9</button>
                            <button type="button" class="btn btn-outline-dark varinput" id="btnnum0" value="0" onclick='varClickNumber("0"); return false;'>0</button>
                        </div>
                    </div>

                    <div class="row mt-2 align-items-center">
                        <div class="col-sm-2">
                            <p class="text-muted">Formula <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-6">
                            <input class="form-control modalform required-field-modal" id="txt_modal_1" type="text" disabled />
                        </div>
                        <div class="col-sm-3">
                            <button type="button" class="btn btn-outline-dark varerase" id="btnerase" value="Backspace" onclick='varClickErase(); return false;'>Backspace</button>
                        </div>
                    </div>

                </div>
            </div>
            <div class="modal-footer">
                <button type="reset" id="btnResetModal" class="btn btn-sm btn-secondary" style="margin-right: auto;">Reset</button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Back</button>
                <button type="button" id="btnsubmitcal" class="btn btn-sm btn-primary">OK</button>
            </div>
        </div>
    </div>
</div>

@section scripts{

    <script>

        $(document).ready(function () {
            checkboxChecking();
            checkbox2Checking();
            var listingURL = appBasePath + 'MM_REGRESSION/MM_REGRESSION_LST';

            var idh = '@Model.MM_REGRESSION_H_ID' != 0 ? '@Model.MM_REGRESSION_H_ID' : 0;

            fillProdGroup($(".ddl_prodgroup"));
            fillMachine();

            var type = $("#compGroupHidden").val();

            //control ui based on sampling type
            if (type == "COMPOUNDER") {
                $('.tpmInfo').hide();
                $('.compInfo').show();
            } else {
                if (type == "TPM") {
                    $('.compInfo').hide();
                    $('.tpmInfo').show();
                } else {
                    $('.compInfo').hide();
                    $('.tpmInfo').hide();
                }
            }

            //SUBMIT FOR MODAL
            $("#btnsubmitcal").click(function () {

                var cont = true;

                $('.invalid-feedback').remove();
                $('.is-invalid').removeClass('is-invalid');

                $('.required-field-modal').each(function (e) {
                    var input_val = $(this).val().trim();
                    if (input_val == null || input_val == undefined || input_val === "") {
                        cont = false;
                        $(this).addClass('is-invalid');
                        inputError(this);
                    }
                });

                if (cont) {
                    var comptype = $("#current_type").val();
                    var count = $("#current_count").val();

                    if (comptype == "TPM") {
                        $("#item_formula_tpm_" + count).val($("#txt_modal_1").val());
                    } else {
                        if (comptype == "COMP") {
                            $("#item_formula_comp_" + count).val($("#txt_modal_1").val());
                        }
                    }

                    $("#calmodalregression").modal("hide");
                }
            });

            //ADD TPM
            $('#addBtn').on('click', function () {

                var cont = true;
                var message = "";

                var ddlpropitemtpm = $("#ddlpropitemtpm").val();

                if (ddlpropitemtpm == undefined || ddlpropitemtpm == null || ddlpropitemtpm == 0 || ddlpropitemtpm == "" || ddlpropitemtpm == "Select an option..") {
                    cont = false;
                    message += 'Please select Property Item First. <br>';
                }

                if (cont) {
                    var rowIdx = $('#item-count').val();
                    rowIdx++;
                    $('#item-count').val(rowIdx);


                    $('#item-table tbody').append(`
                        <tr id="R_${rowIdx}" data-did="${rowIdx}">
                            <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClick(this)"></td>
                            <td class="text-left"><select id="item_prodgroupid_tpm_${rowIdx}" multiple="multiple" class="multiselectpicker select-ddl-item form-control ddl_prodgroup"></select></td>
                            <td class="text-left"><select id="item_machinenameid_tpm_${rowIdx}" class="form-control ddl_machine"><option value="0" selected></option></select></td>
                            <td><input type="text" class="form-control required-field-tpm" id="item_formula_tpm_${rowIdx}" placeholder="" onclick="showModal(${rowIdx}, 'TPM')" readonly ></td>
                            <td class="d-none">
                                <input type="text" id="item_stat_${rowIdx}" value="1">
                                <input type="text" id="item_dbid_${rowIdx}" value="0">

                            </td>
                        </tr>
                        `);

                    var newSelect = $('#item_prodgroupid_tpm_' + rowIdx);
                    fillProdGroup(newSelect);
                    reinitializeMultiselect();
                    fillMachine();

                    checkboxChecking();
                } else {
                    if (message != "") {
                        displayToast("error", message)
                    }
                }

            });

            //REMOVE TPM
            $('#removeBtn').on('click', function () {
                $('#item-table tbody input[type=checkbox][id^="chk_"]:checked').each(function (idx, ele) {
                    var row = $(ele).closest('tr');
                    var itemStatInput = row.find('input[id^="item_stat_"]');
                    var item_stat = itemStatInput.val();

                    //if (item_stat != '1') {
                    //    itemStatInput.val('5');
                    //    row.hide();
                    //} else {
                    //    row.remove();
                    //}

                    row.remove();
                });

                checkboxChecking();
            });

            //ADD COMPOUNDER
            $('#addBtn2').on('click', function () {

                var rowIdx = $('#item2-count').val();
                rowIdx++;
                $('#item2-count').val(rowIdx);

                $('#item2-table tbody').append(`
                        <tr id="R2_${rowIdx}" data-did="${rowIdx}">
                            <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk2_${rowIdx}" onClick="handleCheckbox2Click(this)"></td>
                            <td class="text-left"><select id="item_prodgroupid_comp_${rowIdx}" multiple="multiple" class="multiselectpicker select-ddl-item form-control ddl_prodgroup"></select></td>
                            <td><input type="text" class="form-control required-field-comp" id="item_formula_comp_${rowIdx}" placeholder="" onclick="showModal(${rowIdx}, 'COMP')" readonly ></td>
                            <td class="d-none">
                                <input type="text" id="item2_stat_${rowIdx}" value="1">
                                <input type="text" id="item2_dbid_${rowIdx}" value="0">

                            </td>
                        </tr>
                        `);

                var newSelect = $('#item_prodgroupid_comp_' + rowIdx);
                fillProdGroup(newSelect);
                reinitializeMultiselect();

                checkbox2Checking();

            });

            //REMOVE COMPOUNDER
            $('#removeBtn2').on('click', function () {
                $('#item2-table tbody input[type=checkbox][id^="chk2_"]:checked').each(function (idx, ele) {
                    var row = $(ele).closest('tr');
                    var itemStatInput = row.find('input[id^="item2_stat_"]');
                    var item2_stat = itemStatInput.val();

                    //if (item2_stat != '1') {
                    //    itemStatInput.val('5');
                    //    row.hide();
                    //} else {
                    //    row.remove();
                    //}

                    row.remove();
                });

                checkbox2Checking();
            });

            //SUBMIT
            $('#btnConfirmSubmit').on('click', function () {
                $('.invalid-feedback').remove();
                $('.is-invalid').removeClass('is-invalid');

                var cont = true;
                var message = "";

                var model = {};
                var list = [];
                var comptype = $("#compGroupHidden").val();

                var celine = $('#ceRadio').is(':checked');
                var capline = $('#capRadio').is(':checked');
                var extline = $('#extcompounderRadio').is(':checked');
                var prod_line = "";

                if (celine) {
                    prod_line = "CE"
                } else {
                    if (capline) {
                        prod_line = "CAP"
                    } else {
                        if (extline) {
                            prod_line = "EXT_COMP"
                        }
                    }
                }

                if (comptype == "COMPOUNDER") {
                    // SUBMIT FOR COMPOUNDER
