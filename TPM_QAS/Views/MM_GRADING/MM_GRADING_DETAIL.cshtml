@using TPM_QAS.Models
@model GradingModel


@{
    ViewBag.Title = "GRADING MM - Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row g-0 px-3 tr-listing-header">
    <div class="col-sm-6 align-self-center">
        <p class="text-muted m-0 tr-listing-header-title main-title">View Form - Grading</p>
    </div>
    <div class="col-sm-6 text-end align-self-center">
        <div class="d-flex justify-content-end">
            <div id="customDTButton"></div>
        </div>
    </div>
</div>

<div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

<div class="page-container px-3 overflow-auto">
    <div class="tr-btm-btn-margin">
        <div class="card mt-3 mb-2 card-height">
            <div class="card-body">
                <div class="row align-items-baseline">
                    <div class="col"><h6 class="card-title text-muted">Grading</h6></div>
                    @if (Model.RECORD_TYP != null)
                    {
                        if (@Model.RECORD_TYP != "5")
                        {
                            <div class="col text-end"><button class="btn btn-sm btn-primary" id="btnEdit" type="button" data-behaviour="toggle">Edit</button></div>
                        }

                    }
                </div>

                <hr />
                @Html.HiddenFor(model => model.COMP_GROUP, new { id = "compGroupHidden" })
                <input type="text" id="temp_properties" hidden>
                <input type="text" id="temp_section" hidden>

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Company Group <span class="text-danger">*</span><span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-check form-check-inline">
                            <input class=" form-check-input isEditable" type="radio" name="compgroup" id="compounderRadio" value="COMPOUNDER" onchange="handleRadioChange()"
                                   @(Model.COMP_GROUP != null && Model.COMP_GROUP.ToString() == "COMPOUNDER" ? "checked" : "") disabled>
                            <label class="form-check-label" for="compounderRadio">Compounder</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class=" form-check-input isEditable" type="radio" name="compgroup" id="tpmRadio" value="TPM" onchange="handleRadioChange()"
                                   @(Model.COMP_GROUP != null && Model.COMP_GROUP.ToString() == "TPM" ? "checked" : "") disabled>
                            <label class="form-check-label" for="tpmRadio">TPM</label>
                        </div>

                    </div>
                </div>

                <div class="radioline" style="display:none">
                    <div class="row align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Production Line <span class="text-danger">*</span><span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-check form-check-inline">
                                <input class=" form-check-input isEditable" type="radio" name="prodline" id="ceRadio" value="CE"
                                       @(Model.PROD_LINE != null && Model.PROD_LINE.ToString() == "CE" ? "checked" : "") disabled>
                                <label class="form-check-label" for="ceRadio">CE</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class=" form-check-input isEditable" type="radio" name="prodline" id="capRadio" value="CAP"
                                       @(Model.PROD_LINE != null && Model.PROD_LINE.ToString() == "CAP" ? "checked" : "") disabled>
                                <label class="form-check-label" for="capRadio">CAP</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Product Type <span class="text-danger">*</span><span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        @Html.DropDownListFor(Model => Model.MM_PRODTYPE_H_ID, Model.DropdownProdType, "Select an option..", new { id = "ddlprodtype", @class = "ddloption isEditable form-control form-select", required = "required", disabled = "disabled" })
                    </div>
                    <div class="col-sm-4">
                        <button class="btn btn-sm btn-md btn-primary d-none isEditable" id="gradDuplBtn" type="button" onclick="popupGradingDuplicate()">
                            Duplicate
                        </button>
                    </div>

                </div>

                <nav class="tr-tab">
                    <div class="nav nav-tabs" id="nav-tab" role="tablist">
                        <button class="nav-link active" id="nav-normal-tab" data-bs-toggle="tab" data-bs-target="#nav-normal" type="button" role="tab" aria-controls="nav-normal" aria-selected="true">Normal</button>
                        <button class="nav-link" id="nav-appearance-tab" data-bs-toggle="tab" data-bs-target="#nav-appearance" type="button" role="tab" aria-controls="nav-appearance" aria-selected="false">Appearance</button>
                        <button class="nav-link" id="nav-passgrade-tab" data-bs-toggle="tab" data-bs-target="#nav-passgrade" type="button" role="tab" aria-controls="nav-passgrade" aria-selected="false">Passing Grade</button>
                    </div>

                </nav>
                <div class="tab-content p-2" id="nav-tabContent" style="border: 4px solid #EBF3FF;">

                    @*TAB 1*@
                    <div class="tab-pane fade show active" id="nav-normal" role="tabpanel" aria-labelledby="nav-normal-tab" tabindex="0">
                        <div class="row row-cols-2 mt-4">
                            <div class="col align-self-center">
                                <h6 class="text-muted" style="float: left">Properties Listing</h6>
                            </div>
                            <div class="d-none isEditable col">
                                <div class="row row-cols-auto justify-content-end g-1">
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-danger" id="removeBtn" type="button">
                                            Remove
                                        </button>
                                    </div>
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-primary" id="addBtn" type="button">
                                            Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2 mx-1">
                            <table id="item-table" class="detailTable" style="width:100%">
                                <thead>
                                    <tr class="toolbar-row">
                                        <th class="d-none isEditable" style="width: 3%; text-align: center;">
                                            <input id="trCheckbox" type="checkbox" class="dt-checkboxes select-all form-check-input" style="margin-top:5.5px; display:none">
                                        </th>
                                        <th class="d-none isEditable"></th>
                                        <th>Main Property</th>
                                        <th>Property Item</th>
                                        <th>Priority</th>
                                        <th>Final Priority</th>
                                        <th>Lower Spec</th>
                                        <th>Upper Spec</th>
                                        <th>Lower PCL</th>
                                        <th>Upper PCL</th>
                                        <th>Centre Line</th>
                                        <th>Grade</th>
                                        <th>Rounding</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var count = 0; }
                                    @if (Model.GradingNormalLstModel != null && Model.GradingNormalLstModel.Count > 0)
                                    {
                                        foreach (var item in Model.GradingNormalLstModel)
                                        {
                                            count++;
                                            <tr id="R_@count" data-did="@count">
                                                <td class="d-none isEditable text-center">
                                                    <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_@count" onClick="handleCheckboxClick(this)">
                                                </td>
                                                <td class="d-none sort-handle isEditable">
                                                    <div style="display: inline-flex">
                                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                                    </div>
                                                </td>
                                                <td class="text-left">
                                                    <select id="item_property_norm_@count" class="isEditable select-ddl-item form-control ddl_property" onchange="loadpropitem(@count)" style="border:none; box-shadow: none;min-width:160px;" readonly>
                                                        <option value="@item.PROPERTY" selected></option>
                                                    </select>
                                                </td>
                                                <td class="text-left">
                                                    <select id="item_propitem_norm_@count" class="isEditable select-ddl-item form-control ddl_propitem" style="border:none; box-shadow: none;min-width:160px;" readonly><option value="@item.MM_PROPERTIES_H_ID" selected></option></select>
                                                </td>
                                                <td><input type="text" class="isEditable form-control" id="item_prio_norm_@count" value="@item.PRIORITY" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control" id="item_finalprio_norm_@count" value="@item.FINAL_PRIORITY" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput lspec-input" id="item_lspec_norm_@count" value="@item.L_SPEC" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput uspec-input" id="item_uspec_norm_@count" value="@item.U_SPEC" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput lpcl-input" id="item_lpcl_norm_@count" value="@item.L_PCL" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput upcl-input" id="item_upcl_norm_@count" value="@item.U_PCL" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput" id="item_centre_norm_@count" value="@item.CENTRE_LINE" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control" id="item_grade_norm_@count" value="@item.GRADE" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control" id="item_rounding_norm_@count" value="@item.ROUNDING" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td class="d-none">
                                                    <input type="text" class="form-control" id="item_stat_@count" value="0">
                                                    <input type="text" class="form-control" id="item_dbid_@count" value="@item.MM_GRADING_D1_ID">
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                            <input type="hidden" id="item-count" value="@count" />
                        </div>

                    </div>

                    @*TAB 2*@
                    <div class="tab-pane fade" id="nav-appearance" role="tabpanel" aria-labelledby="nav-appearance-tab" tabindex="0">

                        <div class="row row-cols-2 mt-4">
                            <div class="col align-self-center">
                                <h6 class="text-muted" style="float: left">Properties Listing</h6>
                            </div>
                            <div class="d-none isEditable col">
                                <div class="row row-cols-auto justify-content-end g-1">
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-danger" id="removeBtn2" type="button">
                                            Remove
                                        </button>
                                    </div>
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-primary" id="addBtn2" type="button">
                                            Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-2 mx-1">
                            <table id="item2-table" class="detailTable" style="width:100%">
                                <thead>
                                    <tr class="toolbar-row">
                                        <th class="d-none isEditable" style="width: 3%; text-align: center;">
                                            <input id="trCheckbox2" type="checkbox" class="dt-checkboxes select2-all form-check-input" style="margin-top:5.5px; display:none">
                                        </th>
                                        <th class="d-none isEditable"></th>
                                        <th>Section Name</th>
                                        <th>Field Name</th>
                                        <th>Priority</th>
                                        <th>Final Priority</th>
                                        <th>Lower Spec</th>
                                        <th>Upper Spec</th>
                                        <th>Lower PCL</th>
                                        <th>Upper PCL</th>
                                        <th>Calculation</th>
                                        <th>Grade</th>
                                        <th>Rounding</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var count2 = 0; }
                                    @if (Model.GradingAppearanceLstModel != null && Model.GradingAppearanceLstModel.Count > 0)
                                    {
                                        foreach (var item in Model.GradingAppearanceLstModel)
                                        {
                                            count2++;
                                            <tr id="R2_@count2" data-did="@count2">
                                                <td class="d-none isEditable text-center">
                                                    <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk2_@count2" onClick="handleCheckbox2Click(this)">
                                                </td>
                                                <td class="d-none sort-handle isEditable">
                                                    <div style="display: inline-flex">
                                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                                    </div>
                                                </td>
                                                <td class="text-left">
                                                    <select id="item_section_appr_@count2" class="isEditable select-ddl-item form-control ddl_section" onchange="loadfield(@count2)" style="border:none; box-shadow: none;min-width:160px;" readonly>
                                                        <option value="@item.SECTION" selected></option>
                                                    </select>
                                                </td>

                                                <td class="text-left"><select id="item_field_appr_@count2" class="isEditable select-ddl-item form-control ddl_field" style="border:none; box-shadow: none;min-width:160px;" readonly><option value="@item.FIELD_NAME" selected></option></select></td>
                                                <td><input type="text" class="isEditable form-control" id="item_prio_appr_@count2" value="@item.PRIORITY" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control" id="item_finalprio_appr_@count2" value="@item.FINAL_PRIORITY" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput lspec-input" id="item_lspec_appr_@count2" value="@item.L_SPEC" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput uspec-input" id="item_uspec_appr_@count2" value="@item.U_SPEC" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput lpcl-input" id="item_lpcl_appr_@count2" value="@item.L_PCL" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput upcl-input" id="item_upcl_appr_@count2" value="@item.U_PCL" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control numericInput" id="item_cal_appr_@count2" value="@item.CALCULATION" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control" id="item_grade_appr_@count2" value="@item.GRADE" style="border:none; box-shadow: none;" readonly></td>
                                                <td><input type="text" class="isEditable form-control" id="item_rounding_appr_@count2" value="@item.ROUNDING" onkeypress="return isNumberKey(event)" style="border:none; box-shadow: none;" readonly></td>
                                                <td class="d-none">
                                                    <input type="text" class="form-control" id="item2_stat_@count2" value="0">
                                                    <input type="text" class="form-control" id="item2_dbid_@count2" value="@item.MM_GRADING_D2_ID">
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                            <input type="hidden" id="item2-count" value="@count2" />
                        </div>

                    </div>

                    @*TAB 3*@
                    <div class="tab-pane fade" id="nav-passgrade" role="tabpanel" aria-labelledby="nav-passgrade-tab" tabindex="0">
                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted"><span>Property </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                @Html.DropDownListFor(Model => Model.PROPERTIES, Model.DropdownProperty, "Select an option..", new { id = "ddlpropertypass", @class = "ddloption isEditable form-control form-select", required = "required", onchange = "loadPropItemPass()", disabled = "disabled" })
                            </div>
                        </div>

                        <div class="row mt-2 align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted"><span>Property Item </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                @Html.DropDownListFor(Model => Model.MM_PROPERTIES_H_ID, Model.DropdownItem, "Select an option..", new { id = "ddlpropitempass", @class = "ddloption isEditable form-control form-select", required = "required", disabled = "disabled" })
                            </div>
                        </div>

                        <div class="row row-cols-2 mt-4">
                            <div class="col align-self-center">
                                <h6 class="text-muted" style="float: left">Details</h6>
                            </div>
                            <div class="d-none isEditable col">
                                <div class="row row-cols-auto justify-content-end g-1">
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-danger" id="removeBtn3" type="button">
                                            Remove
                                        </button>
                                    </div>
                                    <div class="col">
                                        <button class="btn btn-sm btn-md btn-primary" id="addBtn3" type="button">
                                            Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-2 mx-1">
                            <table id="item3-table" class="detailTable" style="width:100%">
                                <thead>
                                    <tr class="toolbar-row">
                                        <th class="d-none isEditable" style="width: 3%; text-align: center;">
                                            <input id="trCheckbox3" type="checkbox" class="dt-checkboxes select3-all form-check-input" style="margin-top:5.5px; display:none">
                                        </th>
                                        <th>Property Item</th>
                                        <th>Passing Grade</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var count3 = 0; }
                                    @if (Model.GradingPassingLstModel != null && Model.GradingPassingLstModel.Count > 0)
                                    {
                                        foreach (var item in Model.GradingPassingLstModel)
                                        {
                                            count3++;
                                            <tr id="R3_@count3" data-did="@count3">
                                                <td class="d-none isEditable text-center">
                                                    <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk3_@count3" onClick="handleCheckbox3Click(this)">
                                                </td>
                                                <td>
                                                    <input type="text" class="isItemDisabled form-control" id="item_propitem_pass_@count3" value="@item.PROP_ITEM" placeholder="" style="border:none; box-shadow: none;" readonly>
                                                </td>
                                                <td>
                                                    <input type="text" class="isEditable form-control" id="item_passgrade_pass_@count3" value="@item.PASS_GRADE" placeholder="" style="border:none; box-shadow: none;" readonly>
                                                </td>
                                                <td class="d-none">
                                                    <input type="text" class="form-control" id="item3_stat_@count3" value="0">
                                                    <input type="text" class="form-control" id="item3_dbid_@count3" value="@item.MM_GRADING_D3_ID">
                                                    <input type="text" class="form-control" id="item_properties_pass_@count3" value="@item.PROPERTIES">
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                            <input type="hidden" id="item3-count" value="@count3" />
                        </div>


                    </div>
                </div>

                <div class="hideInfo">
                    <hr />

                    <div class="row row-cols-2 mt-4">
                        <div class="col align-self-center">
                            <h6 style="float: left" class="text-muted">Entry Details</h6>
                        </div>
                        <div class="col">

                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_BY">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_BY">
                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_DATE">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_DATE">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row tr-btm-btn-area">
            @if (Model.RECORD_TYP != null)
            {
                if (@Model.RECORD_TYP != "5")
                {
                    <div class="col"><button id="btnDeleteView" type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#delete-confirmation-modal">Delete</button></div>
                }

            }
            <div class="col">
                <div class="row row-cols-auto justify-content-end isNotEditable" style="padding-right: 20px">
                    <div class="col"><button id="btnCancelView" type="button" class="btn btn-sm btn-secondary">Back</button></div>
                </div>

                <div class="row row-cols-auto justify-content-end isEditable g-1" style="display:none; padding-right: 20px">
                    <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#edit-back-confirmation-modal">Back</button></div>
                    <div class="col"><button id="btnSubmit" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal">Submit</button></div>
                </div>
            </div>
        </div>

    </div>
</div>



@section scripts {
    <script>
    var idh = '@Model.MM_GRADING_H_ID';

    $(document).ready(function () {
        checkboxChecking();
        checkbox2Checking();
        checkbox3Checking();

        var listingURL = '/MM_GRADING/MM_GRADING_LST';

        fillProperty();
        fillPropItem();
        fillSection();
        fillFieldName();

        $("#item-table tbody, #item2-table tbody").sortable({
            handle: ".sort-handle",
            axis: "y" // Enable vertical sorting only if needed
        }).disableSelection();

        //control ui based on Company Group
        var type = $("#compGroupHidden").val();
        if (type == "TPM") {
            $('.radioline').show();
        } else {
            $('.radioline').hide();
        }

        //ADD D1
        $('#addBtn').on('click', function () {

            var rowIdx = $('#item-count').val();
            rowIdx++;
            $('#item-count').val(rowIdx);

            $('#item-table tbody').append(`
                    <tr id="R_${rowIdx}" data-did="${rowIdx}">
                        <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClick(this)"></td>
                        <td class="sort-handle">
                            <div style="display: inline-flex">
                                <i class="fa-solid fa-ellipsis-vertical"></i>
