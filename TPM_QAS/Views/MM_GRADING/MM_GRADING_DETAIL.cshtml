                return;
            }
            // 3️⃣ Check if upcl is defined and lpcl > upcl
            if (!isNaN(upcl) && upcl !== 0 && lpcl > upcl) {
                alert("Lower PCL cannot be greater than Upper PCL!");
                $(this).val('0.000'); // clear lpcl input
                return;
            }
