        $(document).on('change', '.lpcl-input', function () {
            var $row = $(this).closest('tr'); // safer and cleaner than parent().parent()
            var lspec = parseFloat($row.find('.lspec-input').val());
            var uspec = parseFloat($row.find('.uspec-input').val());
            var upcl = parseFloat($row.find('.upcl-input').val());
            var lpcl = parseFloat($(this).val()); // current input value

            // 1️⃣ Check if specs are defined
            if (isNaN(lspec) || isNaN(uspec) || (lspec === 0 && uspec === 0)) {
                alert("Spec must be defined first!");
                $(this).val('0.000'); // clear lpcl input
                return;
            }
            // 2️⃣ Check if lpcl is within the spec range
            if (lpcl < lspec || lpcl > uspec) {
                alert("PCL is out of spec range (" + lspec + " - " + uspec + ")!");
                $(this).val('0.000'); // clear lpcl input
                return;
            }
            // 3️⃣ Check if upcl is defined and lpcl > upcl
            if (!isNaN(upcl) && upcl !== 0 && lpcl > upcl) {
                alert("Lower PCL cannot be greater than Upper PCL!");
                $(this).val('0.000'); // clear lpcl input
                return;
            }
        });

        $(document).on('change', '.upcl-input', function () {
            var $row = $(this).closest('tr'); // safer and cleaner than parent().parent()
