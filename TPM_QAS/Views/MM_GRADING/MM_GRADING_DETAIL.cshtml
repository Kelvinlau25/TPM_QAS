    function fillProdType(comp_group) {

    $.getJSON('@Url.Action("fillProdType", "MM_GRADING")?comp=' + comp_group, function (data) {
        if (data != null && !jQuery.isEmptyObject(data)) {
            var ddl_field = $("#ddlprodtype");

            if (ddl_field != undefined) {
                var currentSelected = ddl_field.val();
                ddl_field.empty();
                $.each(data, function (index, datas) {
                    ddl_field.append($('<option/>', {
                        value: datas.Value,
                        text: datas.Text
                    }));
                });
                ddl_field.val(currentSelected);
            }
        }
    });
}

    function loadpropitem(count) {
        var propertyy = $("#item_property_norm_" + count).val();
        $("#temp_properties").val(propertyy);

        var ddl_propitem = $("#item-table tr#R_" + count + " .ddl_propitem");
        fillPropItem(count, ddl_propitem);
    }

    function loadfield(count) {
        var sectionn = $("#item_section_appr_" + count).val();
        $("#temp_section").val(sectionn);
        fillFieldName(count);
    }

    //ddl_property
    function fillProperty() {
        $.getJSON('@Url.Action("fillProperty", "MM_GRADING")', function (data) {
            if (data != null && !jQuery.isEmptyObject(data)) {
                $(".ddl_property").each(function () {
                    var ddl_property = $(this);
                    var currentSelected = ddl_property.val();
                    ddl_property.empty();
                    $.each(data, function (index, datas) {
                        ddl_property.append($('<option/>', {
                            value: datas.Value,
                            text: datas.Text
                        }));
                    });
                    ddl_property.val(currentSelected);
                    // Trigger change to load propitem dropdown on page load
                    ddl_property.change();
                });
            }
        });
    }


    //ddl_propitem
    function fillPropItem(count, ddl_propitem) {
        if (ddl_propitem != null) {
            var temp_properties = $("#temp_properties").val();
            $.getJSON('@Url.Action("fillPropItem", "MM_GRADING")?property=' + temp_properties, function (data) {
                if (data != null && !jQuery.isEmptyObject(data)) {
                    var currentSelected = ddl_propitem.val();
                    ddl_propitem.empty();
                    $.each(data, function (index, datas) {
                        ddl_propitem.append($('<option/>', {
                            value: datas.Value,
                            text: datas.Text
                        }));
                    });
                    ddl_propitem.val(currentSelected);
                }
            });
        }
    }

    //ddl_section
    function fillSection() {
        $.getJSON('@Url.Action("fillSection", "MM_GRADING")', function (data) {
        if (data != null && !jQuery.isEmptyObject(data)) {
            $(".ddl_section").each(function () {
                var ddl_section = $(this);
                var currentSelected = ddl_section.val();
                ddl_section.empty();
                $.each(data, function (index, datas) {
                    ddl_section.append($('<option/>', {
                        value: datas.Value,
