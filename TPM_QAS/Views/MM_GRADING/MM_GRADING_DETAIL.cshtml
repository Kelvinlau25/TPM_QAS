    function loadPropItemPass() {
        $("#item3-table tbody").empty();
        var ddlpropertypass = $("#ddlpropertypass").val();

        $.getJSON('@Url.Action("fillPropItem", "MM_GRADING")?property=' + ddlpropertypass, function (data) {
