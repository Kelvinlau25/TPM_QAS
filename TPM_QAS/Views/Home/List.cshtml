
@{
    ViewBag.Title = "List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>    
    .status-select {
        border: 0px;
    }

    .tr-text {
        text-align: end;
    }

    @@media (max-width: 576px) {
        .tr-text {
            text-align: start;
        }
    }

    .toolbar {
        float: right;
    }

    /* Override -2px, form some reason the non-bootstrap is -6px */
    table.dataTable tbody td.select-checkbox::before,
    table.dataTable tbody th.select-checkbox::before {
        margin-top: -6px;
    }

    /**, *:before, *:after {
        box-sizing: border-box;
        font-size: 14px;
    }*/

    .styled-select {
        position: relative;
        display: flex;
        align-items: center;
        width: 300px;
        /*margin: 100px auto 0 auto;*/
        font-family: "Helvetica", "Arial", sans-serif;
    }

        .styled-select label {
            flex: 1 1 60px;
        }

        .styled-select .select-wrapper {
            border: none;
            flex: 1 1 100%;
            background: white;
            border-radius: 5px;
            position: relative;
        }

    .select-wrapper[data-prefix]:before {
        content: attr(data-prefix);
        display: flex;
        align-items: center;
        position: absolute;
        z-index: 0;
        left: 0;
        top: 0;
        bottom: 0;
        padding: 0 5px 0 10px;
        /*color: #b3b3b3;*/
    }

    .styled-select .select-wrapper[data-suffix]:after {
        content: attr(data-suffix);
        display: flex;
        align-items: center;
        position: absolute;
        z-index: 0;
        right: 23px;
        top: 0;
        bottom: 0;
        padding: 0 10px 0 5px;
        /*color: #b3b3b3;*/
    }

    /*.styled-select .select-wrapper:focus-within {
                border-color: #00a7e1;
            }*/

    /*.styled-select .select-wrapper:focus-within:before, .styled-select .select-wrapper:focus-within:after, .styled-select .select-wrapper:focus-within .fas {
                    color: #00a7e1;
                }*/

    .styled-select .select-wrapper select {
        display: block;
        padding-top: 10px;
        padding-bottom: 10px;
        width: 100%;
        border: none;
        outline: none;
        -webkit-appearance: none;
        position: relative;
        z-index: 1;
        background: transparent;
        font-size: 16px;
    }

    /*.styled-select .select-wrapper select.default-value {
                    color: #b3b3b3;
                }*/

    .styled-select .select-wrapper .fas {
        display: flex;
        align-items: center;
        font-size: 14px;
        position: absolute;
        z-index: 0;
        top: 0;
        right: 0;
        bottom: 0;
        padding: 0 10px 0 0;
        width: 23px;
        /*color: #b3b3b3;*/
    }

    .tr-no-border {
        border: 0px !important;
    }    
</style>

<div class="tr-btm-btn-margin">
    <div class="row g-0 tr-listing-header">
        <div class="col-sm-6 align-self-center">
            <p class="text-muted m-0 tr-listing-header-title">Data Table Listing 1</p>
        </div>
        <div class="col-sm-6 text-end align-self-center">
            <div class="d-flex justify-content-end">
                <div id="customDTButton"></div>
            </div>
        </div>
    </div>

    <div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

    <div class="row pt-3 pb-2">
        <div class="col-12 col-sm-8">
            <div class="accordion" id="accordionExample">
                <div class="accordion-item" style="border-radius: 0px !important">
                    <div class="row align-items-center">
                        <select class="tr-select" id="select-id" style="color: #FCFCFC; border: 0px">
                            <option selected>All</option>
                            <option>Draft</option>
                            <option>Pending Approval</option>
                            <option>In Progress</option>
                            <option>Completed</option>
                            <option>Rejected</option>
                        </select>
                        @*<div class="styled-select">
                                <div class="select-wrapper" data-prefix="Status :" data-suffix="">
                                    <select class="form-select form-select-lg">
                                        <option selected>All</option>
                                        <option>Draft</option>
                                        <option>Pending Approval</option>
                                        <option>In Progress</option>
                                        <option>Completed</option>
                                        <option>Rejected</option>
                                    </select>
                                    <div class="fas fa-chevron-down"></div>
                                </div>
                            </div>*@
                    </div>
                    @*<h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button remove-bg-color" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne1" aria-expanded="true" aria-controls="collapseOne">
                                Status :
                            </button>
                        </h2>*@
                    <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#accordionExample" style="border-top: 1px solid #F0F0F0">
                        <div class="accordion-body text-center">
                            <p class="h6 m-0 p-2" style="color: #00A251">120</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-4 align-self-end tr-text pb-0 mb-0" id="action-bar">
            @*<button type="button" class="btn btn-link m-0 p-0" id="btnAuditTrail">Audit Trail</button>*@
        </div>
    </div>

    <div class="row">
        <table id="tr-datatable" class="table table-hover table-bordered compact" style="width:100%; margin-top: 0px !important">
            <thead>
                <tr style="background-color: #FCFCFC">
                    <th></th>
                    <th>Name</th>
                    <th>Position</th>
                    <th>Salary</th>
                    <th>Office</th>
                    <th>View</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <div class="row tr-btm-btn-area">
        <div class="col">
            <div class="aud export-section"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmation-modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmation</h5>
            </div>

            <hr />

            <div class="modal-body">
                <h6>Are you sure to delete this record?</h6>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="btnConfirm2">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="advance-search-modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Advanced Search</h5>
            </div>

            <hr />

            <div class="modal-body">
                <div class="container-fluid">
                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Text Box:</div>
                        <div class="col-md-4"><input class="form-control" type="text" /></div>
                        <div class="col-md-2 isLabel">Single Select</div>
                        <div class="col-md-4">
                            <select class="tr-select2" id="select-id" data-placeholder="&nbsp;">
                                <option>&nbsp;</option>
                                <option>Sample 1</option>
                                <option>Sample 2</option>
                                <option>Sample 3</option>
                            </select>
                        </div>
                    </div>

                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Single Select:</div>
                        <div class="col-md-4">
                            <select class="tr-select2" id="select-id" data-placeholder="&nbsp;">
                                <option>&nbsp;</option>
                                <option>Sample 1</option>
                                <option>Sample 2</option>
                                <option>Sample 3</option>
                            </select>
                        </div>
                        <div class="col-md-2 isLabel">Multiple Select</div>
                        <div class="col-md-4">
                            <select class="multiselectpicker form-control" multiple="multiple" data-placeholder="&nbsp;">
                                <option value="sample1">Sample 1</option>
                                <option value="sample2">Sample 2</option>
                                <option value="sample3">Sample 3</option>
                            </select>
                        </div>
                    </div>

                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Multiple Select:</div>
                        <div class="col-md-4">
                            <select class="multiselectpicker form-control" multiple="multiple" data-placeholder="&nbsp;">
                                <option value="sample1">Sample 1</option>
                                <option value="sample2">Sample 2</option>
                                <option value="sample3">Sample 3</option>
                            </select>
                        </div>
                        <div class="col-md-2 isLabel">Disabled Input:</div>
                        <div class="col-md-4">
                            <select class="multiselectpicker2 form-control" multiple="multiple" data-placeholder="&nbsp;" disabled>
                                <option value="Disabled input example" selected>Disabled input example</option>
                                <option value="sample2">Sample 2</option>
                                <option value="sample3">Sample 3</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="reset" id="btnReset" class="btn btn-sm btn-secondary" style="margin-right: auto;">Reset</button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Back</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnSearchAS" data-bs-dismiss="modal">Search</button>
            </div>
        </div>
    </div>
</div>



