                        $(node).removeClass('btn btn-secondary')
                    },
                    action: function (e, dt, node, config) {
                        var url = '@Url.Action("AuditTrail", "Home")';
                        window.location.href = url;
                    }
                }
            ]
        });

        table.buttons("add", null).containers().appendTo('#customDTButton');
        table.buttons("export", null).containers().appendTo('.export-section');
        table.buttons("audit, delete", null).containers().appendTo('#action-bar');
