
@{
    ViewBag.Title = "Cap7";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .detail-frame{
        padding: 0 !important;
    }
    .custom-container{
        overflow: auto;
        min-height: calc(100vh - 75px - 25px);
    }
    /**JH230804**/
    .card_section {
        display: flex;
        flex-wrap: wrap;
    }
    .card_box {
        display: flex;
        width: calc(100%/5);
        padding: 10px;
    }
        .card_box:first-child {
            padding-left: 0;
        }
        .card_box:last-child {
            padding-right: 0;
        }
    .card_item {
        display: flex;
        width: 100%;
        padding: 10px 10px;
        border-radius: 2px;
        box-shadow: 0px 2px 4px 2px #e9ecef;
    }
    .card_item--icon {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 40%;
        min-width: 60px;
        max-width: 100px;
        min-height: 60px;
        color: grey;
    }
        .card_item--icon i {
            font-size: 40px;
        }
    .card_item--text{
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
    .card_item .fs_md {
        font-size: 21px;
    }
    .card_item .fs_lg {
        font-size: 40px;
    }

    .cd-alert {
        border: 1px solid #B1003C;
    }
        .cd-alert .cd_value {
            color: #B1003C;
            animation: textblink 2s infinite;
        }


    .board_section {
        display: flex;
        flex-wrap: wrap;
        font-size: 14px;
        padding: 20px 50px;
    }
    .board_box {
        display: flex;
        width: calc(100%/4);
        padding: 10px;
    }

    .board_item {
        display: flex;
        width: 100%;
        padding: 10px 10px;
        border-radius: 4px;
        box-shadow: 0px 2px 4px 2px #eee;
        background: #E5E9FC;
    }
        .board_item.board-stop {
            background: #C4FCBC;
        }
            .board_item.board-stop .bd_unit{
                display: none;
            }
        .board_item.board-warning {
            background: #FFC4C4;
        }

    .board_item--icon {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 40%;
        min-width: 30px;
        max-width: 40px;
        min-height: 60px;
        color: grey;
    }

        .board_item--icon i {
            font-size: 20px;
        }

    .board_item--icon-sm{
        display:none;
    }
    .board_item--icon-sm.active {
        display:block;
    }
        .board_item--icon-sm i {
            font-size: 14px;
            color: #B1003C;
        }

    .board_item--icon-lg {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 40%;
        min-width: 50px;
        max-width: 60px;
        min-height: 60px;
        color: grey;
    }

        .board_item--icon-lg i {
            font-size: 40px;
        }

    .board_item--text {
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .board_item .fs_lg {
        font-size: 11px;
    }

    .board_item .fc_red {
        color: #B1003C;
    }

    .board_line{
        width: 1px;
        height: 25px;
        background: grey;
        margin:0 5px;
    }

    .bd-alert {
        font-weight: bold;
        color: #B1003C;
    }


    .power-icon {
        color: lightgreen;
    }
        .power-icon i {
            animation: flashygreen 2s infinite;
        }
    @@keyframes flashygreen {
        0% {
            color: green;
        }

        75% {
            color: lightgreen;
        }

        100% {
            color: green;
        }
    }

    .icon-flashybolt {
        color: rgba(255, 255, 255, 0.05);
        background: grey -webkit-gradient(linear, left top, right top, from(grey), to(grey), color-stop(0.5, gold)) 0 0 no-repeat;
        background-size: 150px;
        -webkit-background-size: 150px;
        background-clip: text;
        -webkit-background-clip: text;
        animation: flashybolt 2s infinite;
    }
    @@keyframes flashybolt{
        0% {
            background-position: -150px;
        }
        75% {
            background-position: 150px;
        }
        100% {
            background-position: 150px;
        }
    }

    .bd_alert_total {
        animation: textblink 2s infinite;
        text-shadow: 0 0 2px pink;
    }
    @@keyframes textblink {
        0% {
            opacity: 0;
        }
        75% {
            opacity: 1;
        }
        100% {
            opacity: 0;
        }
    }

    .mini-bolt {
        position: relative;
        width: 45px;
        height: 40px;
    }

        .mini-bolt i {
            position: absolute;
            font-size: 15px;
            top: 22px;
            left: 27px;
            animation: boltblink 2s infinite;
        }

    @@keyframes boltblink {
        0% {
            color: #fff;
        }

        75% {
            color: #0ffff0;
        }

        100% {
            color: #fff;
        }
    }


    .shine-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background-color: #f06292;
        border: 1px solid #f06292;
        box-shadow: 0 0 5px #f06292;
    }
    .moving-dot {
        position: relative;
        width: 50px;
        height: 40px;
    }
        .moving-dot i {
            position: absolute;
            top: 16px;
            left: 0;
            animation: movingdot 2s infinite;
        }
    @@keyframes movingdot {
        0% {
            top: 16px;
            left: 0;
        }
        15% {
            top: 16px;
            left: 9px;
        }
        30% {
            top: 1px;
            left: 9px;
        }
        45% {
            top: 1px;
            left: 22px;
        }
        70% {
            top: 31px;
            left: 22px;
        }
        80% {
            top: 31px;
            left: 35px;
        }
        90% {
            top: 16px;
            left: 35px;
        }
        100% {
            top: 16px;
            left: 45px;
        }
    }

    .legend_section {
        display: flex;
        flex-wrap: wrap;
        background: #fff;
        box-shadow: 0px 2px 4px 2px #e9ecef;
        border-radius: 2px;
        font-weight: bold;
        font-size: 14px;
        padding: 0 15px;
        width: fit-content;
        margin: auto;
    }
    .lg_item {
        display: flex;
        align-items: center;
        padding: 5px;
    }
    .lg_label {
    }
    .lg_sbox {
        width: 17px;
        height: 17px;
        background: #ccc;
    }
    .lg_item.lg-normal .lg_sbox {
        background: #E5E9FC;
    }
    .lg_item.lg-stop .lg_sbox {
        background: #C4FCBC;
    }
    .lg_item.lg-warning .lg_sbox {
        background: #FFC4C4;
    }


    @@media (max-width: 1000px) {
        .legend_section{
            font-size: 10px;
        }
        .card_box {
            padding: 10px !important;
            width: calc(100%/3);
        }
        .board_box {
            width: calc(100%/2);
        }
    }
    @@media (max-width: 750px) {
        .card_box {
            width: 100%;
        }
        .board_box {
            width: 100%;
        }
    }
</style>



