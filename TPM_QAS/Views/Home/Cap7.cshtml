@section scripts {
    <script>
        $(document).ready(function (e) {
            var existingDiv = $('.detail-frame');
            existingDiv.removeClass('ps-md-2 mx-2').addClass('px-0');
            resizeContainer();
            $(window).on('resize', resizeContainer);
        });

        function resizeContainer() {
            var windowHeight = $(window).height();
            var headerHeight = $('header.sticky-top').outerHeight();
            var footerHeight = $('.tr-footer').outerHeight();
            var newHeight = windowHeight - (headerHeight + footerHeight);
            $('#container').css('height', newHeight + 'px');
        }

        $(document).ready(function (e) {
            $('#ddlUnitProcess').change(function (e) {
                if ($(this).val() == "FBD-5") {
                    window.location.href = '@Url.Action("FBD5", "Home")';
                }
            });
        });

        
        function updateCount(targetDiv, targetValue, decimalPlaces) {
            var currentValue = parseFloat(targetDiv.text());
            var interval;
            // Calculate the step based on the difference between current and target values
            var difference = targetValue - currentValue;
            var step = difference !== 0 ? Math.sign(difference) * Math.abs(difference) / 10 : 0;

            if (step === 0) {
                clearInterval(interval);
                targetDiv.text(targetValue.toFixed(decimalPlaces));
                return;
            }

            // Update the value incrementally
            interval = setInterval(function () {
                currentValue += step;
                if (difference !== 0 && ((step > 0 && currentValue >= targetValue) || (step < 0 && currentValue <= targetValue))) {
                    clearInterval(interval);
                    currentValue = targetValue;
                }
                // Round the current value to the specified decimal places
                var roundedValue = decimalPlaces > 0 ? currentValue.toFixed(decimalPlaces) : Math.round(currentValue);
                targetDiv.text(roundedValue);
                //console.log('Looping...');
            }, 100);
        }

        function addLeadingZero(number) {
            if (number < 10) {
                return '0' + number;
            } else {
                return number.toString();
            }
        }

        // Example usage
        //updateCount($('.board_item[data-process="devolatilizer"] [data-item="power"] .bd_value'), 200.123, 1);
        //updateCount($('.board_item[data-process="devolatilizer"] [data-item="voltage"] .bd_value'), 900, 0);
        //updateCount($('.board_item[data-process="compounder"] [data-item="power"] .bd_value'), 300.456, 2);
        //updateCount($('.board_item[data-process="compounder"] [data-item="voltage"] .bd_value'), 800, 0);

    </script>
}

