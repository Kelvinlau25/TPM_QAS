@section scripts{

    <script>
    var idh = '@Model.IDH' != 0 ? '@Model.IDH' : 0;

    $(document).ready(function () {

        checkboxChecking();
        checkbox2Checking();

        var listingURL = appBasePath + 'MM_IDS/MM_IDS_LST';

        $("#readingtypeHidden").val("AVERAGE");

        //DISABLE SAMPLING TYPE IF DRAFT
        if (idh != 0) {
            $('#mixRadio, #directRadio').prop('disabled', true);
        } else {
            $('#mixRadio, #directRadio').prop('disabled', false);
        }

        //REMOVE PROPERTIES
        $('#removeBtn').on('click', function () {
            $('#item-table tbody input[type=checkbox]:checked').each(function (idx, ele) {
                var tablerow = $('#item-count').val();
                var row = $(ele).closest('tr');
                var itemStatInput = row.find('input[id^="item_stat_"]');
                var item_stat = itemStatInput.val();

                //if (item_stat != '1') {
                //    itemStatInput.val('5');
                //    row.hide();
                //} else {
                //    row.remove();
                //}

                row.remove();
                tablerow -= 1;

                $('#item-count').val(tablerow);
            });

            checkboxChecking();
        });

        //REMOVE MACHINE ITEMS
        $('#removeBtn2').on('click', function () {
            $('#item2-table tbody input[type=checkbox]:checked').each(function (idx, ele) {
                var tablerow = $('#item2-count').val();
                var row = $(ele).closest('tr');
                var itemStatInput = row.find('input[id^="item2_stat_"]');
                var item2_stat = itemStatInput.val();

                //if (item2_stat != '1') {
                //    itemStatInput.val('5');
                //    row.hide();
                //} else {
                //    row.remove();
                //}

                row.remove();
                tablerow -= 1;

                $('#item2-count').val(tablerow);
            });

            checkbox2Checking();
        });

        //SUBMIT
        $('#btnConfirmSubmit').on('click', function () {
            $('.invalid-feedback').remove();
            $('.is-invalid').removeClass('is-invalid');

            var cont = true;
            var message = "";

            var model = {};
