    //ADD MACHINE LIST
    function addMachineList(data) {
        var cont = true;
        var message = "";

        for (var i = 0; i < data.length; i++) {

            var rowIdx = $('#item2-count').val();

            if (rowIdx != '0') {

                var tlength = $('#item2-table tbody tr').length;

                if (tlength != 0) {
                    $("#item2-table tr").each(function () {
                        var propid = data[i].MACHINE_ID;

                        var did = $(this).data('did');
                        if (did != '' && did != null && did != undefined) {
                            var item2_stat = $('#item2_stat_' + did).val();
                            var item2_machineid_mix = $('#item2_machineid_mix_' + did).val();

                            if (data[i].INSERT != 'N') {
                                if (item2_stat != '5' && item2_machineid_mix == propid) {
                                    hasDuplicate = true;
                                    data[i].INSERT = 'N';
                                } else {
                                    data[i].INSERT = 'Y';
                                }
                            }

                        }
                    });
                } else {
                    data[i].INSERT = 'Y';
                }

            } else {
                data[i].INSERT = 'Y';
            }

        }

        //if (cont && hasDuplicate) {
        //    cont = false;
        //    message = "Duplicate property type selected.";
        //}

        if (cont) {
            var rowIdx = $('#item2-count').val();

            for (var i = 0; i < data.length; i++) {

                if (data[i].INSERT == 'Y') {
                    rowIdx++;
                    $('#item2-count').val(rowIdx);

                    $("#item2-table tbody").append(`
                    <tr id="R2_${rowIdx}" data-did="${rowIdx}">
                        <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk2_${rowIdx}" onClick="handleCheckboxClick(this)"></td>
                            <td><input type="text" class="form-control" value="${data[i].MACHINE_NAME}"  id="item2_name_mix_${rowIdx}" placeholder="" disabled></td>
                            <td><input type="text" class="form-control" value="${data[i].MACHINE_FIELD}"  id="item2_path_mix_${rowIdx}" placeholder="" disabled></td>
                        <td class="d-none">
                            <input type="text" id="item2_stat_${rowIdx}" value="1">
                            <input type="text" id="item2_dbid_${rowIdx}" value="0">
                            <input type="text" id="item2_machineid_mix_${rowIdx}" value="${data[i].MACHINE_ID}">
                        </td>
                    </tr>`);

                    checkbox2Checking();
                }

            }

        } else {
            if (message != "") {
                displayToast("error", message)
            }
        }
    }

    //ADD PROPERTY LIST
    function addPropertiesList(data) {
        var cont = true;
        var message = "";

        var txtField = $("#txtField").val();

        if (txtField == null || txtField == undefined || txtField === "") {
            cont = false;
            message = "Missing Field Name value.";
        }

        if (cont) {

            for (var i = 0; i < data.length; i++) {

                var rowIdx = $('#item-count').val();

                if (rowIdx != '0') {

                    var tlength = $('#item-table tbody tr').length;

                    if (tlength != 0) {
                        $("#item-table tr").each(function () {
                            var namepath = txtField + "*" + data[i].PROPERTIES;

                            var did = $(this).data('did');
                            if (did != '' && did != null && did != undefined) {
                                var item_stat = $('#item_stat_' + did).val();
                                var item_field_direct = $('#item_field_direct_' + did).val();
                                var item_properties_direct = $('#item_properties_direct_' + did).val();
                                var fieldprop = item_field_direct + "*" + item_properties_direct;

                                if (data[i].INSERT != 'N') {
                                    if (item_stat != '5' && fieldprop == namepath) {
                                        //hasDuplicate = true;
                                        data[i].INSERT = 'N';
                                    } else {
                                        data[i].INSERT = 'Y';
                                    }
                                }

                            }
                        });
                    } else {
                        data[i].INSERT = 'Y';
                    }

                } else {
                    data[i].INSERT = 'Y';
                }

            }

            //if (cont && hasDuplicate) {
            //    cont = false;
            //    message = "Duplicate property type selected.";
            //}

            var rowCount = $('#item-table tbody tr').length;

            var datarow = data.filter(item => item.INSERT === 'Y').length;
            var totalrow = rowCount + datarow;

            if (totalrow > 10) {
                cont = false;
                message = "Total Main Property items cannot be more than 10 items";
            }

            if (cont) {
                var rowIdx = $('#item-count').val();

                for (var i = 0; i < data.length; i++) {

                    if (data[i].INSERT == 'Y') {
                        rowIdx++;
                        $('#item-count').val(rowIdx);

                        $('#item-table tbody').append(`
                        <tr id="R_${rowIdx}" data-did="${rowIdx}">
                            <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClick(this)"></td>
                            <td><input type="text" class="form-control required-field" value="${txtField}"  id="item_field_direct_${rowIdx}" placeholder="" disabled></td>
                            <td><input type="text" class="form-control required-field" id="item_properties_direct_${rowIdx}" value="${data[i].PROPERTIES}" placeholder="" disabled></td>
                            <td class="d-none">
                                <input type="text" id="item_stat_${rowIdx}" value="1">
                                <input type="text" id="item_dbid_${rowIdx}" value="0">
                            </td>
                        </tr>
                        `);

                        checkboxChecking();

                    }
                }
            } else {
                if (message != "") {
                    displayToast("error", message)
                }
            }

            

        } else {
            if (message != "") {
                displayToast("error", message)
            }
        }
    }

    //POPUP MACHINE
    function popupMachine() {

        var id = idh;

        var cont = true;
        var message = "";

        var ddlpropertymix = $("#ddlpropertymix option:selected").text();
        var ddlpropitem = $("#ddlpropitem option:selected").text();

        if (ddlpropertymix == undefined || ddlpropertymix == null || ddlpropertymix == 0 || ddlpropertymix == "" || ddlpropertymix == "Select an option..") {
            cont = false;
            message += 'Please select Main Property first. <br>';
        }

        if (ddlpropitem == undefined || ddlpropitem == null || ddlpropitem == 0 || ddlpropitem == "" || ddlpropitem == "Select an option..") {
            cont = false;
            message += 'Please select Property Item first. <br>';
        }

        if (cont) {
            var popup;
            var url = '@Url.Action("IDS_MACHINE_POPOUT", "MM_IDS")';

            url = url + '?id=' + id + '&prop=' + ddlpropertymix + '&propitem=' + ddlpropitem;

            popup = window.open(url, "Popup", "directories=no,titlebar=no,toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=no,width=800,height=800");
            popup.focus();
        } else {
            displayToast("error", message)
        }

    }

