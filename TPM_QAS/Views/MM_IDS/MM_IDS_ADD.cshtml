        function handleCompRadioChange() {

            var external = $('#compounderRadio').is(':checked');
            var tpm = $('#tpmRadio').is(':checked');
            var comp = "";

            if (external) {
                comp = "COMPOUNDER"
            } else {
                if (tpm) {
                    comp = "TPM"
                }
            } 

            if (comp === 'TPM') {
                $('.tpmprodline').show();
            } else {
                $('.tpmprodline').hide();
            }
            
            $("#compGroupHidden").val(comp);
        }

    function handleRadioChange() {

        var mix = $('#mixRadio').is(':checked');
        var direct = $('#directRadio').is(':checked');
        var sample_type = "";

        if (mix) {
            sample_type = "MIX"
        } else {
            if (direct) {
                sample_type = "DIRECT"
            }
        }

        if (sample_type === 'MIX') {
            $('.DirectInfo').hide();
            $('.MixInfo').show();
        } else {
            if (sample_type === 'DIRECT') {
                $('.MixInfo').hide();
                $('.DirectInfo').show();
            } else {
                $('.MixInfo').hide();
                $('.DirectInfo').hide();
            }
        }

        $("#samplingTypeHidden").val(sample_type);
    }

