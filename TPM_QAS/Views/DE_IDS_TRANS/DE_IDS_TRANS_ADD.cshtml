                        PRODTYPE: $("#txtProdType").val(),
                        PACKEDDATE2: $("#txtPackedDate").val(),
                        LOTNO: $("#txtLotNo").val(),
                        PACKEDDATE2: packdate,
                        prodgroup: prodgroup,
                        PRODTYPE: prodtype,
                        prodline: prodline,
                        chkType: "Uncheck",
                        MoldingList: moldingModel,
                    }
                }

                if ($('#txtfirstlot').val() == "N") {
                    var divmain = $('#firstbagmfryi');
                    divmain.empty();
                }

                var flot = $('#txtfirstlot').val()
                if ($('#txtREPACKLOT').val() == "N") {
                    $.ajax({
                        url: '@Url.Action("UpdateMandatory", "DE_IDS_TRANS")',
                        type: 'POST',
                        datatype: 'application/json',
                        contentType: 'application/json',
                        data: JSON.stringify({ model: modelv, firstlot: flot }),
                        //data: { model: modelv, firstlot: flot },
                        success: function (response) {
                            //console.log(response.MoldingList);
                            var a = response.MoldingList;

                            for (var i = 0; i < a.length; i++) {
                                var p = a[i].PropItem;
                                var mach = $("td").filter(function () {
                                    return $(this).text() == p;
                                }).closest("tr").find("td.txtMandatory");

