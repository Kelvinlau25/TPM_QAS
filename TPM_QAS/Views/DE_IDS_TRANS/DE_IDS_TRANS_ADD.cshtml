            var flot = $('#txtfirstlot').val();

            $.ajax({
                url: "../DE_IDS_TRANS/SetAfterSelProdType",
                //string prodtype, string lotno, string packeddate
                data: { prodtype: prodtype, lotno: lotno, packeddate: pack, firstlot: flot},
                dataType: "json",
                dataSrc: "",
                success: function (data) {
                    $('#txtProdType').val(data.PRODTYPE);
                    $('#txtLotNo').val(data.LOTNO);
                    $('#txtPackedDate').val(data.PACKEDDATE2);
                    $('#txtFullNG').val(data.FullNG);
                    $('#txtInspecDate').val(data.PACKEDDATE);
                    $('#txtTestedBy').val(data.TESTEDBY);
                    $('#txtUpdatedBy').val(data.UPDATEDBY);
                    $('#txtQty').val(data.QUANTITY);
                    $('#txtProdGroup').val(data.prodgroup);
                    //changeprodgroup(); //disable because partial is not for mabs only
                    $('#txtProdLine').val(data.prodline);
                    $('#txtBBS').val(data.BBS);
                    $('#txtBYI').val(data.BYI);
                    $('#txtREPACKLOT').val(data.REPACKLOT);

                    if (data.PropGradeSpecList != null) {
                        propgradespec = data.PropGradeSpecList;
                    }

                    if (data.MoldingList != null) {
                        loadDataTableMold(data.MoldingList);
                    }

                    if (data.descriptionList != null) {
                        loadDataTableApp(data.descriptionList, data.BBS, data.BYI);
                    }

                    if (data.FirstBagList != null) {
                        loadDataTableFirstBag(data.FirstBagList);
                    }

                    if (data.APP_PCL_SPEC != null) { //JH260108
                        APP_PCL_SPEC = data.APP_PCL_SPEC;
                    }

                    console.log(propgradespec);
                    console.log(data.MoldingList);
                    loadings(false);

                    sratioList = data.ratioList;
                    sdescriptionList = data.descriptionList;
                    yiformula = data.YIFORMULA;

                    $("#inlineCheckbox1").removeAttr('disabled');
                    $("#mabs").removeAttr('disabled');
                    $("#chxboxCLP").removeAttr('disabled');
                    $("#chxboxReject").removeAttr('disabled');
