        $(document).on('paste', 'input[id^="yiRead["]', function (e) {
            e.preventDefault();

            const currentInput = this;
            const currentId = currentInput.id;
            const match = currentId.match(/yiRead\[(\d+)\]/);
            if (!match) return;

            const startIndex = parseInt(match[1]);

            navigator.clipboard.readText().then((clipboardData) => {
                let lines = [];

                if (clipboardData.includes('\t')) {
                    // If tab-separated, it's horizontal copy (row)
                    lines = clipboardData.split('\t');
                } else {
                    // Otherwise treat as vertical (newline separated)
                    lines = clipboardData.split(/\r?\n/);
                }

                // Cleanup
                lines = lines.map(line => line.trim()).filter(line => line !== "");

                for (let i = 0; i < lines.length; i++) {
                    const input = document.getElementById(`yiRead[${startIndex + i}]`);
                    if (input) {
                        input.value = lines[i];
                        input.dispatchEvent(new Event("keyup"));
                    }
                }
            });
        });
