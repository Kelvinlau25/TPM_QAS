        function loadDataTableProdtype(data) {
            table = $('#tr-prodtypepopup').DataTable({
                data: data,
                pagingType: 'simple_numbers',
                columns: [
                    { data: 'PRODTYPE' },
                    { data: 'LOTNO' },
                    { data: 'QUANTITY' },
                    {
                        data: 'PACKEDDATEDATE',
                        render: function (data, type, row) {
                            if (type === 'display' || type === 'filter') {
                                const date = new Date(data);
                                return date.toLocaleDateString('en-GB'); // DD/MM/YYYY
                            }
                            return data;
                        }
                    }
                ],
                columnDefs: [
                    {
                        targets: 0,
                        render: function (data, type, row, meta) {
                            var _prodtype = row.PRODTYPE;
                            var _lotno = row.LOTNO;
                            var _packeddate = row.PACKEDDATE;
                            return `<a style="cursor:pointer; color:blue;" onclick="searchSB('${_prodtype}','${_lotno}','${_packeddate}');">${_prodtype}</a>`;
                        }
                    }
                ],
                select: {
                    style: 'multi',
