    <script>
        $('.advMultiselectpicker').multiselect({
            buttonClass: 'form-select form-control text-start',
            includeResetOption: false,
            includeResetDivider: false,
            includeSelectAllOption: false,
            onSelectAll: function () {
                // Custom code to limit the selection to the top 6 options
                var selectedOptions = $(".advMultiselectpicker").val() || [];
                if (selectedOptions.length > 6) {
                    var firstSixOptions = selectedOptions.slice(0, 6);
                    $(".advMultiselectpicker").multiselect("deselectAll", false)
                        .multiselect("select", firstSixOptions);
                }

            },
            enableCaseInsensitiveFiltering: true,
            enableFiltering: true,
            templates: {
                button: '<button type="button" class="multiselect dropdown-toggle" data-bs-toggle="dropdown"><span class="multiselect-selected-text"></span></button>',
                filter: '<div class="multiselect-filter"><div class="input-group input-group-sm p-1"><div class="input-group-prepend"></div><input class="form-control multiselect-search" type="text" /></div></div>',
            },
            onChange: function (option, checked) {
                advMultiselectpickerOnChange();
            }
        });

        function advMultiselectpickerOnChange() {
            var selectedOptions = $('.advMultiselectpicker option:selected');

            if (selectedOptions.length > 0) {
                $('.advMultiselectpicker.form-control + .btn-group .multiselect-selected-text').addClass('multiselect-selected-text-color');
            }
            else {
                $('.advMultiselectpicker.form-control + .btn-group .multiselect-selected-text').removeClass('multiselect-selected-text-color');
            }
        }

        $('.multiselect-native-select').addClass("col-sm-3");
        $('.multiselect-native-select > .btn-group').removeClass("w-100");
        $('.multiselect-native-select > .btn-group > .multiselect').removeClass("text-center");
        //$('.multiselect-native-select > .btn-group > .multiselect-container').addClass("w-300");

        $('.multiselect-native-select > .btn-group').removeClass("w-100");
    </script>

    <script>
        function tofixederror(myNumber, rnd) {
            let myStrNumber = myNumber.toString();
            // checking our number has decimals and if enough decimal points are present
            if (myStrNumber.split(".").length > 1) {
                var befdec = myStrNumber.split(".")[0];
                var aftdec = myStrNumber.split(".")[1];
                if (aftdec.length >= rnd) {
                    aftdec = aftdec + '1';
                    var newnum = befdec + '.' + aftdec;
                    return Number(newnum).toFixed(rnd);
                } else {
                    return Number(myStrNumber).toFixed(rnd);
                }
            } else {
                return Number(myStrNumber).toFixed(rnd);
            }

        }

        //JH251022 -  Result for that particular item row
        function getPCLResult(propitem) {
            var output = "";

            // Get display name (inside parentheses if any)
            var displayName = propitem;
            var bracketMatch = displayName.match(/\(([^)]+)\)/);
            if (bracketMatch) {
                displayName = bracketMatch[1].trim(); // use text inside ()
            }

            var MachineResult = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find(".txtmcahineresult").val();
            MachineResult = parseFloat((MachineResult || "").toString().replace(/,/g, ""));

            var RegressionResult = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("input#txtregressionresult").val();
            RegressionResult = parseFloat((RegressionResult || "").toString().replace(/,/g, ""));

            var Grade = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("td#txtGrade").text();

            if (!isNaN(parseFloat(RegressionResult)) && RegressionResult != 0) {
                MachineResult = RegressionResult;
            }

            var PCL_SPEC = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("td.pcl-spec").text();

            // Only proceed if PCL_SPEC has a valid range
            if (PCL_SPEC && !isNaN(MachineResult) && MachineResult !== 0) {

                // Normalize dashes
                var cleanSpec = PCL_SPEC.replace(/–/g, "-").trim();

                // Parse ALL segments safely
                var parsedSpecs = parsePCLSpec(cleanSpec);
                console.log("Parsed:", parsedSpecs);

                // Find matching grade
                var selected = parsedSpecs.find(x => x.code === Grade);

                if (selected) {
                    var min = selected.min;
                    var max = selected.max;

                    console.log("Min/Max:", min, max, "Machine:", MachineResult);

                    if (!isNaN(min) && !isNaN(max)) {
                        if (MachineResult < min) {
                            output = `${displayName} < PCL`;
                        } else if (MachineResult > max) {
                            output = `${displayName} > PCL`;
                        } else {
                            // within range → no output
                        }
                    }
                }
            }

            var PCL_RESULT = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("td.txtPCLResult");
            $(PCL_RESULT).text(output);

        }

        var APP_PCL_SPEC = [];
        var APP_PCL_REMARK = [];

        function getAppPCLResult() {
            APP_PCL_REMARK = [];
            if (APP_PCL_SPEC) {
                $.each(APP_PCL_SPEC, function (i, item) {
                    var output = "";
                    var displayName = item.PropItem;
                    var MachineResult = 0;
                    var PCL_SPEC = "";

                    var Grade = "A";

                    if (item.Properties == "YI") {
                        var colIndex = $(`.tblAppearance[data-type="${item.Properties}"] th`).filter(function () {
                            return $.trim($(this).text()) === "YI";
                        }).index();

                        MachineResult = $(`.tblAppearance[data-type="${item.Properties}"] tbody tr:last td`)
                            .eq(colIndex).find('input')
                            .val();

                        MachineResult = parseFloat((MachineResult || "").toString().replace(/,/g, ""));

                        var colIndex2 = $(`.tblAppearance[data-type="${item.Properties}"] th`).filter(function () {
                            return $.trim($(this).text()) === "REGRESSION";
                        }).index();

                        RegressionResult = $(`.tblAppearance[data-type="${item.Properties}"] tbody tr:last td`)
                            .eq(colIndex2).find('input')
                            .val();

                        RegressionResult = parseFloat((RegressionResult || "").toString().replace(/,/g, ""));

                        if (!isNaN(parseFloat(RegressionResult)) && RegressionResult != 0) {
                            MachineResult = RegressionResult;
                        }

                        PCL_SPEC = item.PCL_Spec;

                    } else {
                        var colIndex = $(`.tblAppearance[data-type="${item.Properties}"] th`).filter(function () {
                            return $.trim($(this).text()) === item.PropItem;
                        }).index();

                        MachineResult = $(`.tblAppearance[data-type="${item.Properties}"] tbody tr:last td`)
                            .eq(colIndex).find('input')
                            .val();

                        MachineResult = parseFloat(MachineResult);

                        PCL_SPEC = item.PCL_Spec;
                    }

                    // Only proceed if PCL_SPEC has a valid range
                    if (PCL_SPEC && !isNaN(MachineResult) && MachineResult !== 0) {

                        // Normalize dashes
                        var cleanSpec = PCL_SPEC.replace(/–/g, "-").trim();

                        // Parse ALL segments safely
                        var parsedSpecs = parsePCLSpec(cleanSpec);
                        console.log("Parsed:", parsedSpecs);

                        // Find matching grade
                        var selected = parsedSpecs.find(x => x.code === Grade);

                        if (selected) {
                            var min = selected.min;
                            var max = selected.max;

                            console.log("Min/Max:", min, max, "Machine:", MachineResult);

                            if (!isNaN(min) && !isNaN(max)) {
                                if (MachineResult < min) {
                                    output = `${displayName} < PCL`;
                                } else if (MachineResult > max) {
                                    output = `${displayName} > PCL`;
                                } else {
                                    // within range → no output
                                }
                            }
                        }
                    }

                    APP_PCL_REMARK.push({
                        Properties: item.Properties,
                        PropItem: item.PropItem,
                        MainReading: MachineResult,
                        PCL_Spec: PCL_SPEC,
                        PCL_Result: output
                    });

                });
            }

            console.log(APP_PCL_REMARK);
            //APP_PCL_REMARK = APP_PCL_REMARK;
        }

        function parsePCLSpec(specText) {
            if (!specText) return [];

            // Universal parser: CODE MIN - MAX
            const regex = /([A-Za-z]+)\s+([\-0-9,\.]+)\s*-\s*([\-0-9,\.]+)/g;

            let results = [];
            let match;

            while ((match = regex.exec(specText)) !== null) {
                let code = match[1].trim();
                let min = parseFloat(match[2].replace(/,/g, ""));
                let max = parseFloat(match[3].replace(/,/g, ""));

                results.push({ code, min, max });
            }

            console.log(specText, results);

            return results;
        }
    </script>

}



