@using TPM_QAS.Models
@model TPM_QAS.Models.DailyIDSTransVM
@{
    ViewBag.Title = "Daily Property Inspection Result";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>

    .tblAppearance {
        /*width: 1000px !important;*/
        margin: 20px 0 !important;
        display: block;
        overflow: auto;
    }

    .divuse {
        border: 2px solid green;
        margin-bottom: 20px;
    }

    u {
        text-decoration: underline;
        font-weight: bold;
    }

    .multiselect-native-select {
        width: 100%;
    }

    #ddlOwGrade + div .multiselect[title="NG"] .multiselect-selected-text {
        color: red;
        font-weight: bold;
    }

    #ddlOwGrade + div .multiselect-option.dropdown-item[title="NG"] .form-check-label {
        color: red;
        font-weight: bold;
    }
</style>
