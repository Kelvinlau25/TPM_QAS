                    }
                    FinalIndex.push(indexs);
                }
            }

            for (var x = 0; x < FinalIndex.length; x++) {
                g = 0;
                for (var w = 0; w < FinalIndex[x].length; w++) {                    
                    indx = FinalIndex[x][w].ind;
                    column = FinalIndex[x][w].txt;
                    rt = FinalIndex[x][w].rat;

                    var rndn = 1;
                    if (x == 1) {
                        rndn = parseFloat(getround("YI", "A"));
                    } else {
                        rndn = parseFloat(getround(column, "A"));
                    }

                    $("#tblAppearance" + x).each(function () {
                        row = $("tbody tr.approw", this).length;
                        //row = 0;
                        $('tbody tr.approw', this).each(function () {
                            var td = $.trim($('td:eq(' + indx + ') input[type="text"]', this).val());

                            if (td != "") {

                                sum = sum + parseFloat(td);
                                count++;
                                //row = row + 1;
                            }

                            if (row > 0) {
                                //average = (sum * rt) / row; //LEHA REMOVE CALCULATION BECAUSE ENTRY DIDNT TIME CALCULATION, 
                                average = sum / row;
                            } else {
                                average = tofixederror(0, rndn);
                            }
                            
                        });
                        //HANA 080723 change for decimal point 1
                        if (w !== FinalIndex[x].length && x !== FinalIndex.length - 1) {
                            if (average == '') { 
                                $("#tblAppearance" + x + " tbody tr.lastrow td.tdRow .result" + g).val(average);//.toFixed(2));
                            } else {
                                $("#tblAppearance" + x + " tbody tr.lastrow td.tdRow .result" + g).val(tofixederror(parseFloat(average), rndn));//.toFixed(2));
                            }
                        } else {
                            if (average == '') {
                                $("#tblAppearance" + x + " tbody tr.lastrow td.tdRow .result" + g).val(average);//.toFixed(2));
                            } else {
                                $("#tblAppearance" + x + " tbody tr.lastrow td.tdRow .result" + g).val(tofixederror(parseFloat(average), rndn));//.toFixed(1));
                            }
                        }

                    });
                    g++;
                    sum = 0;
                    count = 0;
                }
            }
        }
        function getAverageMold() {
            //251125 - Change hardcode decimal point
            var thname = $('#PP_FishEye .propitems').val();
            var rndn = parseFloat(getround(thname, "N"));

            var r1 = document.getElementById("Reading1").value;
            var r2 = document.getElementById("Reading2").value;
            var r3 = document.getElementById("Reading3").value;
            var r4 = document.getElementById("Reading4").value;
            var r5 = document.getElementById("Reading5").value;
            var r6 = document.getElementById("Reading6").value;
            var result = [];
            if (r1 != '') { result.push(r1) }
            if (r2 != '') { result.push(r2) }
            if (r3 != '') { result.push(r3) }
            if (r4 != '') { result.push(r4) }
            if (r5 != '') { result.push(r5) }
            if (r6 != '') { result.push(r6) }
            document.getElementById('AverageMold').value = tofixederror(calculateAverage(result), rndn);
        }

        function calculateAverage(array) {
            var total = 0;
            var count = 0;
            array.forEach(function (item, index) {
                total += parseFloat(item);
                count++;
            });
            return total / count;
        }

