                if (this.checked) {
                    $('.check input:checkbox').not(this).prop('checked', false);
                    if (name == 'FirstLotContainer') {
                        modelv = {
                            LOTNO: $("#txtLotNo").val(),
                            PACKEDDATE2: packdate,
                            prodgroup: prodgroup,
