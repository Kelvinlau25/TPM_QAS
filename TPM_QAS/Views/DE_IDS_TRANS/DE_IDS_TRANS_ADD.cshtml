                        }

                        $('#txtfirstlot').val("Y");
                    }
                    else if (name == 'PartialContainer') {
                        modelv = {
                            LOTNO: $("#txtLotNo").val(),
                            PACKEDDATE2: packdate,
                            prodgroup: prodgroup,
                            PRODTYPE: prodtype,
                            prodline: prodline,
                            chkType: "Part",
                            MoldingList: moldingModel,
                        }

                        $('#txtfirstlot').val("N");
                    }
                    else if (name == 'CrossLinePacking') {
                        modelv = {
                            LOTNO: $("#txtLotNo").val(),
                            PACKEDDATE2: packdate,
                            prodgroup: prodgroup,
                            PRODTYPE: prodtype,
                            prodline: prodline,
                            chkType: "Uncheck",
                            MoldingList: moldingModel,
                        }

                        $('#txtfirstlot').val("Y");
                    }
                    else if (name == 'Reject') {
                        modelv = {
                            LOTNO: $("#txtLotNo").val(),
                            PACKEDDATE2: packdate,
                            prodgroup: prodgroup,
                            PRODTYPE: prodtype,
                            prodline: prodline,
                            chkType: "Uncheck",
