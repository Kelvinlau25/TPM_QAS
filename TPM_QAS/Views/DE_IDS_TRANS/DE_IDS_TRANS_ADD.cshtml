                            if (response.FirstBagList != null) {
                                loadDataTableFirstBag(response.FirstBagList, $('#txtBBS').val(), $('#txtBYI').val());
                            }
                        },
                        error: function (e) {
                            console.log(e);
                        }
                    });
                }
            }
        });
