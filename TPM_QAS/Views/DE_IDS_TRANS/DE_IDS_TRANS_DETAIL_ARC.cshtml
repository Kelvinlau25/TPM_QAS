                                                                                            else if (Model.descriptionList[a].fieldnameList[b][p].fieldname.ToString().ToUpper() == "REGRESSIONFORMULA")
                                                                                            {
                                                                                                <input type="text" class="form-control yiboolean hidden" name="yiRead[]" value="@words[p]" />
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <input type="text" class="form-control yidata" onkeyup="getAverageApp1()" name="yiRead[]" value="@(words[p] == "" ? "" : Convert.ToDouble(words[p]).ToString(format))" disabled />
                                                                                            }
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            if (fbag == "Y")
                                                                                            {
                                                                                                <input type="text" class="form-control" onChange="firstbagreflect('@p')" name="yiRead[]" value="@(words[p] == "" ? "" : Convert.ToDouble(words[p]).ToString(format))" disabled />
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <input type="text" class="form-control" onkeyup="getAverageApp1()" name="yiRead[]" value="@(words[p] == "" ? "" : Convert.ToDouble(words[p]).ToString(format))" disabled />
                                                                                            }
                                                                                        }
