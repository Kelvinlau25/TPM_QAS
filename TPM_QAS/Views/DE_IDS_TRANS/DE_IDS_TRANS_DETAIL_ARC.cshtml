                var tdid = $('td:eq(0)', this); //id
                var tdgrd = $('td:eq(1)', this); //grade
                var ididssum = $.trim(tdid.html());
                var grd = $.trim(tdgrd.html());
                var tdabnorm = $('td:eq(6) input[type="text"]', this).val();
                if (grd == 'NG') {
                    idssum.push({ id_ids_sum: ididssum, grade: grd, abnormalities: tdabnorm });
                }
            });


            if (idssum.length > 0) {
                $.ajax({
                    url: '@Url.Action("IDS_SUM_ABNORM", "DE_IDS_TRANS")',
                    type: 'POST',
                    datatype: 'application/json',
                    contentType: 'application/json',
                    data: JSON.stringify({ IDSSUM: idssum}),
