        //JH251022 -  Result for that particular item row
        function getPCLResult(propitem) {
            var output = "";

            // Get display name (inside parentheses if any)
            var displayName = propitem;
            var bracketMatch = displayName.match(/\(([^)]+)\)/);
            if (bracketMatch) {
                displayName = bracketMatch[1].trim(); // use text inside ()
            }

            var MachineResult = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find(".txtmcahineresult").val();
            MachineResult = parseFloat(MachineResult);

            var RegressionResult = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("input#txtregressionresult").val();
            RegressionResult = parseFloat(RegressionResult);

            var Grade = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("td#txtGrade").text();

            if (!isNaN(parseFloat(RegressionResult)) && RegressionResult != 0) {
                MachineResult = RegressionResult;
            }

            var PCL_SPEC = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("td.pcl-spec").text();

            // Only proceed if PCL_SPEC has a valid range
            if (PCL_SPEC && MachineResult != 0) {
                // ✅ Normalize: keep one space after grade, and normalize dashes/spaces
                var cleanSpec = PCL_SPEC
                    .replace(/–/g, "-")                  // replace en dash with hyphen
                    .replace(/\s*-\s*/g, " - ")          // ensure single spaces around '-'
                    .replace(/\s*,\s*/g, ",")            // clean comma spacing
                    .replace(/\s+/g, " ")                // collapse multiple spaces
                    .trim();

                // Example: "A 21.000 - 23.000, B 20.000 - 25.000"
                // Split by comma to get individual grade sections
                var specs = cleanSpec.split(",");

                var selectedRange = null;

                specs.forEach(function (segment) {
                    // Example segment: "A 21.000 - 23.000"
                    var parts = segment.trim().split(" ");
                    var letter = parts[0]; // first token (A, B, AA, etc.)

                    if (letter === Grade) {
                        // Extract the part with numeric range
                        var match = segment.match(/(-?\d+(?:\.\d+)?)\s*-\s*(-?\d+(?:\.\d+)?)/);
                        if (match) {
                            selectedRange = {
                                min: parseFloat(match[1]),
                                max: parseFloat(match[2])
                            };
                        }
                    }
                });
                //console.log(MachineResult, specs, Grade);
                //console.log(selectedRange);
                if (selectedRange) {
                    var min = selectedRange.min;
                    var max = selectedRange.max;

                    if (!isNaN(min) && !isNaN(max)) {
                        if (MachineResult < min) {
                            output = `${displayName} < PCL`;
                        } else if (MachineResult > max) {
                            output = `${displayName} > PCL`;
                        } else {
                            // output = `${displayName} within PCL`;
                        }
                    } else {
                        // output = "Invalid PCL range";
                    }
                } else {
                    // output = `No matching PCL range for grade ${Grade}`;
                }
            } else {
                //output = "No PCL range defined";
            }

            var PCL_RESULT = $("#tr-molding td").filter(function () {
                return $(this).text() == propitem;
            }).closest("tr").find("td.txtPCLResult");
            $(PCL_RESULT).text(output);

        }

    </script>

