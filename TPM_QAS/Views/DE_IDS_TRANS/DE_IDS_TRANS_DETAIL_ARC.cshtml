        function getround(propitem, grdind) {
            var propgradespec = @Html.Raw(Json.Serialize(Model.PropGradeSpecList));
            var rnd = 0;

            for (let i = 0; i < propgradespec.length; i++) {
                if (propgradespec[i]['PROP_ITEM'] == propitem && propgradespec[i]['GRADINGIND'] == grdind) {
                    rnd = propgradespec[i]['ROUNDING'];
                }
            }
            return rnd;
        }


        function grdSearch(target, reading, grdind) {
            var propgradespec = @Html.Raw(Json.Serialize(Model.PropGradeSpecList));
            var indexes = '';
            var grade = '';
            for (let i = 0; i < propgradespec.length; i++) {
                if (propgradespec[i]['PROPERTIES'].includes(target) && propgradespec[i]['GRADINGIND'] == grdind) {
                    if (parseFloat(reading) >= parseFloat(propgradespec[i]['L_SPEC']) && parseFloat(reading) <= parseFloat(propgradespec[i]['U_SPEC'])) {
                        if (grade == '') {
                            grade = propgradespec[i]['GRADE'];
                        }
                    }
                }
            }
            if (grade == '') {
                grade = 'NG';
            }
            return grade;
        }

        function grdSearchfb(target, reading, grdind) {
            var propgradespec = @Html.Raw(Json.Serialize(Model.PropGradeSpecList));

            console.log(propgradespec);
            console.log('reading :' + reading);
            var indexes = '';
            var grade = '';
            if (reading == '') {
                var finalpriority = '';
                for (let i = 0; i < propgradespec.length; i++) {
                    if (propgradespec[i]['PROPERTIES'].includes(target) && propgradespec[i]['GRADINGIND'] == grdind) {
                        if (finalpriority == '') {
                            finalpriority = propgradespec[i]['FINAL_PRIORITY'];
                            grade = propgradespec[i]['GRADE'];
                        } else {
                            if ((parseFloat(propgradespec[i]['FINAL_PRIORITY'])) < parseFloat(finalpriority)) {
                                finalpriority = propgradespec[i]['FINAL_PRIORITY'];
                                grade = propgradespec[i]['GRADE'];
                            }
                        }
                        //grade = propgradespec[i]['GRADE'];
                        //return grade;
                        console.log(grade);
                    }
                }
            } else {
                var prevdiff = '';
                for (let i = 0; i < propgradespec.length; i++) {
                    if (propgradespec[i]['PROPERTIES'].includes(target) && propgradespec[i]['GRADINGIND'] == grdind) {
                        if (parseFloat(reading) >= parseFloat(propgradespec[i]['L_SPEC']) && parseFloat(reading) <= parseFloat(propgradespec[i]['U_SPEC'])) {

                            const lowerSpec = parseFloat(propgradespec[i]['L_SPEC']);
                            const upperSpec = parseFloat(propgradespec[i]['U_SPEC']);
                            const diff = upperSpec - lowerSpec;
                            if (prevdiff == '') {
                                prevdiff = parseFloat(diff);
                                grade = propgradespec[i]['GRADE'];
                            } else {
                                if (parseFloat(diff) < parseFloat(prevdiff)) {
                                    prevdiff = parseFloat(diff);
                                    grade = propgradespec[i]['GRADE'];
                                }
                            }
                        }
                    }
                }
            }
            if (grade == '') {
                grade = 'NG';
            }
            return grade;
        }

        function firstbagreflect(x) {
            var propgradespec = @Html.Raw(Json.Serialize(Model.PropGradeSpecList));
            var firsttag = $("#tblAppearance tbody tr:eq(3) td:eq(" + x + ") input[type='text']");
            var top = $("#tblAppearance tbody tr:eq(0) td:eq(" + x + ") input[type='text']");
            var middle = $("#tblAppearance tbody tr:eq(1) td:eq(" + x + ") input[type='text']");
            var bottom = $("#tblAppearance tbody tr:eq(2) td:eq(" + x + ") input[type='text']");

            var topval = top.val().trim();
            var middleval = middle.val().trim();
            var bottomval = bottom.val().trim();
            var totalread = 0;

            var cnt = 0
            if (topval != '' && topval != '0') {
                cnt = cnt + 1;
                totalread = totalread + parseFloat(topval);
            }

            if (middleval != '' && middleval != '0') {
                cnt = cnt + 1;
                totalread = totalread + parseFloat(middleval);
            }

            if (bottomval != '' && bottomval != '0') {
                cnt = cnt + 1;
                totalread = totalread + parseFloat(bottomval);
            }

            var avg = '';
            if (cnt != 0) {
                avg = totalread / cnt
            }

            var roundpi = 0;
            var PROPITEM = $("#tblAppearance:eq(0) thead tr th:eq(" + x + ") ").text();
            for (let i = 0; i < propgradespec.length; i++) {
                if (propgradespec[i]['PROPERTIES'] === 'BLACK SPECK' && propgradespec[i]['PROP_ITEM'] == PROPITEM && propgradespec[i]['GRADINGIND'] == "A") {
                    roundpi = propgradespec[i]['ROUNDING']
                }
            }

            firsttag.val(tofixederror(avg, roundpi));
            getAverageApp1();
        }
