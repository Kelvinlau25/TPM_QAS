                                },
                                complete: function () {
                                    $.ajax({
                                        url: '@Url.Action("DE_IDS_TRANS_DETAIL", "DE_IDS_TRANS")',
                                        type: 'POST',
                                        datatype: 'application/json',
                                        contentType: 'application/json',
                                        data: JSON.stringify({ m: model, field: html_table_data, tag: tagNo, description: arr3, rectype: rectype, saveas: sa }),
                                        success: function (response) {
                                            if (response == "Data save successfully") {
                                                alert(response);
                                                var url = '@Url.Action("DE_IDS_TRANS_LST", "DE_IDS_TRANS")';
                                                window.location.href = url;

                                            } else {
                                                alert(response);
                                            }
                                        },
                                        error: function (ex) {
