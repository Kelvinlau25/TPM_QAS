                            window.location.href = url;
                        } else {
                            alert(response);
                        }
                    },
                    error: function () {
                        displayToast("error", response.responseText)
                        loadings(false);
                    }
                });
            } else {
                alert("No record to saved.")
                loadings(false);
            }
        });
