    }

    u {
        text-decoration: underline;
        font-weight: bold;
    }

    .BBSY, .BYIY {
        display: none;
    }

    .editabnorm {
        float: right;
    }

    .multiselect-native-select {
        width: 100%;
    }

    .btn-danger {
        color: white !important;
    }

    #ddlOwGrade + div .multiselect[title="NG"] .multiselect-selected-text {
        color: red;
