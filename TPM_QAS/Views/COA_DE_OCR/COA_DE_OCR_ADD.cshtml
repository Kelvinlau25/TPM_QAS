                            } else {
                                $.each(data, function (index, datas) {
                                    var firstFiveDB = trimSymbol(datas.Text).substring(0, 5).toLowerCase();
                                    if (firstFiveAPI === firstFiveDB) {
                                        closestMatchFive = datas.Value;
                                        return false;
                                    }
                                });

                                if (closestMatchFive) {
                                    ddl_conf_mat.val(closestMatchFive);
                                } else {                            
                                    $.each(data, function (index, datas) {
                                        var firstThreeDB = trimSymbol(datas.Text).substring(0, 3).toLowerCase();
                                        if (firstThreeAPI === firstThreeDB) {
                                            closestMatchThree = datas.Value;
                                            return false;
                                        }
                                    });

                                    if (closestMatchThree) {
                                        ddl_conf_mat.val(closestMatchThree);
                                    } else {
                                        ddl_conf_mat.val("0");
                                    }
                                }
                            }
                        }
                    }
                }
            });
        }

        function handleCheckboxClickModal(checkbox) {
            checkboxCheckingModal();
        }

        function checkboxCheckingModal() {
            var rowCount = $('#firstOCRtable tbody tr').length;
            if (rowCount > 0) {
                $('#trCheckbox').show();
            } else {
                $('#trCheckbox').hide();
            }

            if (areAllCheckboxesCheckedModal()) {
                $('#trCheckbox').prop('checked', true);
            } else {
                $('#trCheckbox').prop('checked', false);
            }
        }

        function areAllCheckboxesCheckedModal() {
            var allCheckboxes = $('#firstOCRtable tbody input[type="checkbox"]');
            for (var i = 0; i < allCheckboxes.length; i++) {
                if (!allCheckboxes[i].checked) {
                    return false;
                }
            }
            return true;
        }

    </script>
}