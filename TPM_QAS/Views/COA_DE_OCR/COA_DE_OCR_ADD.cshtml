        function fillSupplier() {
            $.getJSON('@Url.Action("fillSupplier", "COA_DE_OCR")', function (data) {
                if (data != null && !jQuery.isEmptyObject(data)) {
                    $(".ddl_conf_supplier").each(function () {
                        var ddl_conf_supplier = $(this);
                        var currentSelected = ddl_conf_supplier.attr("data-selected") || "";
                        
                        var rowcount = ddl_conf_supplier.attr("data-row");

                        ddl_conf_supplier.empty();

                        var closestMatchExact = null;
                        var closestMatchTwenty = null;
                        var closestMatchTen = null;
                        var closestMatchFive = null;
                        var closestMatchThree = null;

                        var normalizedAPI = trimSymbol(currentSelected);
                        var firstTwentyAPI = currentSelected.substring(0, 20).toLowerCase();
                        var firstTenAPI = currentSelected.substring(0, 10).toLowerCase();
                        var firstFiveAPI = currentSelected.substring(0, 5).toLowerCase();
                        var firstThreeAPI = currentSelected.substring(0, 3).toLowerCase();

                        $.each(data, function (index, datas) {
                            ddl_conf_supplier.append($('<option/>', {
                                value: datas.Value,
                                text: datas.Text
                            }));

                            var normalizedDB = trimSymbol(datas.Text);
                            if (normalizedAPI === normalizedDB) {
                                closestMatchExact = datas.Value;
                            }
                        });

                        if (closestMatchExact) {
                            ddl_conf_supplier.val(closestMatchExact);
                        } else {
                            $.each(data, function (index, datas) {
                                var firstTwentyDB = datas.Text.substring(0, 20).toLowerCase();
                                if (firstTwentyAPI === firstTwentyDB) {
                                    closestMatchTwenty = datas.Value;
                                }
                            });

                            if (closestMatchTwenty) {
                                ddl_conf_supplier.val(closestMatchTwenty);
                            } else {
                                $.each(data, function (index, datas) {
                                    var firstTenDB = datas.Text.substring(0, 10).toLowerCase();
                                    if (firstTenAPI === firstTenDB) {
                                        closestMatchTen = datas.Value;
                                        return false;
                                    }
                                });

                                if (closestMatchTen) {
                                    ddl_conf_supplier.val(closestMatchTen);
                                } else {
                                    $.each(data, function (index, datas) {
                                        var firstFiveDB = datas.Text.substring(0, 5).toLowerCase();
                                        if (firstFiveAPI === firstFiveDB) {
                                            closestMatchFive = datas.Value;
                                            return false;
                                        }
                                    });

                                    if (closestMatchFive) {
                                        ddl_conf_supplier.val(closestMatchFive);
                                    } else {
                                        $.each(data, function (index, datas) {
                                            var firstThreeDB = datas.Text.substring(0, 3).toLowerCase();
                                            if (firstThreeAPI === firstThreeDB) {
                                                closestMatchThree = datas.Value;
                                                return false;
                                            }
                                        });

                                        if (closestMatchThree) {
                                            ddl_conf_supplier.val(closestMatchThree);
                                        } else {
                                            ddl_conf_supplier.val("0");
                                        }
                                    }
                                }
                            }
                        }

                        loadmat(rowcount);
                    });
                }
            });
}
