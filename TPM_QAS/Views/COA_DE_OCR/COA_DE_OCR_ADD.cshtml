
@using TPM_QAS.Models
@model COAOCRModel
@{
    ViewBag.Title = "COA OCR Data Entry - Add";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@using (Html.BeginForm("COA_DE_OCR_ADD", "COA_DE_OCR", FormMethod.Post, new { encType = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <div class="row g-0 px-3 tr-listing-header">
        <div class="col-sm-6 align-self-center">
            <p class="text-muted m-0 tr-listing-header-title">New Form - Supplier Raw Material Specifications (OCR)</p>
        </div>
    </div>

    <div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

    <input type="text" id="fileNameHidden" hidden>
    <input type="text" id="temp_supp" hidden>
    <input type="text" id="no_of_tab" hidden>

    <div class="page-container px-3 overflow-auto">
        <div class="tr-btm-btn-margin">
            <div class="card mt-3 mb-2 card-height height-override">
                <div class="card-body">
                    <div class="row align-items-baseline">
                        <div class="col"><h6 class="card-title text-muted">Supplier Raw Material Specifications (OCR)</h6></div>
                        <div class="col text-end"></div>
                    </div>
                    <hr />

                    <div class="row align-items-baseline">
                        <div class="col-sm-3">
                            <p class="text-muted">OCR Indicator (Per Page) <span class="text-danger">*</span><span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-8">
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="ocrindicator" id="indi1" value="1"      
                                 @(string.IsNullOrEmpty(Model.OCR_INDICATOR?.ToString()) || Model.OCR_INDICATOR.ToString() == "1" ? "checked" : "")>
                                <label class="form-check-label" for="indi1">Single Lot no</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="ocrindicator" id="indi2" value="2"
                                       @(Model.OCR_INDICATOR != null && Model.OCR_INDICATOR.ToString() == "2" ? "checked" : "")>
                                <label class="form-check-label" for="indi2">Multiple Lot No and Multiple Result</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="ocrindicator" id="indi3" value="3"
                                       @(Model.OCR_INDICATOR != null && Model.OCR_INDICATOR.ToString() == "3" ? "checked" : "")>
                                <label class="form-check-label" for="indi3">Multiple Lot No and Single Result</label>
                            </div>
                        </div>
                    </div>

                    <div class="row align-items-baseline">
                        <div class="col-sm-3">
                            <p class="text-muted">COA Language <span class="text-danger">*</span><span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-7">
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="coalang" id="ENGMALAYRadio" value="english"
                                       @(string.IsNullOrEmpty(Model.SUPPLIER_LANG?.ToString()) || Model.SUPPLIER_LANG.ToString() == "english" ? "checked" : "")>
                                <label class="form-check-label" for="ENGMALAYRadio">English/Malay</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="coalang" id="CHNRadio" value="chinese"
                                       @(Model.SUPPLIER_LANG != null && Model.SUPPLIER_LANG.ToString() == "chinese" ? "checked" : "")>
                                <label class="form-check-label" for="CHNRadio">Chinese</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="coalang" id="JPNRadio" value="japanese"
                                       @(Model.SUPPLIER_LANG != null && Model.SUPPLIER_LANG.ToString() == "japanese" ? "checked" : "")>
                                <label class="form-check-label" for="JPNRadio">Japanese</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="coalang" id="KORRadio" value="korean"
                                       @(Model.SUPPLIER_LANG != null && Model.SUPPLIER_LANG.ToString() == "korean" ? "checked" : "")>
                                <label class="form-check-label" for="KORRadio">Korean</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="secupl form-check-input" type="radio" name="coalang" id="THAIRadio" value="thai"
                                       @(Model.SUPPLIER_LANG != null && Model.SUPPLIER_LANG.ToString() == "thai" ? "checked" : "")>
                                <label class="form-check-label" for="THAIRadio">Thai</label>
                            </div>
                        </div>
                    </div>

                    <div class="firstupl row mt-2 align-items-baseline">
                        <div class="col-sm-3">
                            <p class="text-muted"><span>Upload PDF </span> <span class="text-danger">*</span><span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-6">
                            @Html.TextBoxFor(Model => Model.DataUploadFile, new { type = "file", @class = "form-control file-upload tt", id = "fileInput", accept = ".pdf" })
                            <small id="imageText" class="form-text text-muted">Maximum upload file size is 5MB</small>
                            <br />
                        </div>
                    </div>

                    <div class="secupl row align-items-baseline" style="display:none">
                        <div class="col-sm-3">
                            <p class="text-muted">Upload PDF <span class="text-danger">*</span><span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <div class="input-group">
                                @Html.TextBoxFor(model => model.VIEW_FILE, new { @class = "isItemDisabled form-control ", @maxlength = "100", id = "sec_ocr_fname", disabled = "disabled" })
                                <span class="input-group-text">
                                    <i class="fa fa-eye text-muted" id="viewFileIcon" onclick="ViewFile()" style="cursor: pointer;"></i>
                                </span>
                            </div>
                        </div>
                    </div>

                    @Html.TextBoxFor(Model => Model.FILE_NAME, new { @class = "hidden form-control", id = "txtfname" })

                    <div class="ocrresult" style="display:none">
                        <hr />
                        <div class="col align-self-center">
                            <h6 class="text-muted" style="float: left;font-weight:bold">OCR Results</h6>
                        </div>
                        <br />
                        <br />

                        <nav class="tr-tab">
                            <div class="nav nav-tabs" id="nav-tab" role="tablist"></div>
                        </nav>
                        <div class="tab-content p-2" id="nav-tabContent" style="border: 4px solid #EBF3FF;"></div>
                    </div>


                </div>
            </div>

            <div class="row row-cols-auto justify-content-end g-1 tr-btm-btn-area" style="padding-right: 20px">
                <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary mx-1 my-button" data-bs-toggle="modal" data-bs-target="#back-confirmation-modal">Back</button></div>
                <div class="col"><button id="btnSubmitFile" type="button" class="btn btn-sm btn-primary">Submit File</button></div>
                <div class="col ocrresult" style="display:none"><button id="btnSubmit" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal">Submit</button></div>
            </div>
        </div>
    </div>

}

<div id="overlay" style="display:none">
    <div class="d-flex flex-column align-items-center justify-content-center">
        <img src="~/Images/AILoading.gif" alt="Loading..." />
        <div class="text-center mt-2">AI is processing your request, please do not leave or close this tab!</div>
    </div>
</div>

<div class="modal fade" id="firstOCRmodal" tabindex="-1" role="dialog" data-backdrop="false">
    <div class="modal-dialog modal-xl-ocr modal-dialog-scrollable" style="max-height : 90vh" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">OCR Result - Supplier Confirmation</h6>
            </div>
            <div style="padding: 25px 0px 15px 0px">
                <a class="viewfilecss" href="#" onclick="ViewFile()" style="text-decoration: underline;">View Uploaded PDF</a>
            </div>

            <div id="mulinfodiv" style="padding-left: 25px; display:none">
                <small class="form-text text-muted" id="mulinfo"></small>
            </div>

            <div class="modal-body" style="overflow-y:auto; max-height: 60vh;flex-grow:1" id="searchSourceBody">
                <div class="container-fluid">

                    <div class="col" style="padding-bottom:5px">
                        <div class="row row-cols-auto justify-content-end g-1">
                            <div class="col">
                                <button class="btn btn-sm btn-md btn-danger" id="removeBtn" type="button">
                                    Remove
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <table id="firstOCRtable" class="table table-bordered compacted" style="width:100%;">
                        <thead>
                            <tr class="toolbar-row ocrmodalth">
                                <th style="width: 1%; text-align: center;">
                                    <input id="trCheckbox" type="checkbox" class="dt-checkboxes select-all form-check-input" style="margin-top:5.5px; display:none">
                                </th>
                                <th style="width: 1%;">Page</th>
                                <th style="width: 10%;">Detected Lot No</th>
                                <th style="width: 23%;">Confirmed Lot No</th>
                                <th style="width: 10%;">Detected Supplier</th>
                                <th style="width: 22%;">Confirmed Supplier</th>
                                <th style="width: 10%;">Detected Material</th>
                                <th style="width: 22%;">Confirmed Material</th>
                        </thead>
                        <tbody id="firstOCR-table-body"></tbody>
                    </table>
                    <input type="hidden" id="item-count" value="0" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Back</button>
                <button type="button" class="btn btn-primary" id="btnConfirmMatSup">Confirm</button>
            </div>
        </div>
    </div>
</div>



@section scripts{

    <script>
        $(document).ready(function () {
            var listingURL = '/COA_DE_OCR/COA_DE_OCR_LST';
            var idh = '@Model.DE_OCR_H_ID' != 0 ? '@Model.DE_OCR_H_ID' : 0;

            $('[data-bs-toggle="tooltip"]').tooltip();

            $('#removeBtn').on('click', function () {
                $('#firstOCRtable tbody input[type=checkbox]:checked').each(function (idx, ele) {
                    var row = $(ele).closest('tr');
                    var itemStatInput = row.find('input[id^="item_stat_"]');
                    var item_stat = itemStatInput.val();

                    itemStatInput.val('5');
                    row.hide();
                });

                checkboxCheckingModal();
            });

            //SUBMIT FILE
            $('#btnSubmitFile').on('click', function () {
                let $navTab = $("#nav-tab");
                let $tabContent = $("#nav-tabContent");

                $navTab.empty();
                $tabContent.empty();

                $('.invalid-feedback').remove();
                $('.is-invalid').removeClass('is-invalid');

                var cont = true;
                var message = "";

                var ocrindicator = $("input[name='ocrindicator']:checked").val();
                if (ocrindicator == undefined || ocrindicator == null || ocrindicator == "") {
                    cont = false;
                    message += 'Please select OCR Indicator. <br>';
                }

                var coalang = $("input[name='coalang']:checked").val();
                if (coalang == undefined || coalang == null || coalang == "") {
                    cont = false;
                    message += 'Please select COA Language. <br>';
                }

                var fileInput = $("#fileInput")[0].files[0];
                if (!fileInput) {
                    cont = false;
                    message += "Please select a file to upload. <br>";
                } else {
                    var maxSize = 5 * 1024 * 1024; // 5MB in bytes
                    if (fileInput.size > maxSize) {
                        cont = false;
                        message += "File size exceeds 5MB. Please select a smaller file.";
                    }
                }

                if (cont) {
                    var formData = new FormData();
                    formData.append("DataUploadFile", fileInput);
                    formData.append("ocrindicator", ocrindicator);
                    formData.append("coalang", coalang);

                    $.ajax({
                        url: "/COA_DE_OCR/UploadOCRFile",
                        type: "POST",
                        data: formData,
                        processData: false,
                        contentType: false,
                        beforeSend: function () {
                            $('#overlay').show();
                        },
                        success: function (response) {
                            $("#overlay").hide();
                            if (response.success) {
                                $("#fileNameHidden").val(response.filename);
                                ocrindicator = response.ocrindicator;
                                var d1 = response.firstOCRresult;

                                $("#firstOCRtable tbody").empty();
                                var rowIdx = 0;

                                //Single Lot no
                                if (ocrindicator == 1) {
                                    for (var i = 0; i < d1.length; i++) {
                                        rowIdx++;
                                        $('#item-count').val(rowIdx);
                                        $('#firstOCRtable tbody').append(`
                                           <tr id="R_${rowIdx}" data-did="${rowIdx}">
                                               <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClickModal(this)"></td>
                                               <td style="text-align:center;">${rowIdx}</td>
                                               <td style="color: ${d1[i].lot_no === 'Not captured by OCR' ? "#B1003C" : "inherit"}">${d1[i].lot_no}</td>
                                               <td><input type="text" class="form-control" id="item_conf_lotno_${rowIdx}" value="${d1[i].lot_no === 'Not captured by OCR' ? '' : d1[i].lot_no}"></td>
                                               <td style="color: ${d1[i].supplier_name === 'Not captured by OCR' ? "#B1003C" : "inherit"}">${d1[i].supplier_name}</td>
                                                <td class="text-left">
                                                   <select id="item_conf_supp_${rowIdx}" class="form-control ddl_conf_supplier" onchange="loadmat(${rowIdx})" style="min-width:160px;" data-selected="${d1[i].supplier_name}" data-row="${rowIdx}">
                                                       <option value="${d1[i].supplier_name}" selected>${d1[i].supplier_name}</option>
                                                   </select>
                                               </td>
                                               <td style="color: ${d1[i].material_name === 'Not captured by OCR' ? "#B1003C" : "inherit"}">${d1[i].material_name}</td>
                                                <td class="text-left">
                                                    <select id="item_conf_mat_${rowIdx}" class="form-control ddl_conf_mat" data-selected="${d1[i].material_name}" style="min-width:160px;">
                                                        <option value="0" selected></option>
                                                    </select>
                                                </td>
                                                <td class="d-none">
                                                    <input type="text" id="item_stat_${rowIdx}" value="1">
                                                </td>
                                           </tr>`);
                                    }
                                } else {
                                    //Multiple Lot No and Single Result
                                    if (ocrindicator == 3 || ocrindicator == 2) {
                                        for (var i = 0; i < d1.length; i++) {
                                            rowIdx++;
                                            $('#item-count').val(rowIdx);
                                            $('#firstOCRtable tbody').append(`
                                              <tr id="R_${rowIdx}" data-did="${rowIdx}">
                                                  <td class="text-center">
                                                    <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClickModal(this)">
                                                  </td>
                                                  <td style="text-align:center;">${rowIdx}</td>
                                                  <td style="color: ${d1[i].lot_no === 'Not captured by OCR' ? "#B1003C" : "inherit"}">${d1[i].lot_no}</td>
                                                   <td style="height: 100px;">
                                                      <textarea class="form-control"
                                                                id="item_conf_lotno_${rowIdx}"
                                                                style="width: 100%; height: 100% !important;">
                                                      </textarea>
                                                    </td>
                                                   <td style="color: ${d1[i].supplier_name === 'Not captured by OCR' ? "#B1003C" : "inherit"}">${d1[i].supplier_name}</td>
                                                   <td class="text-left">
                                                      <select id="item_conf_supp_${rowIdx}" class="form-control ddl_conf_supplier" onchange="loadmat(${rowIdx})" style="min-width:160px;" data-selected="${d1[i].supplier_name}" data-row="${rowIdx}">
                                                          <option value="${d1[i].supplier_name}" selected>${d1[i].supplier_name}</option>
                                                      </select>
                                                  </td>
                                                  <td style="color: ${d1[i].material_name === 'Not captured by OCR' ? "#B1003C" : "inherit"}">${d1[i].material_name}</td>
                                                   <td class="text-left">
                                                       <select id="item_conf_mat_${rowIdx}" class="form-control ddl_conf_mat" data-selected="${d1[i].material_name}" style="min-width:160px;">
                                                           <option value="0" selected></option>
                                                       </select>
                                                   </td>
                                                   <td class="d-none">
                                                       <input type="text" id="item_stat_${rowIdx}" value="1">
                                                   </td>
                                               </tr>`);

                                            if (d1[i].lot_no.trim() != "Not captured by OCR") {
                                                $("#item_conf_lotno_" + rowIdx).val(d1[i].lot_no.trim());
                                            } else {
                                                $("#item_conf_lotno_" + rowIdx).val("");
                                            }
                                            
                                        }
                                    }
                                }

                                checkboxCheckingModal();

                                fillSupplier();

                                if (ocrindicator != 1) {
                                    $('#mulinfo').html(
                                        'For entries containing <span style="color: red;">multiple lot no</span> in each page, please separate each lot number with a comma or place each on a new line. ' +
                                        'For example:<br>' +
                                        'LOT123,<br>' +
                                        'LOT456'
                                    );

                                    $('#mulinfodiv').show();
                                } else {
                                    $('#mulinfodiv').hide();
                                    $('#mulinfo').html(
                                        ''
                                    );
                                }


                                $('#firstOCRmodal').modal('show');

                            } else {
                                $("#overlay").hide();
                                displayToast("error", response.message);
                            }
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            $("#overlay").hide();

                            try {
                                var jsonError = JSON.parse(jqXHR.responseText);
                                console.log("Parsed Error:", jsonError);
                                displayToast("error", "Error uploading data");
                            } catch (e) {
                                // If response is not JSON, show raw error
                                displayToast("error", "Error uploading data");
                            }
                        }
                    });
                } else {
                    if (message !== "") {
                        displayToast("error", message);
                    }
                }
            });

            //TO CALL SECOND OCR
            $("#btnConfirmMatSup").off("click").on("click", function (e) {
                $('.invalid-feedback').remove();
                $('.is-invalid').removeClass('is-invalid');

                var cont = true;
                var message = "";

                $('.required-field').each(function (e) {
                    var input_val = $(this).val().trim();
                    if (input_val == null || input_val == undefined || input_val === "") {
                        cont = false;
                        $(this).addClass('is-invalid');
                        inputError(this);
                    }
                });

                var ocrindicator = $("input[name='ocrindicator']:checked").val();
                if (ocrindicator == undefined || ocrindicator == null || ocrindicator == "") {
                    cont = false;
                    message += 'Please select OCR Indicator. <br>';
                }

                var coalang = $("input[name='coalang']:checked").val();
                if (coalang == undefined || coalang == null || coalang == "") {
                    cont = false;
                    message += 'Please select COA Language. <br>';
                }

                var fileInput = $("#fileInput")[0].files[0];
                if (!fileInput) {
                    cont = false;
                    message += "Please select a file to upload. <br>";
                }

                var hasItem = false;
                var hasError = false;
                var list1 = [];

                var lastSuppId = null;
                var lastSuppText = null;
                var lastMatId = null;
                var lastMatText = null;

                $("#firstOCRtable tbody tr").each(function () {
                    var did = $(this).data("did");
                    if (did != '' && did != null && did != undefined) {
                        var item_stat = $('#item_stat_' + did).val();
                        var item_conf_lotno = $('#item_conf_lotno_' + did).val();
                        var item_conf_supp = $('#item_conf_supp_' + did).val();
                        var item_conf_supp_text = $("#item_conf_supp_" + did + " option:selected").text().trim();
                        var item_conf_mat = $('#item_conf_mat_' + did).val();
                        var item_conf_mat_text = $("#item_conf_mat_" + did + " option:selected").text().trim();

                        if (item_stat != '5') {
                            if (item_conf_lotno != '' && item_conf_supp != '0' && item_conf_supp !== undefined && item_conf_mat != '0' && item_conf_mat !== undefined) {

                                if (item_conf_lotno.includes(",")) {
                                    item_conf_lotno = item_conf_lotno.trim().replace(/\n/g, "");
                                    item_conf_lotno = item_conf_lotno.trim().replace(/,/g, "*");
                                } else {
                                    item_conf_lotno = item_conf_lotno.trim().replace(/\n/g, "*");
                                }

                                hasItem = true;
                            } else {
                                hasError = true;
                            }
                        }

                        list1.push({
                            'record_typ': item_stat,
                            'lot_no': item_conf_lotno,
                            'supplier_id': item_conf_supp,
                            'supplier_name': item_conf_supp_text,
                            'material_id': item_conf_mat,
                            'material_name': item_conf_mat_text
                        });
                        
                    }
                });

                if (cont && hasError) {
                    cont = false;
                    message = "Please make sure all lot no, confirmed supplier and material is not empty.";
                }

                if (cont && !hasItem) {
                    cont = false;
                    message = "Must have atleast one supplier and one material";
                }
                

                if (cont) {

                    var model = {
                        FirstOCRLstModel: list1
                    };


                    //console.log(model);
                    var formData = new FormData();
                    formData.append("DataUploadFile", fileInput);
                    formData.append("ocrindicator", ocrindicator);
                    formData.append("coalang", coalang);
                    formData.append("modelObj", JSON.stringify(model));

                    console.log("model", fileInput)
                    console.log("model", model)

                    $('#firstOCRmodal').modal('hide');

                    $.ajax({
                        url: "/COA_DE_OCR/getOCRFileData",
                        type: "POST",
                        data: formData,
                        processData: false,
                        contentType: false,
                        beforeSend: function () {
                            $('#overlay').show();
                        },
                        success: function (response) {
                            $('#overlay').hide();
                            if (response.success) {
                                var d1 = response.d1;
                                //console.log(d1);
                                $("#sec_ocr_fname").val(response.filename);
                                generateTabs(d1);

                            } else {
                                alert("Error : " + response.message);
                            }
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            $("#overlay").hide();

                            try {
                                var jsonError = JSON.parse(jqXHR.responseText);
                                console.log("Parsed Error:", jsonError);
                                displayToast("error", "Error uploading data");
                            } catch (e) {
                                // If response is not JSON, show raw error
                                displayToast("error", "Error uploading data");
                            }
                        }

                    });
                } else {
                    if (message !== "") {
                        alert(message);
                    }
                }
            });

            //FINAL SUBMIT
            $('#btnConfirmSubmit').on('click', function () {
                var cont = true;
                var message = "";
                var list1 = [];

                var hasItem = false;
                var hasError = false;
                var hasReject = false;
                var hasInvResult = false;

                var ocrindicator = $("input[name='ocrindicator']:checked").val();
                if (ocrindicator == undefined || ocrindicator == null || ocrindicator == "") {
                    cont = false;
                    message += 'Please select OCR Indicator. <br>';
                }

                fileNameHidden = $("#fileNameHidden").val();

                if (fileNameHidden == undefined || fileNameHidden == null || fileNameHidden == "") {
                    cont = false;
                    message += 'Error in getting file name. <br>';
                }

                var existedlot = [];

                $(".detailTable").each(function () {
                    var tableId = $(this).attr("id"); //itemtable5
                    var newtableid = tableId.replace("itemtable", "");  //5

                    if ($("#itemcount" + newtableid).val() != "0") {
                        $(this).find("tbody tr").each(function () {
                            var did = $(this).data("did");

                            if (did != '' && did != null && did != undefined) {

                                var txtsuppid = $("#txtsuppid_" + newtableid).val();
