<script>
    function isValueAInsideValueB(valueA, valueB) {
        console.log('here isValueAInsideValueB');
            try {
                const parsedA = parseAndEvaluate(valueA);
                const parsedB = parseAndEvaluate(valueB);

                if (typeof parsedA === 'number' && typeof parsedB === 'object') {
                    if (parsedB.operator === '>') {
                        return parsedA > parsedB.value;
                    } else if (parsedB.operator === '<') {
                        return parsedA < parsedB.value;
                    } else if (parsedB.operator === '>=') {
                        return parsedA >= parsedB.value;
                    } else if (parsedB.operator === '<=') {
                        return parsedA <= parsedB.value;
                    } else if (parsedB.operator === '==') {
                        return parsedA === parsedB.value;
                    } else if (parsedB.operator === '!=') {
                        return parsedA !== parsedB.value;
                    }
                } else if (typeof parsedB === 'number' && typeof parsedA === 'object') {
                    if (parsedA.operator === '>') {
                        return parsedB > parsedA.value;
                    } else if (parsedA.operator === '<') {
                        return parsedB < parsedA.value;
                    } else if (parsedA.operator === '>=') {
                        return parsedB >= parsedA.value;
                    } else if (parsedA.operator === '<=') {
                        return parsedB <= parsedA.value;
                    } else if (parsedA.operator === '==') {
                        return parsedB === parsedA.value;
                    } else if (parsedA.operator === '!=') {
                        return parsedB !== parsedA.value;
                    }
                } else if (typeof parsedA === 'object' && typeof parsedB === 'object') {
                    if (parsedA.operator === parsedB.operator) {
                        if (parsedA.operator === '>' || parsedA.operator === '>=') return parsedA.value >= parsedB.value;
                        if (parsedA.operator === '<' || parsedA.operator === '<=') return parsedA.value <= parsedB.value;
                        if (parsedA.operator === '==' || parsedA.operator === '!=') return parsedA.value === parsedB.value;
                    } else if ((parsedA.operator === '<' && parsedB.operator === '<=') || (parsedA.operator === '>' && parsedB.operator === '>=')) {
                        return parsedA.value === parsedB.value;
                    } else if ((parsedA.operator === '<=' && parsedB.operator === '<') || (parsedA.operator === '>=' && parsedB.operator === '>')) {
                        return false;
                    }
                    else return false;
                }
                else if (typeof parsedA === 'number' && typeof parsedB === 'number') {
                    return parsedA === parsedB;
                }

                return false; // Default case
            } catch (error) {
                console.error("Error comparing values:", error);
                return false;
            }
        }

        function parseAndEvaluate(value) {
            value = value.trim();
            const operators = ['>=', '<=', '>', '<', '==', '!='];
            let operator = null;

            for (const op of operators) {
                if (value.startsWith(op)) {
                    operator = op;
                    value = value.substring(op.length).trim();
                    break;
                } else if (value.endsWith(op)) {
                    operator = op;
                    value = value.substring(0, value.length - op.length).trim();
                    break;
                }
            }

            if (operator) {
                const num = eval(value); // Evaluate arithmetic expressions
                if (!isNaN(num)) {
                    return { operator, value: num };
                } else {
                    return NaN;
                }
            } else {
                const num = eval(value);
                if (!isNaN(num)) {
                    return num;
                } else {
                    return NaN;
                }
            }
        }
</script>
<script>
    function compareSpecifications(mainSpec, supplierSpec) {
        console.log("Main: " + mainSpec);
        console.log("Supplier: " + supplierSpec);

        const operators = {
            '>': (a, b) => a > b,
            '<': (a, b) => a < b,
            '>=': (a, b) => a >= b,
            '<=': (a, b) => a <= b,
            '+-': (a, b, tolerance) => Math.abs(a - b) <= tolerance,
            '-': (a, b) => a === b,
            '/': (a, b) => a === b,
        };

        function parseSpec(spec) {
            const regex = /^(>=|<=|>|<|\+-|\/|-)?\s*(\d+(\.\d+)?)\s*(?:([+-])\s*(\d+(\.\d+)?))?$/;
            const match = spec.match(regex);

            console.log('Match:', match);

            if (!match) return null;

            const operator = match[1] || '-';
            const value = parseFloat(match[2]);
            const tolerance = match[5] ? parseFloat(match[5]) : null;

            if (operator === '+-' && tolerance !== null) {
                return { operator, value, tolerance };
            }

            return { operator, value };
        }

        const main = parseSpec(mainSpec);
        const supplier = parseSpec(supplierSpec);

        if (!main || !supplier) return null;

        const mainOperator = main.operator;
        const mainValue = main.value;
        const supplierOperator = supplier.operator;
        const supplierValue = supplier.value;

        console.log(`Parsed Main: ${mainOperator} ${mainValue}`);
        console.log(`Parsed Supplier: ${supplierOperator} ${supplierValue}`);

        if (mainOperator === '<=' && supplierOperator === '<=') {
            return mainValue >= supplierValue;
        } else if (mainOperator === '<=' && supplierOperator === '<') {
            return mainValue > supplierValue;
        } else if (mainOperator === '<' && supplierOperator === '<=') {
            return mainValue > supplierValue;
        } else if (mainOperator === '<' && supplierOperator === '<') {
            return mainValue > supplierValue;
        } else if (mainOperator === '>=' && supplierOperator === '>=') {
            return mainValue <= supplierValue;
        } else if (mainOperator === '>=' && supplierOperator === '>') {
            return mainValue <= supplierValue;
        } else if (mainOperator === '>' && supplierOperator === '>=') {
            return mainValue < supplierValue;
        } else if (mainOperator === '>' && supplierOperator === '>') {
            return mainValue < supplierValue;
        } else if (mainOperator === '+-' && supplierOperator === '+-') {
            return operators['+-'](mainValue, supplierValue, main.tolerance);
        } else if (mainOperator === '-' && supplierOperator === '-') {
            return mainValue === supplierValue;
        } else if (mainOperator === '/' && supplierOperator === '/') {
            return mainValue === supplierValue;
        }

        return false;
    }
</script>

