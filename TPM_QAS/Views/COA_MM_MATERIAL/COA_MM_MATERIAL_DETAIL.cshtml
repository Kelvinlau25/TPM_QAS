                    isNumOnly = "Y";
                }

                if (typevalue == 'Numeric' && isNumOnly == 'Y') {
                    console.log('numeric');
                //if (typevalue == 'Text' || (typevalue == 'Numeric' && isNumOnly == 'Y')) {
                    if (tpmvalue == suppvalue) {
                        return "Y";
                    } else {
                        return "Value does not match with TPM value";

                    }
                } else {
                    if (typevalue == 'Range') {
                        const tpmvalarr = tpmvalue.split("~");
                        const suppvalarr = suppvalue.split("~");
                        if (tpmvalarr.length <= 1 || suppvalarr.length <= 1) {
                            return "For Range type set value, both Supplier and TPM need to use same Range Type set value."
                        } else {
                            var tpmmin = tpmvalarr[0];
                            var tpmmax = tpmvalarr[1];

                            var suppmin = suppvalarr[0];
                            var suppmax = suppvalarr[1];

                            if (!isNaN(parseFloat(tpmmin)) && !isNaN(parseFloat(tpmmax)) && !isNaN(parseFloat(suppmin)) && !isNaN(parseFloat(suppmax))) {
                                tpmmin = parseFloat(tpmmin);
                                tpmmax = parseFloat(tpmmax);
                                suppmin = parseFloat(suppmin);
                                suppmax = parseFloat(suppmax);

                                if (suppmin < tpmmin || suppmax > tpmmax) {

                                    return "Supplier Range must be within TPM Range";
                                } else {
                                    return "Y";
                                }
                            } else {
                                return "Range can only be between number and number";
                            }
                        }
                    } else {
                        if (typevalue == 'Numeric') {
                            if (!(tpmvalue.trim() == suppvalue.trim())) {
                                var isit = compareSpecifications(tpmvalue, suppvalue);
                                if (isit) {
                                    return "Y";
                                } else {
                                    return "Supplier value does not go within TPM value";
                                }
                            } else {
                                return "Y";
                            }
                        } else {
                            if (typevalue == 'Text') {
                                //if (tpmvalue === suppvalue) {
                                    return "Y";
                                //} else {
                                //    return "Supplier value is not the same as TPM value";
                                //}
                            }
                        }
                    }
                }

            }
        }
        catch (error) {
            console.error("Error evaluating formulas:", error);
            return null; // Indicate an error
        }
    }
