                </div>
            </div>
            <div class="modal-footer">
                <button type="reset" id="btnResetModal" class="btn btn-sm btn-secondary" style="margin-right: auto;">Reset</button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Back</button>
                <button type="button" id="btnsubmitcal" class="btn btn-sm btn-primary">OK</button>
            </div>
        </div>
    </div>
</div>



@section scripts {

<script>
        var idh = '@Model.MM_MATERIAL_H_ID';

        var ListSupplier = @Html.Raw(ViewBag.SerializedSupplierName);
        var ListUom = @Html.Raw(ViewBag.SerializedUOM);

        var opt = '<option value= "" selected>Not Applicable</option>';
        if (ListUom.length > 0) {
            ListUom.forEach(row => {
                opt = '<option value="' + row.Value + '">' + row.Text + '</option>' + opt;
            });
        }

    $(document).ready(function () {
        var listingURL = '/COA_MM_MATERIAL/COA_MM_MATERIAL_LST';


        checkboxChecking();
        if ('@Model.SUPPMatSpecList.Count' == '0') {
            populatesupplier(1);
            $("#suppliercount").val("1");
        }

        populateUOM();
        //SUBMIT FOR MODAL FORMULA

        $("#btnsubmitcal").click(function () {
            const inputElement = document.getElementById('txtSetValuePreview');

            if (!(inputElement.classList.contains('is-invalid'))) {
                var count = $("#current_count").val();
                var by = $("#current_open_by").val();
                var tr = $('#item-table tbody').find('tr').eq(count);
                var trtpm = $('#item-table tbody').find('tr').eq(count);
                var supplier = false;
                var pass = "Y";

                if (by.includes("btnSuppSetVal")) {
                    var suppcnt = by.replace(" ", "").split("_")[1];
                    tr = $('#tblitemsupp_' + suppcnt + ' tbody').find('tr').eq(count);
                    supplier = true;
                }

                var td = $(tr).find('td').eq(3);
                var inp = $(td).find('input[type="text"]')
                var valtype = $(tr).find('td:eq(5) input[type="text"]');
                var formula = $("#txtSetValuePreview").val().trim();
                var tpmformula = $(trtpm).find("td:eq(3) input[type='text']").val().trim();

                const valueTypes = document.querySelectorAll('input[name="valueType"]');
                let selectedValue = null;

                valueTypes.forEach(radioButton => {
                    if (radioButton.checked) {
                        selectedValue = radioButton.value;
                    }
                });

                if (supplier) {
                    pass = compareFormulas(tpmformula, formula, selectedValue);
                }
                if (pass == "Y") {
                    if ($('.required-field-modal').hasClass('is-invalid')) {
                        pass = $('.invalid-feedback').text().trim();
                        alert(pass);
                    } else {
                        $(inp).val(formula);
                        $(valtype).val(selectedValue);
                        $("#txtsetvalmin").val('');
                        $("#txtsetvalmax").val('');
                        $("#txtsetvaltypetext").val('');
                        $("#txtSetValuePreview").val('');
                        $("#SetValueModal").modal("hide");
                    }
                } else {
                    alert(pass);
                }
            }

        });

        //button + supplier
        $("#btnsupplierplus").click(function () {
            var orisuppcnt = $("#suppliercount").val();
            var suppcnt = $("#suppliercount").val();
            if (!isNaN(parseInt(suppcnt))) {
                suppcnt = parseInt(suppcnt) + 1
            } else {
                suppcnt = 1;
            }

            var $navbartoinsert = $("#nav-tab_supplier_" + orisuppcnt);
            var currbtntoclick = "nav-tab_supplier_" + suppcnt;
            var newnav = '<button class="nav-link" id="nav-tab_supplier_' + suppcnt + '" data-bs-toggle="tab" data-bs-target="#nav-supplier_' + suppcnt + '" type="button" role="tab" aria-controls="nav-supplier_' + suppcnt + '" aria-selected="true">Supplier ' + suppcnt
                + '&nbsp;<i class="fas fa-close dark-grey" id="close_' + suppcnt + '" onclick="DeleteSupplierTab(this);"></i>'
                + '</button>';
            var $divsupplier = $("#nav-supplier_" + orisuppcnt);

            var currdivtopopulate = "nav-supplier_" + suppcnt;
            var newdivsupplier = '<div class="tab-pane fade" id="nav-supplier_' + suppcnt + '" role="tabpanel" aria-labelledby="nav-tab_supplier_' + suppcnt + '" tabindex="0">' +
                '<div class="row align-items-baseline">' +
                '<div class="col-sm-2">' +
                '<p class="text-muted">' +
                '<span>Supplier Name </span>' +
                '<span class="text-danger">*</span>' +
                '<span style="float:right">:</span>' +
                '</p>' +
                '</div>' +
                '<div class="col-sm-4">' +
                '<select class="ddlSupplier ddloption form-control form-select" id="ddlSupplier' + suppcnt + '" onChange="ChangeSupplier(this);">' +
                '<option value=" ">Select Supplier</option>' +
                '</select>' +
                '</div>' +
                '<div class="col-sm-2">' +
                '<p class="text-muted">' +
                '<span>Supplier Material Name</span>' +
                '<span class="text-danger">*</span>' +
                '<span style="float:right">:</span>' +
                '</p>' +
                '</div>' +
                '<div class="col-sm-4">' +
                '<input type="text" class="form-control txtSuppMatName" id="txtSuppMatName_' + suppcnt + '" />' +
                '</div>' +
                '</div> <br>' +
                '<div id="divitemtblsupp_' + suppcnt + '"></div><br>' +
                '</div>';

            if (suppcnt == '1') {
                $(newnav).insertBefore($('#btnsupplierplus'));
                $(newdivsupplier).insertAfter($('#dumdum'));
            } else {
                $(newnav).insertAfter($navbartoinsert);
                $(newdivsupplier).insertAfter($divsupplier);
            }

            $("#suppliercount").val(suppcnt);

            if (suppcnt >= 10) {
                $("#btnsupplierplus").hide();
            } else {
                $("#btnsupplierplus").show();
            }

            populatesupplier(suppcnt);
            $('#' + currbtntoclick).click();
            console.log($('#' + currbtntoclick))

        })

        //SUBMIT
        $('#btnConfirmSubmit').on('click', function () {
            $('.invalid-feedback').remove();
            $('.is-invalid').removeClass('is-invalid');

            var cont = true;
            var message = "";

            if (cont) {

                var TPMModel = new Array();
                var SUPPModel = new Array();

                var model = {
                    MM_MATERIAL_H_ID: idh,
                    MATERIAL_NAME: '@Model.MATERIAL_NAME',
                    MATERIAL_ABBR: '@Model.MATERIAL_ABBR',
                    MATERIAL_CODE: '@Model.MATERIAL_CODE',
                    TPM_CODE: '@Model.TPM_CODE',
                    RECORD_TYP: '3',
                };

                $("#item-table tbody tr").each(function (row, tr) {
                    //-------------- 0 ID, 1 CHECKBOX, 2 TPMSPECNAME , 3 TPM SEPC VAL, 4 TPM SPEC UOM

                    var fTPMSPECNAME = $(tr).find("td:eq(2) input[type='text']").val().trim();
                    var fTPMSPECVAL = $(tr).find("td:eq(3) input[type='text']").val().trim();
                    var fTPMSPECTYPE = $(tr).find("td:eq(5) input[type='text']").val().trim();
                    var fTPMSPECUOM = $(tr).find("td:eq(4) select").val().trim();

                    if (fTPMSPECNAME == "") {
                        cont = false;
                        message = "Items cannot be empty.";
                    }

                    TPMModel.push({
                        TPM_SPEC_NAME: fTPMSPECNAME,
                        TPM_SPEC_VALUE: fTPMSPECVAL,
                        TPM_SPEC_TYPE: fTPMSPECTYPE,
                        TPM_SPEC_UOM: fTPMSPECUOM
                    });
                });

                if (cont) {
                    var cntsupp = 0;
                    $(".tblitemsupp").each(function (value, tbl) {
                        cntsupp = cntsupp + 1;
                        var tblid = $(tbl).attr("id");
                        var allitem = "";
                        $("#" + tblid + " tbody tr").each(function (valuetr, tr) {
                            //---------0 ROWID, 1 TPMNAME TEXT, 2 SUPP NAME INPUT, 3, 4
                            var currsuppcnt = tblid.replace("tblitemsupp_", "");
                            var ddlorNot = $("#ddlSupplier" + currsuppcnt).length > 0 ? true : false;
                            var fSUPPNAMEID = "";
                            if (ddlorNot) {
                                fSUPPNAMEID = $("#ddlSupplier" + currsuppcnt).val().trim();
                            } else {
                                fSUPPNAMEID = $("#txtSuppID_" + currsuppcnt).val().trim();
                            }
                            var fSUPPMATNAME = $("#txtSuppMatName_" + currsuppcnt).val().trim();
                            if (fSUPPMATNAME == "") {
                                cont = false;
                                message = "Please insert Supplier Material Name";
                            }

                            if (fSUPPNAMEID != "") {
                                var fTPMSPECNAME = $(tr).find('td').eq(1).text().trim();
                                var fSUPPSPECNAME = $(tr).find("td:eq(2) input[type='text']").val().trim();
                                var fSUPPSPECVAL = $(tr).find("td:eq(3) input[type='text']").val().trim();
                                var fSUPPSPECTYPE = $(tr).find("td:eq(5) input[type='text']").val().trim();
                                var fSUPPSPECUOM = $(tr).find("td:eq(4) select").val().trim();
                                allitem = allitem + fSUPPSPECNAME;
                                SUPPModel.push({
                                    COUNT_SUPPLIER: cntsupp,
                                    MM_SUPPLIER_H_ID: fSUPPNAMEID,
                                    SUPP_MATERIAL_NAME: fSUPPMATNAME,
                                    TPM_SPEC_NAME: fTPMSPECNAME,
                                    SUPP_SPEC_NAME: fSUPPSPECNAME,
                                    SUPP_SPEC_VALUE: fSUPPSPECVAL,
                                    SUPP_SPEC_TYPE: fSUPPSPECTYPE,
                                    SUPP_SPEC_UOM: fSUPPSPECUOM
                                });
                            } else {
                                cont = false;
                                message = "Please select Supplier";
                            }
                        });

                        if (allitem.trim() == "") {
                            cont = false;
                            message = "Please insert atleast 1 Supplier Inspection item for each supplier.";
                        }
                    });
                }

                console.log(model)
                console.log(TPMModel)
                console.log(SUPPModel)
                if (cont) {
                    $.ajax({
                        url: '@Url.Action("InsertUpdateCOAMaterial", "COA_MM_MATERIAL")',
                        type: 'POST',
                        datatype: 'application/json',
                        contentType: 'application/json',
                        //data: JSON.stringify({ m: model, allbagandprop: allbagandprop, bagnoappcolmodel: bagnoappcolmodel, bagnoapprowmodel: bagnoapprowmodel, action: action }),
                        data: JSON.stringify({ m: model, TPMModel: TPMModel, SUPPModel: SUPPModel, action: "Save" }),
                        success: function (response) {
                            loadings(false);
                            if (response.success) {
                                displayToast("s", "Data save successfully");

                                setTimeout(function () {
                                    window.location.href = listingURL;
                                }, 2000);

                            } else {
                                displayToast("error", response.message)
                            }
                        },
                        error: function () {
                            displayToast("error", response.responseText)
                        },
                        complete: function () {
                            $("#loading").fadeOut();
                        }
                    });
                }

            }
            if (!(cont)) {
                if (message != "") {
                    displayToast("error", message)
                }
            }

        });

        // BUTTON DELETE
        $('#btnConfirmDel').on('click', function () {

            var lstid = [];
            lstid.push(idh)

            $.ajax({
                url: "/COA_MM_MATERIAL/deleteCOAMaterial",
                type: 'POST',
                data: {
                    lstid: lstid
                },
                beforeSend: function () {
                    loadings();
                },
                success: function (response) {
                    loadings(false);
                    if (response.success) {
                        displayToast("s", "Data successfully deleted");

                        setTimeout(function () {
                            window.location.href = listingURL;
                        }, 2000);

                    } else {
                        displayToast("error", response.message)
                    }
                },
                error: function () {
                    displayToast("error", response.responseText)
                }
            });

        });

        //BUTTON CANCEL/BACK
        $('#btnCancelView').on('click', function () {
            var del = '0';
            if (@Model.RECORD_TYP != null && @Model.RECORD_TYP  == '5') {
                del = '1';
            }
            window.location.href = listingURL + '?Deleted=' + del;
        });

        $('#btnBackEdit').on('click', function () {
            window.location.href = listingURL;
        });

        $("#btnResetModal").on('click', function () {
            $("#txtsetvalmin").val('');
            $("#txtsetvalmax").val('');
            $("#txtsetvaltypetext").val('');
            $("#txtSetValuePreview").val('');
        });

    });

</script>

    @*TPM Tab*@
<script>
        function addrow() {

            var trcount = $("#item-table tbody tr").length;
            var tbody = $("#item-table tbody");
            var td = $("<td>");
            var row = $("<tr>");

            td = $("<td class='hidden'>").html(trcount);
            row.append(td);
            td = $("<td class='text-center'>").html('<input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk" onClick="handleCheckboxClick(this)">');
            row.append(td);
            td = $("<td>").html('<input type="text" class="form-control" id="items" onChange="tpmTableChange(\'EDITNAME\');"/>');
            row.append(td);
            td = $("<td>").html('<div class="input-group">' +
                '<input type="text" class="form-control" id="itemsval" disabled/>' +
                '<button type="button" id="btnTPMSetVal" class="btn-info input-group-text tr-input-group fa-solid fa-ellipsis" data-bs-target="#SetValue" title="Set Value" style="margin: 0;" onclick="openSetValue(this);"></button>' +
                '</div>');
            row.append(td);
            //td = $("<td>").html('<input type="text" class="form-control" id="itemsuom" />');
            td = $("<td>").html('<select class="ddloption form-select form-control ddlTPMUOM" id="ddlTPMUOM_' + trcount + '">' +
                opt +
                '</select > ');

            row.append(td);
            td = $("<td class='hidden'>").html('<input type="text" class="form-control" id="itemstype" disabled/>');
            row.append(td);
            td = $("<td>").html('<button type="button" class="btn-info input-group-text tr-input-group fa-solid fa-plus" style="margin: 0;" onclick="addsamerow(this);"></button>');
            row.append(td);

            tbody.append(row);

            tpmTableChange("ADDROW");
        }

        function addsamerow(thisbutton) {

            var $this = $(thisbutton);
            var $parentTR = $this.closest('tr');

            $parentTR.clone().insertAfter($parentTR);

            //-------for supptable
            var rowid = $parentTR.find('td').eq(0).text();
            $(".tblitemsupp").each(function (value, tbl) {
                var tblid = $(tbl).attr("id");
                var $trtoclone = $("#" + tblid + " tbody tr:eq(" + rowid + ")");
                $trtoclone.clone().insertAfter($trtoclone);
            });
            //-----------
            populateitemid();
        }

        $('#btnRemove').on('click', function () {
            $('#item-table tbody input[type=checkbox]:checked').each(function (idx, ele) {
                var tablerow = $('#item-count').val();
                var row = $(ele).closest('tr');
                //var itemStatInput = row.find('input[id^="item_stat_"]');

                var rowid = $(row).find('td').eq(0).text();
                $(".tblitemsupp").each(function (value, tbl) {
                    var tblid = $(tbl).attr("id");
                    $("#" + tblid + " tbody tr").each(function (valuetr, tr) {
                        //check if td text = rowid if yes only delete
                        var crid = $(tr).find("td:eq(0)").text();
                        if (crid == rowid) {
                            tr.remove();
                        }
                    });
                });

                row.remove();
            });
            populateitemid();

            checkboxChecking();
        });

        function populateitemid() {
            var cnt = 0;
            $('#item-table tbody tr').each(function (x, tr) {
                $(tr).find('td').eq(0).text(cnt);
                cnt = cnt + 1;
            });
            $(".tblitemsupp").each(function (value, tbl) {
                var tblid = $(tbl).attr("id");
                var cnt2 = 0;
                $('#' + tblid + ' tbody tr').each(function (x, tr) {
                    $(tr).find('td').eq(0).text(cnt2);
                    cnt2 = cnt2 + 1;
                });
            });
        }

        function tpmTableChange(type) {
            if (type == "EDITNAME") {

                $('#item-table tbody tr').each(function (x, tr) {
                    var rowid = $(tr).find('td').eq(0).text();
                    var tpmitems = $(tr).find("td:eq(2) input[type='text']").val();
                    $(".tblitemsupp").each(function (value, tbl) {
                        var tblid = $(tbl).attr("id");
                        var trchg = $("#" + tblid + " tbody tr:eq(" + rowid + ")");
                        $(trchg).find('td').eq(1).text(tpmitems);
                        $(trchg).find("td:eq(2) input[type='text']").val(tpmitems);
                    });
                });
            }

            if (type == "ADDROW") {
                var idtrtocopy = $('#item-table tbody tr').length;
                var tr = $('#item-table tbody tr:eq(' + (idtrtocopy - 1) + ')');
                $(".tblitemsupp").each(function (value, tbl) {
                    var tblid = $(tbl).attr("id");
                    if ($(tbl).length != idtrtocopy) {
                        var suppcnt = tblid.replace("tblitemsupp","").replace("_","")
                        var tbody = $("#" + tblid + " tbody");
                        var rowtr = $("<tr>");
                        var td = $("<td>");
                        var tdrownum, tdtpmitem = "";

                        rowtr = $("<tr>");
                        tdrownum = idtrtocopy - 1;
                        td = $("<td class='hidden'>").html(tdrownum);
                        rowtr.append(td);

                        tdtpmitem = $(tr).find("td:eq(2) input[type='text']").val();
                        td = $("<td>").html(tdtpmitem);
                        rowtr.append(td);

