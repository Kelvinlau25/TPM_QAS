@using TPM_QAS.Models
@model COAMMMaterialModel

@{
    ViewBag.Title = "MM TPM RAW MATERIAL SPECIFICATION - Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>

    /* Rotate tab text vertically */
    .vertical-tabs .nav-link {
        writing-mode: vertical-rl; /* Rotates text vertically */
        transform: rotate(180deg); /* Ensures proper text alignment */
        text-align: left;
        background-color: #F0F0F0 !important;
        height: 100px;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 15px;
        border-top-left-radius: 0px;
        border-bottom-left-radius: 0px;
        border-top-right-radius: 15px;
        border-bottom-right-radius: 15px;
    }

        .vertical-tabs .nav-link:not(:first-child) {
            margin-top: 5px;
            /*border-bottom-right-radius: 15px;*/
        }



    .tab-content {
        flex-grow: 1;
    }

    #nav-summary, #nav-allsup {
        border: 10px solid #EBF3FF !important;
    }

    .vertical-tabs .nav-link.active {
        color: #54575A !important;
        background-color: #EBF3FF !important;
        font-weight: bold;
    }

    #nav-allsup .nav-link.active {
        color: #54575A !important;
        background-color: white !important;
        font-weight: bold;
    }

    .tabtitle {
        /*padding-left: 12px;*/
        background-color: #EBF3FF;
        margin: 0px;
        padding-top: 0px;
        padding-bottom: 0px;
    }

        .tabtitle h6 {
            padding-bottom: 0px;
            margin-bottom: 0px;
            padding-left: 0px !important;
        }

    .tabdetail {
        margin: 5px 0px;
    }

    .btn {
        --bs-btn-padding-x: 0 !important;
    }

    .btnsupplierplus {
        margin: 10px;
    }

    .nav-tabs {
        background-color: #EBF3FF;
    }

    #nav-allsup .nav-link {
        min-width: 10px;
    }

        #nav-allsup .nav-link:not(:first-child) {
            margin-left: 5px;
            /*border-bottom-right-radius: 15px;*/
        }

    .detailTable th, .detailTable td {
        border: 1px solid #d3c8c8;
    }
</style>

<div class="row g-0 px-3 tr-listing-header">
    <div class="col-sm-6 align-self-center">
        <p class="text-muted m-0 tr-listing-header-title main-title">View Form - Raw Material Specification</p>
    </div>
    <div class="col-sm-6 text-end align-self-center">
        <div class="d-flex justify-content-end">
            <div id="customDTButton"></div>
        </div>
    </div>
</div>

<div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

<div class="page-container px-3 overflow-auto">
    <div class="tr-btm-btn-margin">
        <div class="card mt-3 mb-2 card-height">
            <div class="card-body">
                <div class="row align-items-baseline">
                    <div class="col"><h6 class="card-title text-muted">Raw Material Specification</h6></div>
                    @if (Model.RECORD_TYP != null)
                    {
                    if (@Model.RECORD_TYP != "5")
                    {
                    <div class="col text-end"><button class="btn btn-sm btn-primary" id="btnEdit" type="button" data-behaviour="toggle">Edit</button></div>
                    }

                    }
                </div>

                <hr />

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">
                            <span>Material Name</span>
                            <span class="text-danger isEditable" style="display:none">*</span>
                            <span style="float:right">:</span>
                        </p>
                    </div>
                    <div class="col-sm-3 d-flex">
                        @Html.TextBoxFor(m => m.MATERIAL_NAME, null, new { @id = "txtMatName", @class = "form-control", @disabled = "disabled" })
                    </div>
                    <div class="col-sm-1">
                    </div>

                    <div class="col-sm-2">
                        <p class="text-muted">
                            <span>Abbreviation </span>
                            <span style="float:right">:</span>
                        </p>
                    </div>
                    <div class="col-sm-3 d-flex">
                        @Html.TextBoxFor(m => m.MATERIAL_ABBR, null, new { @id = "txtMatAbbr", @class = "form-control", @disabled = "disabled" })
                    </div>
                </div>
                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">
                            <span>Material Code</span>
                            <span class="text-danger isEditable" style="display:none">*</span>
                            <span style="float:right">:</span>
                        </p>
                    </div>
                    <div class="col-sm-3 d-flex">
                        @Html.TextBoxFor(m => m.MATERIAL_CODE, null, new { @id = "txtMatCode", @class = "form-control", @disabled = "disabled" })
                    </div>
                    <div class="col-sm-1">
                    </div>

                    <div class="col-sm-2">
                        <p class="text-muted">
                            <span>TPM Code </span>
                            <span style="float:right">:</span>
                        </p>
                    </div>
                    <div class="col-sm-3 d-flex">
                        @Html.TextBoxFor(m => m.TPM_CODE, null, new { @id = "txtTPMCode", @class = "form-control", @disabled = "disabled" })
                    </div>
                </div>

                <div class="page-container px-3 overflow-auto" style="padding-left:0px !important;">
                    <div class="tr-btm-btn-margin">
                        <div class="card mt-3 mb-2 card-height height-override">
                            <div class="card-body">
                                <!-- Left-Side Tab Layout with Vertical Text -->
                                <div class="d-flex">
                                    <!-- Tabs (Sidebar on Left with Vertical Text) -->
                                    <nav class="nav flex-column nav-pills vertical-tabs" id="nav-tab" role="tablist">
                                        <button class="nav-link active" id="nav-summary-tab" data-bs-toggle="pill" data-bs-target="#nav-summary" type="button" role="tab" aria-controls="nav-summary" aria-selected="true">TPM</button>
                                        <button class="nav-link" id="nav-allsup-tab" data-bs-toggle="pill" data-bs-target="#nav-allsup" type="button" role="tab" aria-controls="nav-allsup" aria-selected="false">Supplier</button>
                                    </nav>
                                    <!-- Tab Content (Right Side) -->
                                    <div class="tab-content align-items-baseline" id="nav-tabContent">
                                        @*TPM TAB*@
                                        <div class="tab-pane fade show active" id="nav-summary" role="tabpanel" aria-labelledby="nav-summary-tab">
                                            <div class="row align-items-baseline tabtitle">
                                                <h6 class="card-title text-muted">TPM Raw Material Specifications</h6>
                                                <hr />
                                                <br />
                                            </div>
                                            <div class="row tabdetail">
                                                <div class="row mt-2 align-items-baseline">

                                                    <div class="col"><span class="text-muted">Inspection Item</span></div>
                                                    <div class="col text-end isEditable" style="display:none">
                                                        <button class="btn btn-sm btn-danger" id="btnRemove" type="button">Remove</button>
                                                        <button class="btn btn-sm btn-primary" id="btnAdd" type="button" onclick="addrow();">Add</button>
                                                    </div>
                                                </div>
                                                <div class="row mt-2 mx-1 isEditable" style="display:none">
                                                    <table id="item-table" class="detailTable" style="width:100%">
                                                        <thead>
                                                            <tr class="toolbar-row">
                                                                <th class="hidden">id</th>
                                                                <th style="width: 3%; text-align: center;">
                                                                    <input id="trCheckbox" type="checkbox" class="dt-checkboxes select-all form-check-input" style="margin-top:5.5px; display:none">
                                                                </th>
                                                                <th>
                                                                    <span>Items</span>
                                                                    <span class="text-danger isEditable" style="display:none">*</span>
                                                                </th>
                                                                <th>Set Value</th>
                                                                <th>Unit of Measurement</th>
                                                                <th class="hidden">type</th>
                                                                <th></th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @{ var cnt = 0;}
                                                            @for (var j = 0; j < Model.TPMMatSpecList.Count; j++)
                                                            {
                                                            <tr>
                                                                <td class="hidden">@cnt</td>
                                                                <td class="text-center">
                                                                    <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk" onClick="handleCheckboxClick(this)">
                                                                </td>
                                                                <td>
                                                                    <input type="text" class="form-control" id="items" onChange="tpmTableChange('EDITNAME');" value="@Model.TPMMatSpecList[j].TPM_SPEC_NAME">
                                                                </td>
                                                                <td>
                                                                    <div class="input-group">
                                                                        <input type="text" class="form-control" id="itemsval" value="@Model.TPMMatSpecList[j].TPM_SPEC_VALUE" disabled="disabled">
                                                                        <button type="button" id="btnTPMSetVal" class="btn-info input-group-text tr-input-group fa-solid fa-ellipsis" data-bs-target="#SetValue" title="Set Value" style="margin: 0;" onclick="openSetValue(this);"></button>
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    @*<input type="text" class="form-control" id="itemsuom" value="@Model.TPMMatSpecList[j].TPM_SPEC_UOM">*@
                                                                    <select class="ddloption form-select form-control ddlTPMUOM" id="ddlTPMUOM_@cnt" name="@Model.TPMMatSpecList[j].TPM_SPEC_UOM"></select>
                                                                </td>
                                                                <td class="hidden">
                                                                    <input type="text" class="form-control" id="itemstype" value="@Model.TPMMatSpecList[j].TPM_SPEC_TYPE" disabled="disabled">
                                                                </td>
                                                                <td>
                                                                    <button type="button" class="btn-info input-group-text tr-input-group fa-solid fa-plus" style="margin: 0;" onclick="addsamerow(this);"></button>
                                                                </td>
                                                                <td class="hidden">@Model.TPMMatSpecList[j].MM_MATERIAL_D1_ID</td>
                                                            </tr>
                                                            cnt = cnt + 1;
                                                            }
                                                        </tbody>
                                                    </table>

                                                </div>
                                                <div class="row mt-2 mx-1 isNotEditable">
                                                    <table class="detailTable" style="width:100%">
                                                        <thead>
                                                            <tr class="toolbar-row">
                                                                <th>Items</th>
                                                                <th>Set Value</th>
                                                                <th>Unit of Measurement</th>

                                                            </tr>
                                                        </thead>
                                                        <tbody>

                                                            @for (var j = 0; j < Model.TPMMatSpecList.Count; j++)
                                                            {
                                                            <tr>
                                                                <td>@Model.TPMMatSpecList[j].TPM_SPEC_NAME</td>
                                                                <td>@Model.TPMMatSpecList[j].TPM_SPEC_VALUE</td>
                                                                <td>@Model.TPMMatSpecList[j].TPM_SPEC_UOM</td>
                                                            </tr>

                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                            <br />
                                        </div>

                                        <div class="tab-pane fade" id="nav-allsup" role="tabpanel" aria-labelledby="nav-allsup-tab">
                                            <div>
                                                @{ List<SUPPMatSpecList>
                                                    supplierlist = new List<SUPPMatSpecList>
                                                        ();
                                                        supplierlist = Model.SUPPMatSpecList.GroupBy(x => new { x.MM_SUPPLIER_H_ID, x.SUPPLIER_NAME, x.SUPP_MATERIAL_NAME })
                                                        .Select(g => new SUPPMatSpecList
                                                        {
                                                        MM_SUPPLIER_H_ID = g.Key.MM_SUPPLIER_H_ID,
                                                        SUPPLIER_NAME = g.Key.SUPPLIER_NAME,
                                                        SUPP_MATERIAL_NAME = g.Key.SUPP_MATERIAL_NAME
                                                        }).ToList();
                                                        var cntsuppnav = 1; }
                                                        <input type="hidden" id="suppliercount" value="@supplierlist.Count" />
                                                        <div class="row align-items-baseline tabtitle">
                                                            <h6 class="card-title text-muted">Supplier Raw Material Specifications</h6>
                                                            <hr />
                                                            <br />
                                                        </div>
                                                        <nav class="tr-tab">
                                                            <div class="nav nav-tabs" id="nav-tab" role="tablist">
                                                                @if (supplierlist.Count > 0)
                                                                {
                                                                for (var j = 0; j < supplierlist.Count; j++)
                                                                {
                                                                string pact = cntsuppnav == 1 ? "active" : "";
                                                                <button class="nav-link @pact nav-link-supp" id="nav-tab_supplier_@cntsuppnav" data-bs-toggle="tab" data-bs-target="#nav-supplier_@cntsuppnav" type="button" role="tab" aria-controls="nav-supplier_@cntsuppnav" aria-selected="true">
                                                                    @supplierlist[j].SUPPLIER_NAME.ToString()
                                                                    &nbsp;<i class="fas fa-close dark-grey isEditable" id="close_@cntsuppnav" onclick="DeleteSupplierTab(this);" style="display:none"></i>
                                                                </button>

                                                                cntsuppnav = cntsuppnav + 1;
                                                                }
                                                                }
                                                                else
                                                                {
                                                                <button class="nav-link active nav-link-supp isEditable" style="display:none" id="nav-tab_supplier_1" data-bs-toggle="tab" data-bs-target="#nav-supplier_1" type="button" role="tab" aria-controls="nav-supplier_1" aria-selected="true">
                                                                    Supplier 1
                                                                    &nbsp;<i class="fas fa-close dark-grey isEditable" id="close_1" onclick="DeleteSupplierTab(this);" style="display:none"></i>
                                                                </button>
                                                                }
                                                                <span id="btnsupplierplus" class="btnsupplierplus isEditable" style="display:none"><i class="fa-solid fa-plus text-primary"></i></span>
                                                            </div>
                                                        </nav>
                                                        <div class="row tabdetail">
                                                            <div class="tab-content p-2" id="nav-tabContent">
                                                                <div id="dumdum" style="display:none"></div>
                                                                @{
                                                                var cntsuppdiv = 1;
                                                                }
                                                                @if (supplierlist.Count > 0)
                                                                {
                                                                for (var j = 0; j < supplierlist.Count; j++)
                                                                {
                                                                string pact = cntsuppdiv == 1 ? "show active" : "";
                                                                <div class="tab-pane fade @pact" id="nav-supplier_@cntsuppdiv" role="tabpanel" aria-labelledby="nav-tab_supplier_@cntsuppdiv" tabindex="0">
                                                                    <div class="row align-items-baseline">
                                                                        <div class="col-sm-2">
                                                                            <p class="text-muted">
                                                                                <span>Supplier Name</span>
                                                                                <span class="text-danger isEditable" style="display:none">*</span>
                                                                                <span style="float:right">:</span>
                                                                            </p>
                                                                        </div>
                                                                        <div class="col-sm-4">
                                                                            <input type="text" id="txtSuppName_@cntsuppdiv" value="@supplierlist[j].SUPPLIER_NAME" class="form-control" disabled />
                                                                            <input type="text" id="txtSuppID_@cntsuppdiv" value="@supplierlist[j].MM_SUPPLIER_H_ID" class="hidden" />
                                                                        </div>
                                                                        <div class="col-sm-2">
                                                                            <p class="text-muted">
                                                                                <span>Supplier Material Name</span>
                                                                                <span class="text-danger isEditable" style="display:none">*</span>
                                                                                <span style="float:right">:</span>
                                                                            </p>
                                                                        </div>
                                                                        <div class="col-sm-4">
                                                                            <input type="text" class="form-control txtSuppMatName isEditable" id="txtSuppMatName_@cntsuppdiv" value="@supplierlist[j].SUPP_MATERIAL_NAME" disabled />
                                                                        </div>
                                                                    </div>
                                                                    <br />
                                                                    <div id="divitemtblsupp_@cntsuppdiv" class="isEditable" style="display:none;">
                                                                        <table class='detailTable tblitemsupp' id='tblitemsupp_@cntsuppdiv' style='width:100%;'>
                                                                            <thead>
                                                                                <tr class='toolbar-row'>
                                                                                    <th class='hidden'>ROWID</th>
                                                                                    <th>TPM Inspection Item</th>
                                                                                    <th>Supplier Inspection Item</th>
                                                                                    <th>Set Value</th>
                                                                                    <th>UOM</th>
                                                                                    <th class='hidden'>TYpe</th>
                                                                                    <th class='hidden'>MM_MATERIAL_D2_ID</th>
                                                                                    <th class='hidden'>MM_MATERIAL_D1_ID</th>
                                                                                </tr>
                                                                            </thead>
                                                                            @{ List
                                                                            <SUPPMatSpecList>
                                                                                thissuppitems = Model.SUPPMatSpecList
                                                                                .Where(x => x.MM_SUPPLIER_H_ID == supplierlist[j].MM_SUPPLIER_H_ID)
                                                                                .ToList();
                                                                                var cntitems = 0;
                                                                                }
                                                                                @if (thissuppitems.Count > 0)
                                                                                {
                                                                                <tbody>
                                                                                    @foreach (var supitems in thissuppitems)
                                                                                    {
                                                                                    <tr>
                                                                                        <td class="hidden">@cntitems</td>
                                                                                        <td>@supitems.TPM_SPEC_NAME</td>
                                                                                        <td>
                                                                                            <input type="text" class="form-control txtSuppInspItem" id="txtSuppInspItem_@cntitems" value="@supitems.SUPP_SPEC_NAME" />
                                                                                        </td>
                                                                                        <td>
                                                                                            <div class="input-group">
                                                                                                <input type="text" class="form-control" id="txtSuppSetVal_@cntitems" value="@supitems.SUPP_SPEC_VALUE" disabled />
                                                                                                <button type="button" id="btnSuppSetVal_@cntsuppdiv _@cntitems" class="btnSuppSetVal btn-info input-group-text tr-input-group fa-solid fa-ellipsis" data-bs-target="#SetValue" title="Set Value" style="margin: 0;" onclick="openSetValue(this);"></button>
                                                                                            </div>
                                                                                        </td>
                                                                                        <td>
                                                                                            @*<input type="text" class="form-control txtSuppUOM" id="txtSuppUOM_@cntitems" value="@supitems.SUPP_SPEC_UOM" />*@
                                                                                            <select class="ddloption form-select form-control ddlSuppUOM" id="ddlSuppUOM_@cntitems" name="@supitems.SUPP_SPEC_UOM"></select>
                                                                                        </td>
                                                                                        <td class="hidden">
                                                                                            <input type="text" class="form-control" id="txtSuppSetType_@cntitems" value="@supitems.SUPP_SPEC_TYPE" disabled />
                                                                                        </td>
                                                                                        <td class="hidden">@supitems.MM_MATERIAL_D2_ID</td>
                                                                                        <td class="hidden">@supitems.MM_MATERIAL_D1_ID</td>
                                                                                    </tr>

                                                                                    cntitems = cntitems + 1;
                                                                                    }
                                                                                </tbody>
                                                                                }

                                                                        </table>
                                                                    </div>
                                                                    <div class="isNotEditable">
                                                                        <table class='detailTable' style='width:100%;'>
                                                                            <thead>
                                                                                <tr class='toolbar-row'>
                                                                                    <th>TPM Inspection Item</th>
                                                                                    <th>Supplier Inspection Item</th>
                                                                                    <th>Set Value</th>
                                                                                    <th>UOM</th>
                                                                                </tr>
                                                                            </thead>
                                                                            @{ List
                                                                            <SUPPMatSpecList>
                                                                                thissuppitemsv = Model.SUPPMatSpecList
                                                                                .Where(x => x.MM_SUPPLIER_H_ID == supplierlist[j].MM_SUPPLIER_H_ID)
                                                                                .ToList();
                                                                                }
                                                                                @if (thissuppitems.Count > 0)
                                                                                {
                                                                                <tbody>
                                                                                    @foreach (var supitems in thissuppitemsv)
                                                                                    {
                                                                                    <tr>
                                                                                        <td>@supitems.TPM_SPEC_NAME</td>
                                                                                        <td>@supitems.SUPP_SPEC_NAME</td>
                                                                                        <td>@supitems.SUPP_SPEC_VALUE</td>
                                                                                        <td>@supitems.SUPP_SPEC_UOM</td>
                                                                                    </tr>
                                                                                    }
                                                                                </tbody>
                                                                                }
                                                                        </table>
                                                                    </div>
                                                                    <br />
                                                                </div>
                                                                cntsuppdiv = cntsuppdiv + 1;
                                                                }
                                                                }
                                                                else
                                                                {
                                                                <div class="tab-pane fade show active isEditable" style="display:none" id="nav-supplier_1" role="tabpanel" aria-labelledby="nav-tab_supplier_1" tabindex="0">
                                                                    <div class="row align-items-baseline">
                                                                        <div class="col-sm-2">
                                                                            <p class="text-muted">
                                                                                <span>Supplier Name</span>
                                                                                <span class="text-danger">*</span>
                                                                                <span style="float:right">:</span>
                                                                            </p>
                                                                        </div>
                                                                        <div class="col-sm-4">
                                                                            <select class="ddlSupplier ddloption form-control form-select" id="ddlSupplier1" onChange="ChangeSupplier(this);">
                                                                                <option value=" ">Select Supplier</option>
                                                                            </select>
                                                                        </div>
                                                                        <div class="col-sm-2">
                                                                            <p class="text-muted">
                                                                                <span>Supplier Material Name</span>
                                                                                <span class="text-danger">*</span>
                                                                                <span style="float:right">:</span>
                                                                            </p>
                                                                        </div>
                                                                        <div class="col-sm-4">
                                                                            <input type="text" class="form-control txtSuppMatName" id="txtSuppMatName_1" />
                                                                        </div>
                                                                    </div>
                                                                    <br />
                                                                    <div id="divitemtblsupp_1">

                                                                    </div>
                                                                    <br />
                                                                </div>
                                                                }
                                                            </div>
                                                        </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>



                <div class="hideInfo">
                    <hr />

                    <div class="row row-cols-2 mt-4">
                        <div class="col align-self-center">
                            <h6 style="float: left" class="text-muted">Entry Details</h6>
                        </div>
                        <div class="col">

                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_BY">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_BY">
                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_DATE">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_DATE">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row tr-btm-btn-area">
            @if (Model.RECORD_TYP != null)
            {
            if (@Model.RECORD_TYP != "5")
            {
            <div class="col"><button id="btnDeleteView" type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#delete-confirmation-modal">Delete</button></div>
            }

            }
            <div class="col">
                <div class="row row-cols-auto justify-content-end isNotEditable" style="padding-right: 20px">
                    <div class="col"><button id="btnCancelView" type="button" class="btn btn-sm btn-secondary">Back</button></div>
                </div>

                <div class="row row-cols-auto justify-content-end isEditable g-1" style="display:none; padding-right: 20px">
                    <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#edit-back-confirmation-modal">Back</button></div>
                    <div class="col"><button id="btnSubmit" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal">Submit</button></div>
                </div>
            </div>
        </div>

    </div>
</div>


@*formula modal*@
