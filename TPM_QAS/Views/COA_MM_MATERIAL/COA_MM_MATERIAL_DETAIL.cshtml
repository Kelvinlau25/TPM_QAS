                    </div>
                    <div class="row mt-2 align-items-center">
                        <div class="col-sm-2">
                            <p class="text-muted">Set value preview <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-6">
                            <input class="form-control modalform required-field-modal" id="txtSetValuePreview" type="text" maxlength="200" disabled />
                        </div>
                        <div class="col-sm-3">
                            <button type="button" class="btn btn-outline-dark varerase" id="btnerase" value="Backspace" onclick='varClickErase(); return false;'>Backspace</button>
