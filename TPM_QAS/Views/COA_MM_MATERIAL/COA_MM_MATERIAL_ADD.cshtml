<script>
    // show formula modal
    function openSetValue(x) {
        var currtr = x.closest('tr');
        var count = $(currtr).find('td').eq(0).text();
        $("#current_count").val(count);
        $("#current_open_by").val($(x).attr("id"));
        $("#txtSetValuePreview").val('');

        $("#SetValueModal").modal("show");
        document.getElementById("setvalNumeric").checked = true;
        $('#valnumeric').show();
        $('#valtext').hide();
        $('#valrange').hide();
        $("#btnerase").show();
    }

    $('#setvalNumeric, #setvalText, #setvalRange').on('change', function () {
        $("#txtsetvalmin").val('');
        $("#txtsetvalmax").val('');
        $("#txtsetvaltypetext").val('');
        if (this.value == "Numeric") {
            $('#valnumeric').show();
            $("#btnerase").show();
            $('#valtext').hide();
            $('#valrange').hide();
        } else if (this.value == "Text") {
            $('#valnumeric').hide();
            $('#valtext').show();
            $('#valrange').hide();
            $("#btnerase").hide();
        } else if (this.value == "Range") {
            $('#valnumeric').hide();
            $('#valtext').hide();
            $('#valrange').show();
            $("#btnerase").hide();
        } else {
            $('#valnumeric').hide();
            $('#valtext').hide();
            $('#valrange').hide();
            $("#btnerase").hide();
        }
    });

    function varClickSymbol(text) {
        var txt = $('#txtSetValuePreview').val();
        var trimmedValue = $.trim(txt);
        $('#txtSetValuePreview').val(trimmedValue + " " + text);
    }

    function varClickNumber(num) {
        $('.invalid-feedback').remove();
        $('.is-invalid').removeClass('is-invalid');
        var txt = $('#txtSetValuePreview').val();
        $('#txtSetValuePreview').focus();
        var trimmedValue = $.trim(txt);

        if (!isNaN(trimmedValue.slice(-1)) || trimmedValue.slice(-1) === '.') {
            $('#txtSetValuePreview').val(trimmedValue + num);
        } else {
            $('#txtSetValuePreview').val(trimmedValue + ' ' + num);
        }

        txt = $('#txtSetValuePreview').val();
        $('#txtSetValuePreview').val($.trim(txt).substring(0, 200));
    }

    function varClickErase() {
        $('.invalid-feedback').remove();
        $('.is-invalid').removeClass('is-invalid');
        var txt = $('#txtSetValuePreview').val();
        $('#txtSetValuePreview').focus();

        if (txt.length > 0) {
            var trimmedValue = $.trim(txt);
            var parts = trimmedValue.split(" ");
            var lastPart = parts[parts.length - 1];

            if (/^var[1-6]$/.test(lastPart)) {
                // If the last part is a variable (e.g., var1, var2), remove the entire variable
                parts.pop();
                $('#txtSetValuePreview').val(parts.join(" "));
            } else {
                // Otherwise, just remove the last character
                $('#txtSetValuePreview').val(trimmedValue.slice(0, -1));
            }
        }
    }

    function varChangeText() {
        $('.invalid-feedback').remove();
        $('.is-invalid').removeClass('is-invalid');
        var txtprev = $('#txtSetValuePreview');
        var txt = $('#txtsetvaltypetext').val();
        var trimmedValue = $.trim(txt).substring(0, 200);
        $('#txtSetValuePreview').val(trimmedValue);
    }

    function varChangeRange() {
        var txtprev = $('#txtSetValuePreview');
        var txtmin = $('#txtsetvalmin').val();
        var txtmax = $('#txtsetvalmax').val();
        var concat = "";
        $('.invalid-feedback').remove();
        $('.is-invalid').removeClass('is-invalid');
        if ((txtmin != "" && txtmax != "") && (parseFloat(txtmax) > parseFloat(txtmin))) {
            concat = $.trim(txtmin) + " ~ " + $.trim(txtmax);
        } else {           
            $('.required-field-modal').each(function (e) {
                console.log(this);
                    $(this).addClass('is-invalid');
                    inputCustomError(this, "Maximum value need to be more than minimum value");
            });
            concat = "";
        }

        $('#txtSetValuePreview').val(concat);
    }

</script>

