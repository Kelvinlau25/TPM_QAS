@using TPM_QAS.Models
@model COAMMMaterialModel
@{
    ViewBag.Title = "MM RAW MATERIAL SPECIFICATION - Add";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>

    /* Rotate tab text vertically */
    .vertical-tabs .nav-link {
        writing-mode: vertical-rl; /* Rotates text vertically */
        transform: rotate(180deg); /* Ensures proper text alignment */
        text-align: left;
        background-color: #F0F0F0 !important;
        height: 100px;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 15px;
        border-top-left-radius: 0px;
        border-bottom-left-radius: 0px;
        border-top-right-radius: 15px;
        border-bottom-right-radius: 15px;
    }

        .vertical-tabs .nav-link:not(:first-child) {
            margin-top: 5px;
            /*border-bottom-right-radius: 15px;*/
        }


    .tab-content {
        flex-grow: 1;
    }

    #nav-summary, #nav-allsup {
        border: 10px solid #EBF3FF !important;
    }

    .vertical-tabs .nav-link.active {
        color: #54575A !important;
        background-color: #EBF3FF !important;
        font-weight: bold;
    }

    #nav-allsup .nav-link.active {
        color: #54575A !important;
        background-color: white !important;
        font-weight: bold;
    }

    .tabtitle {
        /*padding-left: 12px;*/
        background-color: #EBF3FF;
        margin: 0px;
        padding-top: 0px;
        padding-bottom: 0px;
    }

        .tabtitle h6 {
            padding-bottom: 0px;
            margin-bottom: 0px;
            padding-left: 0px !important;
        }

    .tabdetail {
        margin: 5px 0px;
    }

    .btn {
        --bs-btn-padding-x: 0 !important;
    }

    .btnsupplierplus {
        margin: 10px;
    }

    .nav-tabs {
        background-color: #EBF3FF;
    }

    #nav-allsup .nav-link {
        min-width: 10px;
    }

        #nav-allsup .nav-link:not(:first-child) {
            margin-left: 5px;
            /*border-bottom-right-radius: 15px;*/
        }

</style>

@using (Html.BeginForm("COA_MM_MATERIAL_ADD", "COA_MM_MATERIAL", FormMethod.Post, new { encType = "multipart/form-data" }))
{
