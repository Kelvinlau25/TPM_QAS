@*formula modal*@
<div class="modal fade" id="SetValueModal" tabindex="-1" role="dialog" data-backdrop="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="float:left;">Set Value</h5>
            </div>
            <hr />

            <input type="hidden" id="current_count" />
            <input type="hidden" id="current_open_by" />
            <div class="modal-body" id="searchSourceBody">
                <div class="container-fluid">
                    <div class="row align-items-center">
                        <div class="col-sm-2">
                            <p class="text-muted">
                                <span>Value Type</span>
                                <span class="text-danger">*</span>
                                <span style="float:right">:</span>
                            </p>
                        </div>
                        <div class="col-sm-5" style="margin-top:0px; margin-bottom:1rem;">
                                <input type="radio" id="setvalNumeric" name="valueType" value="Numeric" /> Numeric &nbsp;&nbsp;
                                <input type="radio" id="setvalText" name="valueType" value="Text" /> Text &nbsp;&nbsp;
                                <input type="radio" id="setvalRange" name="valueType" value="Range" /> Range
                        </div>
                    </div>
                    <div id="valnumeric">
                        <div class="row align-items-center">
                            <div class="col-sm-2">
                                <p class="text-muted">Symbol <span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-5">
                                <button type="button" class="btn btn-outline-dark varinput" id="btnsym1" value="<=" onclick='varClickSymbol("<="); return false;'><=</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnsym2" value=">=" onclick='varClickSymbol(">="); return false;'>>=</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnsym3" value="<" onclick='varClickSymbol("<"); return false;'><</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnsym4" value=">" onclick='varClickSymbol(">"); return false;'>></button>
                                @*<button type="button" class="btn btn-outline-dark varinput" id="btnsym5" value="+-" onclick='varClickSymbol("+-"); return false;'>+-</button>*@
                                <button type="button" class="btn btn-outline-dark varinput" id="btnsym6" value="/" onclick='varClickSymbol("/"); return false;'>/</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnsym7" value="." onclick='varClickNumber("."); return false;'>.</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnsym7" value="-" onclick='varClickSymbol("-"); return false;'>-</button>
                            </div>
                        </div>

                        <div class="row align-items-center">
                            <div class="col-sm-2">
                                <p class="text-muted">Number <span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-7">
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum1" value="1" onclick='varClickNumber("1"); return false;'>1</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum2" value="2" onclick='varClickNumber("2"); return false;'>2</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum3" value="3" onclick='varClickNumber("3"); return false;'>3</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum4" value="4" onclick='varClickNumber("4"); return false;'>4</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum5" value="5" onclick='varClickNumber("5"); return false;'>5</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum6" value="6" onclick='varClickNumber("6"); return false;'>6</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum7" value="7" onclick='varClickNumber("7"); return false;'>7</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum8" value="8" onclick='varClickNumber("8"); return false;'>8</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum9" value="9" onclick='varClickNumber("9"); return false;'>9</button>
                                <button type="button" class="btn btn-outline-dark varinput" id="btnnum0" value="0" onclick='varClickNumber("0"); return false;'>0</button>
                            </div>
                        </div>
                    </div>
                    <div id="valtext">
                        <div class="row align-items-center">
                            <div class="col-sm-2">
                                <p class="text-muted">Text value <span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-6">
                                <input class="form-control" id="txtsetvaltypetext" type="text" onchange="varChangeText();" maxlength="200"/>
                            </div>
                        </div>
                    </div>
                    <div id="valrange">
                        <div class="row align-items-center">
                            <div class="col-sm-2">
                                <p class="text-muted">Minimum <span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-2">
                                <input class="form-control" id="txtsetvalmin" type="number" onchange="varChangeRange();" />
                            </div>
                        </div>
                        <br />
                        <div class="row align-items-center">
                            <div class="col-sm-2">
                                <p class="text-muted">Maximum <span style="float:right">:</span></p>
                            </div>
                            <div class="col-sm-2">
                                <input class="form-control" id="txtsetvalmax" type="number" onchange="varChangeRange();" />
                            </div>
                        </div>
                        <br />
                    </div>
                    <div class="row mt-2 align-items-center">
                        <div class="col-sm-2">
                            <p class="text-muted">Set value preview <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-6">
                            <input class="form-control modalform required-field-modal" id="txtSetValuePreview" type="text" maxlength="200" disabled  />
                        </div>
                        <div class="col-sm-3">
                            <button type="button" class="btn btn-outline-dark varerase" id="btnerase" value="Backspace" onclick='varClickErase(); return false;'>Backspace</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="reset" id="btnResetModal" class="btn btn-sm btn-secondary" style="margin-right: auto;">Reset</button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Back</button>
                <button type="button" id="btnsubmitcal" class="btn btn-sm btn-primary">OK</button>
            </div>
        </div>
    </div>
</div>

<script>
    var idh = '@Model.MM_MATERIAL_H_ID' != 0 ? '@Model.MM_MATERIAL_H_ID' : 0;

    var ListOraMaterial = @Html.Raw(ViewBag.SerializedOraMaterial);
    var ListSupplier = @Html.Raw(ViewBag.SerializedSupplierName);
    var ListUom = @Html.Raw(ViewBag.SerializedUOM);

    var opt = '<option value= "" selected>Not Applicable</option>';
    if (ListUom.length > 0) {
        ListUom.forEach(row => {
            opt = '<option value="' + row.Value + '">' + row.Text + '</option>' + opt;
        });
    }

    $(document).ready(function () {

        $(document).on('click', '.ora-link', function (e) {
            e.preventDefault();
            const MatName = $(this).data('name');
            const MatCode = $(this).data('code');
            const MatAbbr = $(this).data('abbr');
            const TPMCode = $(this).data('tpm');
            populateOraDet(MatName, MatCode, MatAbbr, TPMCode);
        });


        console.log(eval(6 > 5));
        console.log(eval(6 > 7));
        var listingURL = '/COA_MM_MATERIAL/COA_MM_MATERIAL_LST';

        $("#suppliercount").val(1);
        populatesupplier("1");

        document.getElementById("ddlTPMUOM_1").innerHTML += opt;

        //populateUOM("TPM","1");
        checkboxChecking();
        loadDataTableOraMaterial(ListOraMaterial);

        //SUBMIT FOR MODAL FORMULA
        $("#btnsubmitcal").click(function () {

            const inputElement = document.getElementById('txtSetValuePreview');

            if (!(inputElement.classList.contains('is-invalid'))) {

                var count = $("#current_count").val();
                var by = $("#current_open_by").val();
                var tr = $('#item-table tbody').find('tr').eq(count);
                var trtpm = $('#item-table tbody').find('tr').eq(count);
                var supplier = false;
                var pass = "Y";

                if (by.includes("btnSuppSetVal")) {
                    var suppcnt = by.replace("btnSuppSetVal", "");
                    tr = $('#tblitemsupp' + suppcnt + ' tbody').find('tr').eq(count);
                    supplier = true;
                }

                var td = $(tr).find('td').eq(3);
                var inp = $(td).find('input[type="text"]')
                var valtype = $(tr).find('td:eq(5) input[type="text"]');
                var formula = $("#txtSetValuePreview").val().trim();
                var tpmformula = $(trtpm).find("td:eq(3) input[type='text']").val().trim();

                const valueTypes = document.querySelectorAll('input[name="valueType"]');
                let selectedValue = null;

                valueTypes.forEach(radioButton => {
                    if (radioButton.checked) {
                        selectedValue = radioButton.value;
                    }
                });

                if (supplier) {
                    pass = compareFormulas(tpmformula, formula, selectedValue);
                    console.log(pass)
                }
                if (pass == "Y") {
                    $(inp).val(formula);
                    $(valtype).val(selectedValue);
                    $("#txtsetvalmin").val('');
                    $("#txtsetvalmax").val('');
                    $("#txtsetvaltypetext").val('');
                    $("#txtSetValuePreview").val('');
                    $("#SetValueModal").modal("hide");
                } else {
                    alert(pass);
                }
            }
        });

        //button + supplier
        $("#btnsupplierplus").click(function () {
            var orisuppcnt = $("#suppliercount").val();
            var suppcnt = $("#suppliercount").val();
            if (!isNaN(parseInt(suppcnt))) {
                suppcnt = parseInt(suppcnt) + 1
            } else {
                suppcnt = 1;
            }

            var $navbartoinsert = $("#nav-tab_supplier_" + orisuppcnt);
            var currbtntoclick = "nav-tab_supplier_" + suppcnt;
