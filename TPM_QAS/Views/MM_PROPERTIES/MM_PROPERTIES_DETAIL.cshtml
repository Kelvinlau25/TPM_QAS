@using TPM_QAS.Models
@model PropertiesModel


@{
    ViewBag.Title = "PROPERTIES MM - Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row g-0 px-3 tr-listing-header">
        <div class="col-sm-6 align-self-center">
        <p class="text-muted m-0 tr-listing-header-title main-title">View Form - Properties</p>
    </div>
    <div class="col-sm-6 text-end align-self-center">
        <div class="d-flex justify-content-end">
            <div id="customDTButton"></div>
        </div>
    </div>
</div>

<div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

<div class="page-container px-3 overflow-auto">
    <div class="tr-btm-btn-margin">
        <div class="card mt-3 mb-2 card-height">
            <div class="card-body">
                <div class="row align-items-baseline">
                    <div class="col"><h6 class="card-title text-muted">Properties</h6></div>
                    @if (Model.RECORD_TYP != null)
                    {
                        if (@Model.RECORD_TYP != "5")
                        {
                            <div class="col text-end"><button class="btn btn-sm btn-primary" id="btnEdit" type="button" data-behaviour="toggle">Edit</button></div>
                        }

                    }
                    <div class="d-none isEditable col-auto">
                        <div class="form-check form-switch p-0">
                            <div class="d-inline-flex flex-row-reverse gap-1">
                                <input class="form-check-input ms-2" type="checkbox" role="switch" id="updHeaderSwitch" />
                                <label class="form-check-label" for="updHeaderSwitch">Update Header</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Main Property <span class="text-danger">*</span><span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        @Html.TextBoxFor(model => model.PROPERTIES, new { @class = "form-control required-field", id = "txtproperties", @maxlength = "100", disabled = "disabled" })

                    </div>
                </div>

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Property Items <span class="text-danger">*</span><span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        @Html.TextBoxFor(model => model.PROP_ITEM, new { @class = "isEditable form-control required-field", id = "txtpropitem", @maxlength = "100", disabled = "disabled" })

                    </div>
                </div>

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Oracle Column Name <span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        @Html.DropDownListFor(Model => Model.OraColumn, Model.DropdownOraColumn, "Not Applicable", new { @id = "ddlOraColumn", @class = "isEditable form-control", disabled = "disabled" })
                    </div>
                    <div class="col-sm-4">
                        <span class="text-danger">(This attribute is solely for Trend reporting. Please refrain from any unnecessary changes)</span>
                    </div>
                </div>

                <div class="row align-items-baseline isEditable">
                    <div class="col-sm-2">
                        <p class="text-muted">Reference Method <span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        @Html.TextBoxFor(model => model.REF_METHOD, new { @class = "isEditable form-control", id = "txtref", @maxlength = "100", disabled = "disabled" })

                    </div>
                </div>

                <div class="row align-items-baseline isEditable">
                    <div class="col-sm-2">
                        <p class="text-muted">Remarks (If any) <span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        @Html.TextBoxFor(model => model.REMARKS, new { @class = "isEditable form-control viewmode", id = "txtremarks", @maxlength = "200", disabled = "disabled" })

                    </div>
                </div>

                <div class="row row-cols-2 mt-4">
                    <div class="col align-self-center">
                        <h6 class="text-muted" style="float: left">Machine Details</h6>
                    </div>
                    <div class="d-none isEditable col normsub">
                        <div class="row row-cols-auto justify-content-end g-1">
                            <div class="col">
                                <button class="btn btn-sm btn-md btn-danger" id="removeBtn" type="button">
                                    Remove
                                </button>
                            </div>
                            <div class="col">
                                <button class="btn btn-sm btn-md btn-primary" id="addBtn" type="button">
                                    Add
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-2 mx-1">
                    <table id="item-table" class="detailTable" style="width:100%">
                        <thead>
                            <tr class="toolbar-row">
                                <th class="d-none isEditable" style="width: 3%; text-align: center;">
                                    <input id="trCheckbox" type="checkbox" class=" dt-checkboxes select-all form-check-input" style="margin-top:5.5px;">
                                </th>
                                <th>Machine Name</th>
                                <th>Machine Path</th>
                                <th>CSV Fields</th>
                            </tr>
                        </thead>
                        <tbody id="tbody">
                            @{ var count = 0; }
                            @if (Model.PropertiesMachineLstModel != null && Model.PropertiesMachineLstModel.Count > 0)
                            {
                                foreach (var item in Model.PropertiesMachineLstModel)
                                {
                                    count++;
                                    <tr id="R_@count" data-did="@count">
                                        <td class="d-none isEditable text-center">
                                            <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_@count" onClick="handleCheckboxClick(this)">
                                        </td>
                                        <td>
                                            <input type="text" class="isEditable required-field form-control" id="item_name_@count" value="@item.MACHINE_NAME" placeholder="" style="border:none; box-shadow: none;" readonly>
                                        </td>
                                        <td>
                                            <input type="text" class="isEditable required-field form-control dis2" id="item_path_@count" value="@item.MACHINE_PATH" placeholder="" style="border:none; box-shadow: none;" readonly>
                                        </td>
                                        <td>
                                            <div class="input-group">
                                                <div class="input-group-text tr-input-group tr-disabled" id="item_field_@count" onclick="csvFieldsModal(@count)">
                                                    <a href="#" class="text-reset vm tr-disabled isEditable" disabled><i class="fa-solid fa-ellipsis" aria-hidden="true" style="color: #fff"></i></a>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="d-none">
                                            <input type="text" class="form-control" id="item_stat_@count" value="0">
                                            <input type="text" class="form-control" id="item_dbid_@count" value="@item.MM_PROPERTIES_D_ID">

                                            <input type="text" class="form-control" id="item_time_@count" value="@item.TESTING_TIME">
                                            <input type="text" class="form-control" id="item_lot_@count" value="@item.LOT_NO">
                                            <input type="text" class="form-control" id="item_operator_@count" value="@item.OPERATOR">

                                            <input type="text" class="form-control" id="item_r1_@count" value="@item.READING_1">
                                            <input type="text" class="form-control" id="item_r2_@count" value="@item.READING_2">
                                            <input type="text" class="form-control" id="item_r3_@count" value="@item.READING_3">
                                            <input type="text" class="form-control" id="item_r4_@count" value="@item.READING_4">
                                            <input type="text" class="form-control" id="item_r5_@count" value="@item.READING_5">
                                            <input type="text" class="form-control" id="item_r6_@count" value="@item.READING_6">

                                            <input type="text" class="form-control" id="item_total_@count" value="@item.TTL_READING">
                                            <input type="text" class="form-control" id="item_avg_@count" value="@item.AVERAGE">
                                        </td>
                                    </tr>
                                }
                            }

                        </tbody>
                    </table>
                    <input type="hidden" id="item-count" value="@count" />
                </div>

                <div class="hideInfo">
                    <hr />

                    <div class="row row-cols-2 mt-4">
                        <div class="col align-self-center">
                            <h6 style="float: left" class="text-muted">Entry Details</h6>
                        </div>
                        <div class="col">

                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_BY">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_BY">
                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_DATE">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_DATE">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row tr-btm-btn-area">
            @if (Model.RECORD_TYP != null)
            {
                if (@Model.RECORD_TYP != "5")
                {
                    <div class="col"><button id="btnDeleteView" type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#delete-confirmation-modal">Delete</button></div>
                }

            }
                    <div class="col">
                        <div class="row row-cols-auto justify-content-end isNotEditable" style="padding-right: 20px">
                            <div class="col"><button id="btnCancelView" type="button" class="btn btn-sm btn-secondary">Back</button></div>
                        </div>

                        <div class="row row-cols-auto justify-content-end isEditable g-1 normsub d-none" style="padding-right: 20px">
                            <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#edit-back-confirmation-modal">Back</button></div>
                            <div class="col"><button id="btnSubmit" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal">Submit</button></div>
                        </div>

                        <div class="row row-cols-auto justify-content-end g-1 updheader d-none" style="padding-right: 20px">
                            <div class="col"><button id="btnBack2" type="button" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#edit-back-confirmation-modal">Back</button></div>
                            <div class="col"><button id="btnSubmitHeader" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal-header">Submit Header</button></div>
                        </div>
                    </div>
        </div>

    </div>
</div>


<div class="modal fade" id="submit-confirmation-modal-header" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmation</h5>
            </div>

            <hr />

            <div class="modal-body">
                <h6>Are you sure to submit properties header record only?</h6>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" data-bs-dismiss="modal" id="btnConfirmSubmitHeader">Confirm</button>
            </div>
        </div>
    </div>
</div>


@*CSV FIELD MODAL*@
<div class="modal fade" id="fieldmodal" tabindex="-1" role="dialog" data-backdrop="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="float:left;">CSV Field Properties</h5>
            </div>
            <hr />

            <input type="hidden" id="current_count" />

            <div class="modal-body" style="overflow-x: auto; white-space: nowrap" id="searchSourceBody">
                <div class="container-fluid">

                    <div id="excelvalue"></div>

                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Machine Name <span class="text-danger">*</span><span style="float:right">:</span></div>
                        <div class="col-md-4"><input class="required-field-modal form-control" id="txt_modal_1" type="text" disabled /></div>
                        <div class="col-md-2 isLabel">Lot No <span class="text-danger">*</span><span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_2", @class = "ddloption isEditable clmnddl required-field-modal form-control form-select dis2", required = "required", disabled = "disabled" })
                        </div>
                    </div>

                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Testing Datetime <span class="text-danger">*</span><span style="float:right">:</span></div>
                        <div class="col-md-4"><input class="required-field-modal form-control" id="txt_modal_3" type="text" disabled /></div>
                        <div class="col-md-2 isLabel">Operator <span class="text-danger">*</span><span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_4", @class = "ddloption isEditable clmnddl required-field-modal form-control form-select dis2", disabled = "disabled" })
                        </div>
                    </div>

                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Reading 1 <span class="text-danger">*</span><span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_5", @class = "ddloption isEditable readfield clmnddl required-field-modal form-control form-select dis2", disabled = "disabled" })
                        </div>
                        <div class="col-md-2 isLabel">Reading 4 <span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_6", @class = "ddloption isEditable readfield clmnddl form-control form-select dis2", disabled = "disabled" })
                        </div>
                    </div>

                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Reading 2 <span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_7", @class = "ddloption isEditable readfield clmnddl form-control form-select dis2", disabled = "disabled" })
                        </div>
                        <div class="col-md-2 isLabel">Reading 5 <span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_8", @class = "ddloption isEditable readfield clmnddl form-control form-select dis2", disabled = "disabled" })
                        </div>
                    </div>

                    <div class="row align-items-center mt-2">
                        <div class="col-md-2 isLabel">Reading 3 <span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_9", @class = "ddloption isEditable readfield clmnddl form-control form-select dis2", disabled = "disabled" })
                        </div>
                        <div class="col-md-2 isLabel">Reading 6 <span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_10", @class = "ddloption isEditable readfield clmnddl form-control form-select dis2", disabled = "disabled" })
                        </div>
                    </div>

                    <div class="row align-items-center mt-2">
                        <div hidden class="col-md-2 isLabel">Total Reading <span style="float:right">:</span></div>
                        <div hidden class="col-md-4"><input class="form-control" id="txt_modal_11" type="text"  disabled /></div>
                        <div class="col-md-2 isLabel">Average <span class="text-danger">*</span><span style="float:right">:</span></div>
                        <div class="col-md-4">
                            @Html.DropDownListFor(Model => Model.DROPDOWN, Model.DropdownColumn, "Select an option..", new { id = "txt_modal_12", @class = "ddloption isEditable clmnddl required-field-modal form-control form-select dis2", disabled = "disabled" })
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer isNotEditable btnbackmodal">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Back</button>
            </div>

            <div class="modal-footer isEditable d-none normsub">
                <button type="reset" id="btnResetFieldModal" class="btn btn-sm btn-secondary">Reset</button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Back</button>
                <button type="button" id="btnsubmitmodal" class="btn btn-sm btn-primary">Submit</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>

    var listFieldValue = []
    $(document).ready(function () {
        checkboxChecking();

        var listingURL = '/MM_PROPERTIES/MM_PROPERTIES_LST';
        var idh = '@Model.MM_PROPERTIES_H_ID';

        $('#updHeaderSwitch').on('change', function () {
            if (this.checked) {
                $('.normsub').addClass("d-none");
                $('.updheader').removeClass("d-none");
                $('.dis2').attr("disabled", "disabled");
                $('.tr-input-group').addClass("tr-disabled");
                $('.btnbackmodal').css("display", "");
                //$('#txtproperties').addClass('viewmode');
            } else {
                $('.updheader').addClass("d-none");
                $('.normsub').removeClass("d-none");
                $('.dis2').removeAttr("disabled");
                $('.tr-input-group').removeClass("tr-disabled");
                $('.btnbackmodal').css("display", "none");
                //$('#txtproperties').removeClass("viewmode");
            }
        });

        //ADD
        $('#addBtn').on('click', function () {

            var cont = true;
            var message = "";

            if (cont) {
                var rowIdx = $('#item-count').val();
                rowIdx++;
                $('#item-count').val(rowIdx);


                $('#item-table tbody').append(`
                <tr id="R_${rowIdx}" data-did="${rowIdx}">
                    <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClick(this)"></td>
                    <td><input type="text" class="form-control required-field"  id="item_name_${rowIdx}" placeholder="" ></td>
                    <td><input type="text" class="form-control required-field dis2" id="item_path_${rowIdx}" placeholder=""></td>
                    <td>
                        <div class="input-group">
                        <div class="input-group-text tr-input-group" id="item_field_${rowIdx}" onclick="csvFieldsModal(${rowIdx})">
                            <a href="#" class="text-reset vm"><i class="fa-solid fa-ellipsis" aria-hidden="true" style="color: #fff"></i></a>
                        </div></div>
                    </td>
                    <td class="d-none">
                        <input type="text" id="item_stat_${rowIdx}" value="1">
                        <input type="text" id="item_dbid_${rowIdx}" value="0">

                        <input type="text" id="item_time_${rowIdx}">
                        <input type="text" id="item_lot_${rowIdx}">
                        <input type="text" id="item_operator_${rowIdx}">

                        <input type="text" id="item_r1_${rowIdx}">
                        <input type="text" id="item_r2_${rowIdx}">
                        <input type="text" id="item_r3_${rowIdx}">
                        <input type="text" id="item_r4_${rowIdx}">
                        <input type="text" id="item_r5_${rowIdx}">
                        <input type="text" id="item_r6_${rowIdx}">

                        <input type="text" id="item_total_${rowIdx}">
                        <input type="text" id="item_avg_${rowIdx}">
                    </td>
                </tr>
                `);

                checkboxChecking();
            } else {
                if (message != "") {
                    displayToast("error", message)
                }
            }

        });

        //REMOVE
        $('#removeBtn').on('click', function () {
            $('#item-table tbody input[type=checkbox]:checked').each(function (idx, ele) {
                var row = $(ele).closest('tr');
                var itemStatInput = row.find('input[id^="item_stat_"]');
                var item_stat = itemStatInput.val();

                if (item_stat != '1') {
                    itemStatInput.val('5');
                    row.hide();
                } else {
                    row.remove();
                }
            });

            checkboxChecking();
        });

        //SUBMIT
        $('#btnConfirmSubmit').on('click', function () {
            $('.invalid-feedback').remove();
            $('.is-invalid').removeClass('is-invalid');

            var cont = true;
            var message = "";

            var txtproperties = $("#txtproperties").val();
            var txtpropitem = $("#txtpropitem").val();
            var txtref = $("#txtref").val();
            var txtremarks = $("#txtremarks").val();
            var txtoracolumn = $("#ddlOraColumn").val();

            if (txtproperties == undefined || txtproperties == null || txtproperties == "") {
                cont = false;
                message += 'Missing Main Property value. <br>';
            }

            if (txtpropitem == undefined || txtpropitem == null || txtpropitem == "") {
                cont = false;
                message += 'Missing Property Items value. <br>';
            }

            $('.required-field').each(function (e) {
                var input_val = $(this).val().trim();
                if (input_val == null || input_val == undefined || input_val === "") {
                    cont = false;
                    $(this).addClass('is-invalid');
                    inputError(this);
                }
            });

            var hasItem = false;
            var hasError = false;
            var hasfieldrequired = false;
            var hasDuplicate = false;
            var existedItem = [];

            var list = [];

            $("#item-table tbody tr").each(function () {
                var did = $(this).data("did");
                if (did != '' && did != null && did != undefined) {
                    var item_stat = $('#item_stat_' + did).val();
                    var item_dbid = $('#item_dbid_' + did).val();

                    var item_name = $('#item_name_' + did).val();
                    var item_path = $('#item_path_' + did).val();

                    var item_time = $('#item_time_' + did).val();
                    var item_lot = $('#item_lot_' + did).val();
                    var item_operator = $('#item_operator_' + did).val();
                    var item_r1 = $('#item_r1_' + did).val();
                    var item_r2 = $('#item_r2_' + did).val();
                    var item_r3 = $('#item_r3_' + did).val();
                    var item_r4 = $('#item_r4_' + did).val();
                    var item_r5 = $('#item_r5_' + did).val();
                    var item_r6 = $('#item_r6_' + did).val();
                    var item_total = $('#item_total_' + did).val();
                    var item_avg = $('#item_avg_' + did).val();

                    var namepath = item_name + '*' + item_path;

                    if (item_stat != '5') {
                        if (namepath !== "") {
                            //hasItem = true;
                            if (existedItem.includes(namepath)) {
                                hasDuplicate = true;
                                return false;
                            } else {
                                if (item_time == '' || item_lot == '' || item_operator == '' || item_r1 == '' || item_avg == '') {
                                    hasfieldrequired = true;
                                    return false;
                                } else {
                                    existedItem.push(namepath);
                                }
                            }
                        } else {
                            hasError = true;
                        }
                    }

                    list.push({
                        'MM_PROPERTIES_D_ID': item_dbid,
                        'RECORD_TYP': item_stat,
                        'MACHINE_NAME': item_name,
                        'MACHINE_PATH': item_path,
                        'TESTING_TIME': item_time,
                        'LOT_NO': item_lot,
