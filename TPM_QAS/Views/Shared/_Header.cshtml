<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.10.2/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<script>
    $(document).ready(function () {
        var deleted = '@deleted';

        if (deleted == '1') {

            let cbCheckDeleted = document.getElementById("cbCheckDeleted");
            cbCheckDeleted.checked = true;

        }
        if (deleted == '0') {

            let cbCheckDeleted = document.getElementById("cbCheckDeleted");
            cbCheckDeleted.checked = false;
        }
    });
</script>
@{
    if (num != 0)   //To check whether the search value is in model or not
    {
        using (Html.BeginForm(postto, ctrlto, FormMethod.Post, new { id = "frmEntry", Model, enctype = "multipart/form-data" }))
        {
            <div id="loadSrh">
                <fieldset>
                    <div class="editor-field">

                        <div class="topleft">
                            <div class="row align-items-baseline">
                                <div class="col-sm-3">
                                    <input type="text" id="SEARCH_VALUE" class="form-control" name=@Html.ViewData["SrcVal"].ToString() value="@Model[0].SEARCH_VALUE" />
                                </div>
                                <div class="col-sm-4">
                                    <button id="btnsubmit" class="btn btn-sm btn-secondary mx-1" style="width:10px; margin-bottom:2px;"><i class="fa fa-search"></i></button>
                                    <input type="hidden" name="Deleted" value="@deleted" />
                                    &nbsp;
                                    <input type="checkbox" class="form-check-input" id="cbCheckDeleted" name="cbCheckDeleted" onclick="CheckDeleted()" style="margin-top:8px;">
                                    <label class="form-check-label" for="cbCheckDeleted"> Show Deleted Records</label>
                                </div>

                            </div>
                        </div>
                        <div class="topright">


                        </div>

                        <div style="float:right;">
                            @*<input class="fa fa-search-plus fa-2x greyiconcolor" onclick="advanceSearchClick()" data-toggle="modal" data-target="#exampleModal1" type="button" />*@
                            @*<a href="#" onclick="advanceSearchClick()" data-toggle="modal" data-target="#exampleModal1" class="fa fa-search-plus fa-2x greyiconcolor"></a>&nbsp; &nbsp;*@
                            <a href="#" onclick="advanceSearchClick()" data-toggle="modal" data-target="#exampleModal1" class="fa fa-filter fa-2x greyiconcolor" data-title="Advance Search"></a>&nbsp; &nbsp;  @*maryam - 14032023*@

                            @if (act != "")
                            {
                                @Html.ActionLink(" ", "AddNew", "Mstmain",
                            new { act = this.ViewData["Act"], ctrl = this.ViewData["Ctrl"] },
                            new { @class = "fa fa-plus-square fa-2x greyiconcolor", @onclick = "loadings();"})
                            }
                        </div>
                        <div class="modal fade" id="exampleModal1" tabindex="-1" role="dialog" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
                            <div class="modal-dialog" role="document">
                                <div id="advanceSearchDiv"></div>
                            </div>
                        </div>
                        <script>
                        function advanceSearchClick() {
                                debugger
                                //alert("test");
                                $("#advanceSearchDiv").load('@(Url.Content("/Home/AdvancedSearch") + "?actionRequested=" + ViewContext.RouteData.Values["action"].ToString() + "/" + ViewContext.RouteData.Values["controller"].ToString())');
                        }

                        function CheckDeleted() {
                            //debugger;
                            var chboxs = document.getElementById("cbCheckDeleted");
                            var deleted = "0";

                            if (chboxs.checked == true) {
                                deleted = "1";
                            }

                            var url = '@Url.Action(ViewContext.RouteData.Values["action"].ToString(), ViewContext.RouteData.Values["controller"].ToString()).ToString()' + '?Deleted=' + deleted;

                            window.location.href = url;
                        }

                        </script>

                    </div>

                </fieldset>

            </div>
        }
    }
    else
    {
        using (Html.BeginForm(postto, ctrlto, FormMethod.Post, new { id = "frmEntry", Model, enctype = "multipart/form-data" }))
        {
            <div id="loadSrh">
                <fieldset>
                    <div class="editor-field">

                        <div class="topleft">
                            <input type="text" id="SEARCH_VALUE" class="searchtxt dis" name=@Html.ViewData["SrcVal"].ToString() />
                            <button id="btnsubmit" class="btntolink searchbtn dis"><i class="fa fa-search"></i></button>
                            <input type="hidden" name="Deleted" value="@deleted" />
                            &nbsp;
                            <input type="checkbox" id="cbCheckDeleted" name="cbCheckDeleted" onclick="CheckDeleted()"> Show Deleted Records
                        </div>
                        <div class="topright">


                        </div>

                        <div style="float:right;">
                            @*<input class="fa fa-search-plus fa-2x greyiconcolor" onclick="advanceSearchClick()" data-toggle="modal" data-target="#exampleModal1" type="button" />*@
                            @*<a href="#" onclick="advanceSearchClick()" data-toggle="modal" data-target="#exampleModal1" class="fa fa-search-plus fa-2x greyiconcolor"></a>&nbsp; &nbsp;*@
                            @*<a href="#" onclick="advanceSearchClick()" data-toggle="modal" data-target="#exampleModal1" class="fa-light fa-filter fa-2x greyiconcolor"></a>&nbsp; &nbsp;*@
                            <a href="#" onclick="advanceSearchClick()" data-toggle="modal" data-target="#exampleModal1" class="fa fa-filter fa-2x greyiconcolor" data-title="Advance Search"></a>&nbsp; &nbsp;  @*maryam - 14032023*@

                            @if (act != "")
                            {
                                @Html.ActionLink(" ", "AddNew", "Mstmain",
                            new { act = this.ViewData["Act"], ctrl = this.ViewData["Ctrl"] },
                            new { @class = "fa fa-plus-square fa-2x greyiconcolor", @onclick = "loadings();" })
                            }
                        </div>
                        <div class="modal fade" id="exampleModal1" tabindex="-1" role="dialog" data-backdrop="false" style="background-color: rgba(0, 0, 0, 0.5);">
                            <div class="modal-dialog" role="document">
                                <div id="advanceSearchDiv"></div>
                            </div>
                        </div>
                        <script>
                        function advanceSearchClick() {
                                //debugger
                                //alert("test");
                                $("#advanceSearchDiv").load('@(Url.Content("/Home/AdvancedSearch") + "?actionRequested=" + ViewContext.RouteData.Values["action"].ToString() + "/" + ViewContext.RouteData.Values["controller"].ToString())');
                        }

                        function CheckDeleted() {
                            //debugger;
                            var chboxs = document.getElementById("cbCheckDeleted");
                            var deleted = "0";

                            if (chboxs.checked == true) {
                                deleted = "1";
                            }

                            var url = '@Url.Action(ViewContext.RouteData.Values["action"].ToString(), ViewContext.RouteData.Values["controller"].ToString()).ToString()' + '?Deleted=' + deleted;

                            window.location.href = url;
                        }

                        </script>

                    </div>

                </fieldset>

            </div>
        }
    }

}

<script type="text/javascript">
    var links = $('a[href*=page], a[href*=sort]'), form = $('form');
    links.click(function () {
        form.attr("action", this.href);
        $(this).attr("href", "#");
        form.submit();
    });

</script>


