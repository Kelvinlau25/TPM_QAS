@{
    var postto = this.ViewData["SrcAct"].ToString();
    var act = this.ViewData["Act"].ToString();
    var ctrlto = this.ViewData["Ctrl"].ToString();
    var deleted = "0";
    var num = Model.Count;
    if (Request.QueryString["Deleted"] != null)
    {
        deleted = Request.QueryString["Deleted"].ToString();
    }
    var ViewAutoGen = this.ViewData["AutoGenView"].ToString();
}

