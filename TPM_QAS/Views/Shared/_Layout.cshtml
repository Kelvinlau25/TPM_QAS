                            }
                            else
                            {
                                <a id="btnProfile" href="#" class="m-0 px-1 text-reset tr-navbar-logout">
                                    <i class="fa-solid fa-user px-2"></i>Anonymous
                                </a>
                            }
                        </div>
                        <div class="tr-nav-divider"></div>
                        <div>
                            <a id="btnLogout" href="#" class="px-1 text-reset tr-navbar-logout"><i class="fa-solid fa-right-from-bracket px-2"></i>&nbsp;LOGOUT</a>
