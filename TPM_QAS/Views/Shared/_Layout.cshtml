        //NISA-20230907- ALLOW ONLY NUMERIC INPUT ONLY + NEGATIVE
        function isNumberKey(evt) {
            var charCode = (evt.which) ? evt.which : evt.keyCode;

            if (charCode === 45) {
                if (evt.target.selectionStart !== 0 || evt.target.value.includes("-")) {
