            $('#btnCancelView').text("Cancel");
            $('#btnDeleteView').hide();
            $('#btnSubmit').show();
            $('#btnEdit').hide();
            $('.title').html("Edit Form");
            $('.tr-is-invalid').addClass('is-invalid');
            $('a.tr-disabled').css("pointer-events", "auto");
            $('.tr-input-group').removeClass("tr-disabled");
            //$('.hideInfo').css("display", "none");
            $('.isEditable').removeClass("viewmode");

            $('#adddescBtn').show();
            var isManager = '@ViewBag.isManager';
            if (isManager  == "Y")
            {
                $('.lotnofield').removeAttr("disabled");
            }

        });

        // BUTTON RESET MODAL
        $('#btnResetModal').on('click', function () {

            $("#txt_modal_1").val("");
            $("#txt_modal_2").val("");
            $("#txt_modal_3").val("");
            $("#txt_modal_4").val("");
            $("#txt_modal_5").val("");
            $("#txt_modal_6").val("");
            $("#txt_modal_7").val("");
            $("#txt_modal_8").val("");
            $("#txt_modal_9").val("");
            $("#txt_modal_10").val("");
            $("#txt_modal_11").val("");
            $("#txt_modal_12").val("");

        });

        // REQUIRED FIELD MESSAGE
        function inputError(inputElement) {
            $(inputElement).addClass('is-invalid');
            var errorDiv = $('<div>').addClass('text-danger invalid-feedback');
            errorDiv.text("Field cannot be empty.");
            $(inputElement).after(errorDiv);
        }

        // REQUIRED FIELD MESSAGE
        function inputCustomError(inputElement, errmsg) {
            $(inputElement).addClass('is-invalid');
            var errorDiv = $('<div>').addClass('text-danger invalid-feedback');
            errorDiv.text(errmsg);
            $(inputElement).after(errorDiv);
        }

        function addTableButtons() {
            const moduleName = $('.export-section').data('modulename') || 'TPM QAS Datalink Phase 3';
            new $.fn.dataTable.Buttons(table, {
                name: "export",
                buttons: [
                    {
                        text: 'Export to Excel',
                        extend: 'excelHtml5',
                        filename: moduleName + '_' + new Date().toISOString().slice(0, 10),
                        className: 'btn-sm btn-primary tr-btn-primary',
                        init: function (api, node, config) {
                            $(node).removeClass('btn-secondary')
                        },
                        customize: function (xlsx) {
                            var sheet = xlsx.xl.worksheets['sheet1.xml'];

                            $('row c[r^="D3"]', sheet).each(function () {
                                $(this).css('s', '0');
                            });

                        },
                        exportOptions: {
                            columns: ':not(:first-child):not(:last-child)'
                        }
                    }
                ]
            });

            table.buttons("export", null).containers().appendTo('.export-section');
        }

</script>



    @{
        if (ViewBag.Result != "" && ViewBag.Result != null)
        {
            <script type="text/javascript" language="javascript">
            alert("@ViewBag.Result");
            </script>
        }

        if (ViewBag.Error != "" && ViewBag.Error != null)
        {
            <script type="text/javascript" language="javascript">
            alert("@ViewBag.Error");
            </script>
        }
    }
</body>
</html>
