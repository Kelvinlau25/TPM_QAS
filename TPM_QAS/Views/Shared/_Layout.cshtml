    function viewBlobFile(filename, path) {

        if (path != null && path != '') {
            var contentType = "application/pdf"; // Default content type for unsupported file types
            var fileExtension = filename.split('.').pop().toLowerCase();

            if (fileExtension === "jpg" || fileExtension === "jpeg" || fileExtension === "png") {
                contentType = "image/jpeg"; // Adjust content type for image formats
            } else if (fileExtension === "pdf") {
                contentType = "application/pdf"; // Content type for PDF files
            } else {
                // Unsupported file type
                alert("Unsupported file type.");
                return;
            }


            var newWindow = window.open('', '_blank', 'width=800,height=800');
            if (fileExtension === "pdf") {
                newWindow.document.write('<embed src="' + path + '" type="application/pdf" width="100%" height="100%" />');
            } else {
                newWindow.document.write('<img src="' + path + '" style="max-width: 100%; max-height: 100%;" />');
            }
        } else {
            alert("File not found or cannot be accessed.");
        }
    }

