        //Input control - JH230613
        $(document).on('input', '.numericInput', function () {
            var inputElement = $(this)[0]; // Get the raw DOM element
            var inputValue = inputElement.value;
            var cursorPositionStart = inputElement.selectionStart;
            var cursorPositionEnd = inputElement.selectionEnd;
            // Remove any non-digit or non-decimal characters
            inputValue = inputValue.replace(/(?!^-)[^0-9.]/g, '');
            // Remove leading zeros, except for zero before the decimal point
            inputValue = inputValue.replace(/^0+(?=\d)(?!$)/, '');
            // Add trailing zeros if the input does not contain a decimal point
            if (!inputValue.includes('.')) {
                inputValue += '.000';
            } else {
                // Pad the decimal part with zeros to ensure three decimal places
                var decimalIndex = inputValue.indexOf('.');
                var decimalPart = inputValue.substring(decimalIndex + 1);
                if (decimalPart.length === 0) {
                    inputValue += '000';
                } else if (decimalPart.length === 1) {
                    inputValue += '00';
                } else if (decimalPart.length === 2) {
                    inputValue += '0';
                }
            }
            // Limit to a maximum of 3 decimal places while typing
            var decimalIndex = inputValue.indexOf('.');
            if (decimalIndex !== -1) {
                var decimalPart = inputValue.substring(decimalIndex + 1);
                if (decimalPart.length > 3) {
                    inputValue = inputValue.slice(0, decimalIndex + 4);
                }
            }
            // Update the input value
            inputElement.value = inputValue;
            // Restore the cursor position
            inputElement.selectionStart = cursorPositionStart;
            inputElement.selectionEnd = cursorPositionEnd;
        });

