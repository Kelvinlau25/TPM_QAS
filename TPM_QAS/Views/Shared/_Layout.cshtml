                    <img class="p-0 tr-navbar-logo" src="~/Images/Toray Logo.png" />
                </a>
                <div class="tr-nav-divider"></div>
                <div id="accountMenu" class="d-md-none collapse">
                    <div class="row mb-2">
                        <p class="h4 text-secondary m-0 px-4">@TPM_QAS.DAL.Database.GetAppSettingStatic("SystemName")</p>
                    </div>
                    <div class="row mb-2">
                        @if (Context.Session.GetString("AclUser") != null)
                        {
                            <p class="h6 text-secondary m-0 px-4"><i class="fa-solid fa-user px-2"></i>@(Context.Session.GetObject<ACL_UserObj>("AclUser")?.EMP_NAME)</p>
                        }
                        else
                        {
                            <p class="h6 text-secondary m-0 px-4"><i class="fa-solid fa-user px-2"></i>Anonymous</p>
                        }
                    </div>
                    <div class="row mb-2">
                        <a href="#" class="text-reset" style="color:#fff !important"><i class="fa-solid fa-right-from-bracket px-2"></i>LOGOUT</a>
                    </div>
                </div>
            </div>
            <div class="me-auto d-none d-md-block">
                <p class="m-0 px-4 tr-navbar-title">@TPM_QAS.DAL.Database.GetAppSettingStatic("SystemName")</p>
            </div>
            <div class="navbar-nav d-none d-md-block">
                <div class="nav-item text-nowrap">
                    <form class="d-flex align-items-center">
                        <div class="mx-2 text-uppercase">
                            @if (Context.Session.GetString("AclUser") != null)
                            {
                                <a id="btnProfile" href="#" class="m-0 px-1 text-reset tr-navbar-logout">
