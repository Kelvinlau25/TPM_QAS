            max-width: 300px;
        }

        .popup-container {
            position: relative;
            display: inline-block;
        }

        .form-switch {
            padding-right: 20px;
        }

        .sort-handle:hover {
            cursor: grab;
        }

        .day-box {
            padding: 10px 10px 10px 10px;
        }

        .highlight {
            border: 2px solid blue;
        }

        /* Style for the popup button */
        .popup-button {
            background-color: dodgerblue;
            border: none;
            cursor: pointer;
        }

            .popup-button a {
                color: #fff;
                text-decoration: none;
                display: block;
            }

        /* Style for the popup content */
        .popup-content {
            display: none;
            position: absolute;
            background-color: #fff;
            border: 1px solid dodgerblue;
            padding: 10px;
            z-index: 1;
        }

        /* Show the popup content when the button is clicked */
        .popup-button:hover + .popup-content {
            display: block;
        }

        /**JH230712 - Custom**/

        .isHide {
            display: none;
        }

        .hidden {
            display: none;
        }

        .tr-input-group {
            background-color: #057EE6;
            border-color: #057EE6;
        }

        .multiselect-container.dropdown-menu {
            max-height: 400px;
            overflow: auto;
        }

        .table-control {
            width: 100%;
            overflow: auto;
        }

        .sticky-header {
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .arrowinv {
            width: 3% !important;
        }

        .radioh {
            padding-top: 20px;
        }

        .disabled-div {
            background-color: #ccc !important;
            cursor: not-allowed;
            pointer-events: none;
        }

        .varinput {
            height: 40px;
            width: 40px;
            text-align: center;
            line-height: 1;
            margin-right: 10px;
            margin-bottom: 10px;
            border: 1px solid #ced4da;
        }

        .varerase {
            height: 40px;
            width: 100px;
            text-align: center;
            line-height: 1;
            margin: 10px 10px;
            border: 1px solid #ced4da;
        }

        .varian {
            height: 40px;
            width: 65px;
            text-align: center;
            line-height: 1;
            margin-right: 10px;
            margin-bottom: 10px;
            border: 1px solid #ced4da;
        }


        .modalform {
            height: 40px; /* Match the height of varinput buttons */
        }

        a.tr-disabled {
            pointer-events: none;
        }

        .status-select {
            border: 0px;
        }

        .tr-text {
            text-align: end;
        }

        .toolbar {
            float: right;
        }

        .toolbar-pop {
            float: left;
        }

        .tr-pop-line {
            border-top: 1px solid #F0F0F0;
            margin: 0px;
        }

        .tr-input-group {
            background-color: #057EE6;
            border-color: #057EE6;
        }

            .tr-input-group.tr-disabled {
                background-color: #54575A;
                border-color: #54575A;
            }

        @@keyframes shake-anim {
            0% {
                transform: rotate(-35deg);
            }

            25% {
                transform: rotate(25deg);
            }

            50% {
                transform: rotate(-15deg);
            }

            75% {
                transform: rotate(10deg);
            }

            100% {
                transform: rotate(0deg);
            }
        }

        /**Overwrite site.css**/
        .detail-frame {
            overflow: hidden;
        }

        /*select.form-control {
            -webkit-appearance: menulist !important;
            -moz-appearance: menulist !important;
        }*/
        body {
            overflow: hidden;
        }


        .toasts {
            position: absolute;
            bottom: 0;
            right: 0;
            z-index: 999;
        }

        #sidebar, #sidebar-nav {
            width: 300px !important;
        }

        #sidebar-nav {
            position: fixed;
            overflow-y: auto;
            height: calc(100vh - 55px - 42px - 42px - 25px - 19px) !important;
        }

        .inc-tooltips {
            width: fit-content;
        }

        .inc-tooltip {
            position: absolute;
            background-color: #fff;
            color: rgba(0,0,0,0.9);
            padding: 5px;
            border: 1px solid #000;
            border-radius: 3px;
            z-index: 10;
            white-space: nowrap;
        }

        .inc-tooltip-table {
            border-collapse: collapse;
        }

            .inc-tooltip-table td {
                font-size: 14px;
                padding: 2px 5px;
            }

        #chgpassword_btn {
            color: inherit !important;
            font-weight: bold;
            position: fixed;
            bottom: 68px;
            margin-top: auto;
            width: 330px;
            padding: 10px;
            text-decoration: none;
        }

            #chgpassword_btn:hover {
                color: dodgerblue !important;
                cursor: pointer;
            }

        @@media only screen and (min-device-width: 1280px) and (max-device-width: 1599px) {
            /*laptop*/
            .select2.select2-container .select2-selection {
                height: 28px;
                padding-bottom: 29px;
            }

            .select2-selection__rendered {
                color: #54575A !important;
                font: 14px Roboto, sans-serif;
            }

            .select2.select2-container .select2-selection .select2-selection__arrow {
                padding: 1.9rem 1.5rem 0.5rem 1rem;
            }

            .modal-header {
                margin-bottom: -15px;
                margin-top: -10px;
            }

            .custom-toolbar {
                margin-right: 2px;
            }

            .modal-xl-ocr {
                --bs-modal-width: 1220px;
            }

            .content-center-p {
                padding-left: 90px !important;
                padding-top: 5px !important;
            }

            #chgpassword_btn {
                width: 200px;
            }

            #sidebar, #sidebar-nav {
                width: 220px !important;
            }

            #sidebar-nav {
                height: calc(100vh - 55px - 42px - 42px - 25px) !important;
            }
            /*.tr-text {
                text-align: start;
            }*/
            .tr-pop-line {
                border-top: 1px solid #F0F0F0;
                margin: 10px 0px;
            }
        }

        @@media (min-width: 1599px) {
            /*monitor*/
            

            .height-override {
                height: calc(100vh - 58px - 70px - 75px - 25px) !important;
            }

            .tr-btm-size {
                padding-top: 2px !important;
            }

            .modal-header {
                margin-bottom: -25px;
                margin-top: -10px;
            }

            .custom-toolbar-add-margin {
                margin-right: 2px;
            }

            .content-center-p {
            }

            .modal-lg, .modal-xl {
                --bs-modal-width: 1024px;
            }

            .modal-seq {
                --bs-modal-width: 700px;
            }

            .modal-xl-ocr {
                --bs-modal-width: 1524px;
            }

            .select2.select2-container .select2-selection {
                height: 40px;
                padding-top: 3px;
            }

                .select2.select2-container .select2-selection .select2-selection__arrow {
                    padding: 1.9rem 1.5rem 0.5rem 1rem;
                }
        }

        @@media (max-width: 576px) {
            .tr-text {
                text-align: start;
            }
        }

        .nav-tabs {
            --bs-nav-tabs-border-width: 0px;
        }

        .tr-tab .nav-link {
            min-width: 250px;
            text-align: left;
            background-color: #F0F0F0 !important;
            border-top-left-radius: 15px;
            border-top-right-radius: 15px;
        }

            .tr-tab .nav-link:not(:first-child) {
                margin-left: 5px;
            }

        .nav-tabs .nav-link.active, .nav-tabs .nav-item.show .nav-link {
            box-shadow: inset 0 0px 0 transparent !important;
        }

        .tr-tab .nav-link.active {
            color: #54575A !important;
            background-color: #EBF3FF !important;
            font-weight: bold;
            border-top-left-radius: 15px;
            border-top-right-radius: 15px;
        }

        .nav-tabs .nav-link {
            padding-top: 10px !important;
            padding-bottom: 10px !important;
            border-width: 0px !important;
        }

        .label-input-group {
            background-color: inherit !important;
            border-color: #ced4da !important;
        }

        .btn-info {
            color: #ffffff !important;
            background-color: #3459e6;
            border-color: #46b8da;
        }

        .select2.select2-container {
            width: 100% !important;
        }

            .select2.select2-container .select2-selection {
                border: 1px solid #ccc;
                -webkit-border-radius: 3px;
                -moz-border-radius: 3px;
                border-radius: 0.375rem;
              /*  height: 40px;*/
                outline: none !important;
                transition: all .15s ease-in-out;
            }

                .select2.select2-container .select2-selection .select2-selection__rendered {
                    color: #333;
                    line-height: 32px;
                    padding-right: 33px;
                }


            .select2.select2-container.select2-container--open .select2-selection.select2-selection--single {
                /*background: #f8f8f8;*/
            }

                .select2.select2-container.select2-container--open .select2-selection.select2-selection--single .select2-selection__arrow {
                    -webkit-border-radius: 0 3px 0 0;
                    -moz-border-radius: 0 3px 0 0;
                    border-radius: 0 3px 0 0;
                }

            .select2.select2-container.select2-container--open .select2-selection.select2-selection--multiple {
                border: 1px solid #34495e;
            }

            .select2.select2-container .select2-selection--multiple {
                height: auto;
                min-height: 34px;
            }

                .select2.select2-container .select2-selection--multiple .select2-search--inline .select2-search__field {
                    margin-top: 0;
                    height: 32px;
                }

                .select2.select2-container .select2-selection--multiple .select2-selection__rendered {
                    display: block;
                    padding: 0 4px;
                    line-height: 29px;
                }

                .select2.select2-container .select2-selection--multiple .select2-selection__choice {
                    background-color: #f8f8f8;
                    border: 1px solid #ccc;
                    -webkit-border-radius: 3px;
                    -moz-border-radius: 3px;
                    border-radius: 3px;
                    margin: 4px 4px 0 0;
                    padding: 0 6px 0 22px;
                    height: 24px;
                    line-height: 24px;
                    font-size: 12px;
                    position: relative;
                }

                    .select2.select2-container .select2-selection--multiple .select2-selection__choice .select2-selection__choice__remove {
                        position: absolute;
                        top: 0;
                        left: 0;
                        height: 22px;
                        width: 22px;
                        margin: 0;
                        text-align: center;
                        color: #e74c3c;
                        font-weight: bold;
                        font-size: 16px;
                    }

        .select2-container .select2-dropdown {
            background: transparent;
            border: none;
        }

        .select2-results__option {
            padding: 0px 10px;
            user-select: none;
            -webkit-user-select: none;
        }

        .select2-container .select2-dropdown .select2-search {
            padding: 0;
        }

            .select2-container .select2-dropdown .select2-search input {
                outline: none !important;
                border-bottom: none !important;
            }

        .select2-container .select2-dropdown .select2-results {
            padding: 0;
        }

            .select2-container .select2-dropdown .select2-results ul {
                background: #fff;
                border: 1px solid #ced4da;
            }

                .select2-container .select2-dropdown .select2-results ul .select2-results__option--highlighted[aria-selected] {
                    background-color: #3498db;
                }

    </style>
</head>

<body class="theme-cyan">
    <script>var appBasePath = '@Url.Content("~/")';</script>
    <div class="tr-tooltips-container"></div>
    <div class="sticky-top">
        <header class="navbar navbar-dark sticky-top flex-md-nowrap p-0 shadow tr-navbar">
            <div class="row row-cols-auto align-items-center">
