@using TPM_QAS.Models
@model CheckPlanModel


@{
    ViewBag.Title = "CHECKING PLAN MM - Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-0 px-3 tr-listing-header">
    <div class="col-sm-6 align-self-center">
        <p class="text-muted m-0 tr-listing-header-title main-title">View Form - Checking Plan</p>
    </div>
    <div class="col-sm-6 text-end align-self-center">
        <div class="d-flex justify-content-end">
            <div id="customDTButton"></div>
        </div>
    </div>
</div>

<div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

<div class="page-container px-3 overflow-auto">
    <div class="tr-btm-btn-margin">
        <div class="card mt-3 mb-2 card-height">
            <div class="card-body">
                <div class="row align-items-baseline">
                    <div class="col"><h6 class="card-title text-muted">Checking Plan</h6></div>
                    @if (Model.RECORD_TYP != null)
                    {
                        if (@Model.RECORD_TYP != "5")
                        {
                            <div class="col text-end"><button class="btn btn-sm btn-primary" id="btnEdit" type="button" data-behaviour="toggle">Edit</button></div>
                        }

                    }
                </div>

                <hr />

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Product Group <span class="text-danger">*</span><span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        @Html.DropDownListFor(Model => Model.MM_PRODGROUP_H_ID, Model.DropdownProdGroup, "Select an option..", new { id = "ddlProdGroup", @class = "ddloption isEditable form-control form-select", required = "required", disabled = "disabled" })
                    </div>
                </div>

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Company Group <span class="text-danger">*</span><span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-check form-check-inline">
                            <input class="isEditable form-check-input" type="radio" name="compgroup" id="compounderRadio" onchange = handleRadioChange() value="COMPOUNDER"
                                   @(Model.COMP_GROUP != null && Model.COMP_GROUP.ToString() == "COMPOUNDER" ? "checked" : "") disabled>
                            <label class="form-check-label" for="compounderRadio">Compounder</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="isEditable form-check-input" type="radio" name="compgroup" id="tpmRadio" onchange = handleRadioChange() value="TPM"
                                   @(Model.COMP_GROUP != null && Model.COMP_GROUP.ToString() == "TPM" ? "checked" : "") disabled>
                            <label class="form-check-label" for="tpmRadio">TPM</label>
                        </div>

                    </div>
                </div>

                <div class="row align-items-baseline">
                    <div class="col-sm-2">
                        <p class="text-muted">Pattern Type <span class="text-danger">*</span><span style="float:right">:</span></p>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-check form-check-inline">
                            <input class="isEditable form-check-input" type="radio" name="pattern" id="patternfull" value="F"
                                   @(Model.PATTERN_TYPE != null && Model.PATTERN_TYPE.ToString() == "F" ? "checked" : "") disabled>
                            <label class="form-check-label" for="compounderRadio">Full</label>
                        </div>
                        <div class="form-check form-check-inline tpmpattern" style="display:none">
                            <input class="isEditable form-check-input" type="radio" name="pattern" id="patternpartial" value="P"
                                   @(Model.PATTERN_TYPE != null && Model.PATTERN_TYPE.ToString() == "P" ? "checked" : "") disabled>
                            <label class="form-check-label" for="tpmRadio">Partial</label>
                        </div>
                        <div class="form-check form-check-inline tpmpattern" style="display:none">
                            <input class="isEditable form-check-input" type="radio" name="pattern" id="patternc" value="C"
                                   @(Model.PATTERN_TYPE != null && Model.PATTERN_TYPE.ToString() == "C" ? "checked" : "") disabled>
                            <label class="form-check-label" for="tpmRadio">C</label>
                        </div>

                    </div>
                </div>

                <div class="row row-cols-2 mt-4">
                    <div class="col-2 align-self-center">
                        <h6 class="text-muted" style="float: left">Properties Listing</h6>
                    </div>
                    <div class="col-3">
                        <div class="input-group">
                            <div class="input-group-text tr-input-group tr-disabled" id="searchProperty" onclick="popupPropertyDetail()">
                                <a href="#" class="text-reset vm isEditable" disabled><i class="fa-solid fa-ellipsis" aria-hidden="true" style="color: #fff"></i></a>
                            </div>
                        </div>
                    </div>
                    <div class="d-none isEditable col-7">
                        <div class="row row-cols-auto justify-content-end g-1">
                            <div class="col">
                                <button class="btn btn-sm btn-md btn-danger" id="removeBtn" type="button">
                                    Remove
                                </button>
                            </div>
                            <div class="col">
                                <button class="btn btn-sm btn-md btn-primary" id="addBtn" onclick="popupPropertyDetail()" type="button">
                                    Add
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-2 mx-1">
                    <table id="item-table" class="detailTable" style="width:100%">
                        <thead>
                            <tr class="toolbar-row">
                                <th class="d-none isEditable" style="width: 3%; text-align: center;">
                                    <input id="trCheckbox" type="checkbox" class=" dt-checkboxes select-all form-check-input" style="margin-top:5.5px;">
                                </th>
                                <th>Properties</th>
                                <th>Property Items</th>
                            </tr>
                        </thead>
                        <tbody id="tbody">
                            @{ var count = 0; }
                            @if (Model.CheckPlanPropLstModel != null && Model.CheckPlanPropLstModel.Count > 0)
                            {
                                foreach (var item in Model.CheckPlanPropLstModel)
                                {
                                    count++;
                                    <tr id="R_@count" data-did="@count">
                                        <td class="d-none isEditable text-center">
                                            <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_@count" onClick="handleCheckboxClick(this)">
                                        </td>
                                        <td>
                                            <input type="text" class="isItemDisabled form-control" id="item_prop_@count" value="@item.PROPERTIES" placeholder="" style="border:none; box-shadow: none;" readonly>
                                        </td>
                                        <td>
                                            <input type="text" class="isItemDisabled form-control" id="item_propitem_@count" value="@item.PROP_ITEM" placeholder="" style="border:none; box-shadow: none;" readonly>
                                        </td>
                                        <td class="d-none">
                                            <input type="text" class="form-control" id="item_stat_@count" value="0">
                                            <input type="text" class="form-control" id="item_dbid_@count" value="@item.MM_CHECKPLAN_D_ID">
                                            <input type="text" class="form-control" id="item_propid_@count" value="@item.MM_PROPERTIES_H_ID">
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <input type="hidden" id="item-count" value="@count" />
                </div>

                <div class="hideInfo">
                    <hr />

                    <div class="row row-cols-2 mt-4">
                        <div class="col align-self-center">
                            <h6 style="float: left" class="text-muted">Entry Details</h6>
                        </div>
                        <div class="col">

                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_BY">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created By<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_BY">
                        </div>
                    </div>

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Updated Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.UPDATED_DATE">
                        </div>
                        <div class="col-sm-2">
                            <p class="text-muted">Created Date<span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <input class="form-control" type="text" disabled value="@Model.CREATED_DATE">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row tr-btm-btn-area">
            @if (Model.RECORD_TYP != null)
            {
                if (@Model.RECORD_TYP != "5")
                {
                    <div class="col"><button id="btnDeleteView" type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#delete-confirmation-modal">Delete</button></div>
                }

            }
            <div class="col">
                <div class="row row-cols-auto justify-content-end isNotEditable" style="padding-right: 20px">
                    <div class="col"><button id="btnCancelView" type="button" class="btn btn-sm btn-secondary">Back</button></div>
                </div>

                <div class="row row-cols-auto justify-content-end isEditable g-1" style="display:none; padding-right: 20px">
                    <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary" data-bs-toggle="modal" data-bs-target="#edit-back-confirmation-modal">Back</button></div>
                    <div class="col"><button id="btnSubmit" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal">Submit</button></div>
                </div>
            </div>
        </div>

    </div>
</div>



@section scripts {
    <script>
    var idh = '@Model.MM_CHECKPLAN_H_ID';

    $(document).ready(function () {

        handleRadioChange()

        checkboxChecking();

        var listingURL = '/MM_CHECK_PLAN/MM_CHECK_PLAN_LST';

        //REMOVE D
        $('#removeBtn').on('click', function () {
            $('#item-table tbody input[type=checkbox]:checked').each(function (idx, ele) {
                var row = $(ele).closest('tr');
                var itemStatInput = row.find('input[id^="item_stat_"]');
                var item_stat = itemStatInput.val();

                if (item_stat != '1') {
                    itemStatInput.val('5');
                    row.hide();
                } else {
                    row.remove();
                }
            });

            checkboxChecking();
        });

        //SUBMIT
        $('#btnConfirmSubmit').on('click', function () {
            $('.invalid-feedback').remove();
            $('.is-invalid').removeClass('is-invalid');

            var cont = true;
            var message = "";

            var ddlProdGroup = $("#ddlProdGroup").val();
            var prodgroup = $('#ddlProdGroup option:selected').text();
            var pattern = $("input[name='pattern']:checked").val();
            var comp_group = $("input[name='compgroup']:checked").val();

            if (ddlProdGroup == undefined || ddlProdGroup == null || ddlProdGroup == 0 || ddlProdGroup == "" || ddlProdGroup == "Select an option..") {
                cont = false;
                message += 'Please select Product Group. <br>';
            }

            if (pattern == undefined || pattern == null || pattern == "") {
                cont = false;
                message += 'Please select Pattern Type. <br>';
            }

            if (comp_group == undefined || comp_group == null || comp_group == "") {
                cont = false;
                message += 'Please select Company Group. <br>';
            }

            $('.required-field').each(function (e) {
                var input_val = $(this).val().trim();
                if (input_val == null || input_val == undefined || input_val === "") {
                    cont = false;
                    $(this).addClass('is-invalid');
                    inputError(this);
                }
            });

            var hasItem = false;
            var hasError = false;
            var hasDuplicate = false;
            var existedItem = [];

            var propertylist = [];

            $("#item-table tbody tr").each(function () {
                var did = $(this).data("did");
                if (did != '' && did != null && did != undefined) {
                    var item_stat = $('#item_stat_' + did).val();
                    var item_dbid = $('#item_dbid_' + did).val();

                    var item_prop = $('#item_prop_' + did).val();
                    var item_propitem = $('#item_propitem_' + did).val();
                    var item_propid = $('#item_propid_' + did).val();

                    if (item_stat != '5') {
                        if (item_propid !== "" && item_propid != '0') {
                            hasItem = true;
                            if (existedItem.includes(item_propid)) {
                                hasDuplicate = true;
                                return false;
                            } else {
                                existedItem.push(item_propid);
                            }
                        } else {
                            hasError = true;
                        }
                    }

                    propertylist.push({
                        'MM_CHECKPLAN_D_ID': item_dbid,
                        'RECORD_TYP': item_stat,

                        'PROPERTIES': item_prop,
                        'PROP_ITEM': item_propitem,
                        'MM_PROPERTIES_H_ID': item_propid
                    });
                }
            });

            if (cont && !hasItem) {
                cont = false;
                message = "Please add at least one Properties Listing.";
            }
            if (cont && hasError) {
                cont = false;
                message = "Please make sure Property field in Properties Listing is not empty.";
            }
            if (cont && hasDuplicate) {
                cont = false;
                message = "Duplicate properties and property items selected.";
            }

            if (comp_group == "COMPOUNDER") {
                pattern = "F";
            }

            if (cont) {

                var model = {

                    MM_CHECKPLAN_H_ID: idh,
                    RECORD_TYP: '3',

                    MM_PRODGROUP_H_ID: ddlProdGroup,
                    PROD_GROUP: prodgroup,
                    PATTERN_TYPE: pattern,
                    COMP_GROUP: comp_group,
                    CheckPlanPropLstModel: propertylist
                };

                console.log(model)

                $.ajax({
                    url: "/MM_CHECK_PLAN/InsertUpdateCheckPlan",
                    type: 'POST',
                    data: {
                        model: model
                    },
                    beforeSend: function () {
                        loadings();
                    },
                    success: function (response) {
                        loadings(false);
                        if (response.success) {
                            displayToast("s", "Data save successfully");

                            setTimeout(function () {
                                window.location.href = listingURL;
                            }, 2000);

                        } else {
                            displayToast("error", response.message)
                        }
                    },
                    error: function () {
                        displayToast("error", response.responseText)
                    }
                });

            } else {
                if (message != "") {
                    displayToast("error", message)
                }
            }

        });

        // BUTTON DELETE
        $('#btnConfirmDel').on('click', function () {

            var lstid = [];
            lstid.push(idh)

            $.ajax({
                url: "/MM_CHECK_PLAN/deleteCheckPlan",
                type: 'POST',
                data: {
                    lstid: lstid
                },
                beforeSend: function () {
                    loadings();
                },
                success: function (response) {
                    loadings(false);
                    if (response.success) {
                        displayToast("s", "Data successfully deleted");

                        setTimeout(function () {
                            window.location.href = listingURL;
                        }, 2000);

                    } else {
                        displayToast("error", response.message)
                    }
                },
                error: function () {
                    displayToast("error", response.responseText)
                }
            });

        });

        //BUTTON CANCEL/BACK
        $('#btnCancelView').on('click', function () {
                var del = '0';
                if (@Model.RECORD_TYP != null && @Model.RECORD_TYP  == '5') {
                    del = '1';
                }
                window.location.href = listingURL + '?Deleted=' + del;
        });

        $('#btnBackEdit').on('click', function () {
            window.location.href = listingURL;
        });
    });

        function handleRadioChange() {

            var external = $('#compounderRadio').is(':checked');
            var tpm = $('#tpmRadio').is(':checked');
            var comp = "";

            if (external) {
                comp = "COMPOUNDER"
            } else {
                if (tpm) {
                    comp = "TPM"
                }
            }

            if (comp === 'TPM') {
                $('.tpmpattern').show();
            } else {
                $('.tpmpattern').hide();
            }
        }
    //ADD PROPERTIES LIST
    function addPropertiesList(data) {
        var cont = true;
        var message = "";

        var hasDuplicate = false;
        for (var i = 0; i < data.length; i++) {

            var rowIdx = $('#item-count').val();

            if (rowIdx != '0') {
                $("#item-table tbody tr").each(function () {
                    var propid = data[i].MM_PROPERTIES_H_ID;

                    var did = $(this).data('did');
                    if (did != '' && did != null && did != undefined) {
                        var item_stat = $('#item_stat_' + did).val();
                        var item_propid = $('#item_propid_' + did).val();

                        if (data[i].INSERT != 'N') {
                            if (item_stat != '5' && item_propid == propid) {
                                hasDuplicate = true;
                                data[i].INSERT = 'N';
                            } else {
                                data[i].INSERT = 'Y';
                            }
                        }

                    }
                });
            } else {
                data[i].INSERT = 'Y';
            }


        }

        //if (cont && hasDuplicate) {
        //    cont = false;
        //    message = "Duplicate property and property items selected.";
        //}

        if (cont) {
            var rowIdx = $('#item-count').val();

            for (var i = 0; i < data.length; i++) {

                if (data[i].INSERT == 'Y') {
                    rowIdx++;
                    $('#item-count').val(rowIdx);

                    $("#item-table tbody").append(`
                    <tr id="R_${rowIdx}" data-did="${rowIdx}">
                        <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClick(this)"></td>
                        <td><input type="text" class="form-control" value="${data[i].PROPERTIES}"  id="item_prop_${rowIdx}" placeholder="" disabled></td>
                        <td><input type="text" class="form-control" value="${data[i].PROP_ITEM}"  id="item_propitem_${rowIdx}" placeholder="" disabled></td>
                        <td class="d-none">
                            <input type="text" id="item_stat_${rowIdx}" value="1">
                            <input type="text" id="item_dbid_${rowIdx}" value="0">
                            <input type="text" id="item_propid_${rowIdx}" value="${data[i].MM_PROPERTIES_H_ID}">
                        </td>
                    </tr>`);

                    checkboxChecking();
                }
            }

        } else {
            if (message != "") {
                displayToast("error", message)
            }
        }
    }

    //POPUP
    function popupPropertyDetail() {
        var isDisabled = $('#searchProperty').hasClass('tr-disabled');

        if (!isDisabled) {
            var id = idh;
            var popup;
            var url = '@Url.Action("MM_CHECK_PLAN_PROPERTY_POPOUT", "MM_CHECK_PLAN")';

            url = url + '?id=' + id;
            popup = window.open(url, "Popup", "directories=no,titlebar=no,toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=no,width=800,height=800");
            popup.focus();
        }
    }
    </script>
}

