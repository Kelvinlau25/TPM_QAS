                        <h6 class="card-title text-muted pt-2"></h6>
                        <div style="display:none">
                            ProdGroup : @Html.TextBoxFor(m => m.ModelObj.prodgroup, new { @class = "form-control", @id = "txtProdGroup", @style = "height: 30px; " })
                            ProdLine : @Html.TextBoxFor(m => m.ModelObj.prodline, new { @class = "form-control", @id = "txtProdLine", @style = "height: 30px; " })
                        </div>
                        <div class="row align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.PRODTYPE) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.PRODTYPE, null, new { @id = "txtProdType", @class = "form-control", @disabled = "disabled" })
                            </div>
                            <div class="col-sm-1">
                            </div>

                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.PACKEDDATE) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.PACKEDDATE, null, new { @id = "txtInspecDate", @class = "form-control", @disabled = "disabled" })
                            </div>
                        </div>
                        <br />
                        <div class="row align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.LOTNO) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.LOTNO, null, new { @id = "txtLotNo", @class = "form-control", @disabled = "disabled" })
                            </div>

                            <div class="col-sm-1">

                            </div>
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.PACKEDDATE2) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.PACKEDDATE2, null, new { @id = "txtPackedDate", @class = "form-control", @disabled = "disabled" })
                            </div>
                        </div>
                        <br />
                        <div class="row align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.FullNG) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                <div class="input-group">
                                    @Html.TextBoxFor(m => m.ModelObj.FullNG, null, new { @id = "txtFullNG", @class = "form-control", @disabled = "disabled" })
                                    <span class="label-input-group input-group-text tr-input-group"> % </span>
                                </div>

                            </div>

                            <div class="col-sm-1">
                            </div>
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.QUANTITY) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.QUANTITY, null, new { @id = "txtQty", @class = "form-control", @maxLength = "6", @disabled = "disabled" })
                            </div>
                        </div>

                        <br />
                        <div class="row align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.TESTEDBY) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.TESTEDBY, null, new { @id = "txtTestedBy", @class = "form-control", @disabled = "disabled" })
                            </div>

                            <div class="col-sm-1">
                            </div>
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.UPDATEDBY) </span>
                                    <span class="text-danger">*</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.UPDATEDBY, null, new { @id = "txtUpdatedBy", @class = "form-control", @maxLength = "6", @disabled = "disabled" })
                            </div>
                        </div>

                        <br />
                        <div class="row align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.OVERWRITE) </span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                <div class="input-group">

                                    @Html.TextBoxFor(m => m.ModelObj.OVERWRITE, null, new { @id = "txtOverwrite", @class = "form-control", @disabled = "disabled" })
                                    <span class="label-input-group input-group-text tr-input-group">/ set after</span>
                                </div>
                            </div>

                            <div class="col-sm-1">
                            </div>
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.INSPECTION) </span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.HiddenFor(a => a.ModelObj.INSPECTION, new { @id = "moinspection" })
                                <div class="form-check form-check-inline check">
                                    @*<input class="form-check-input" type="checkbox" id="inlineCheckbox1" value="Firstlot" checked>*@
                                    <input class="form-check-input" type="checkbox" id="inlineCheckbox1" value="Full" name="FirstLotContainer" disabled>
                                    <label class="form-check-label" for="inlineCheckbox1">First lot</label>
                                </div>
                                <div class="form-check form-check-inline check">
                                    <input class="form-check-input" type="checkbox" id="mabs" value="Part" name="PartialContainer" disabled>
                                    <label class="form-check-label" for="mabs">Partial (Only For MABS)</label>
                                </div>
                            </div>
                        </div>

                        <br />
                        <div class="row align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.STATUS) </span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.STATUS, null, new { @id = "txtStatus", @class = "form-control", @disabled = "disabled" })
                                @Html.ValidationMessageFor(m => m.ModelObj.STATUS, "", new { style = "color:red" })
                                @Html.HiddenFor(a => a.ModelObj.STATUS, new { @id = "mostatus" })
                            </div>

                            <div class="col-sm-1">
                            </div>
                            <div class="col-sm-2">
                                <p class="text-muted">
                                    <span>@Html.LabelFor(a => a.ModelObj.GRADE) </span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                @Html.TextBoxFor(m => m.ModelObj.GRADE, null, new { @id = "txtGradeM", @class = "form-control", @maxLength = "6", @disabled = "disabled" })
                                @Html.ValidationMessageFor(m => m.ModelObj.GRADE, "", new { style = "color:red" })
                                @Html.HiddenFor(a => a.ModelObj.GRADE, new { @id = "mograde" })
                            </div>
                        </div>

                        <br />
                        <div class="row align-items-baseline">
                            <div class="col-sm-2">
                                <p class="text-muted editonly">
                                    <span>Production Reject</span>
                                    <span style="float:right">:</span>
                                </p>
                            </div>
                            <div class="col-sm-3 d-flex">
                                <input class="form-check-input check editonly" type="checkbox" id="chkProduction" value="Reject" name="Rejected">
                            </div>
                            <div class="col-sm-1">
                            </div>
                            
                        </div>
                        <br />
                        <div class="row align-items-baseline">
                            <p class="text-muted">
                                <span>Overall Split Lot Quantity</span>
                            </p>
                            <div class="row align-items-baseline">
                                <div class="col-sm-12">
                                    <div class="row mt-2 mx-1">
                                        <table id="tblSplitSum" class="table table-bordered compact detailTable" style="width:100%">
                                            <thead>
                                                <tr class="toolbar-row">
                                                    <th>Grade</th>
                                                    <th>Initial Impacted Tonnage</th>
                                                    <th>Final Impacted Tonnage</th>
                                                    <th>Initial Impacted Ton</th>
                                                    <th>Final Impacted Ton</th>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="nav-mold" role="tabpanel" aria-labelledby="nav-mold-tab" tabindex="0">

                        <div class="row align-items-baseline">
                            <div class="col-sm-12">
                                <div class="row mt-2 mx-1">
                                    <div style="overflow-x: auto; width: 100%;">
                                        <table border="1" id="MoldingTable" class="table table-bordered compact detailTable">

                                            @if (Model.ModelObj.STATUS == "Draft")
                                            {
                                                <thead>
                                                    <tr style="background-color: #9ED1F8">
                                                        <th></th>  @* 0  --- for (+) sign *@
                                                        <th style="text-align:center">Property</th> @* 1 *@
                                                        <th style="text-align:center">Unit</th> @* 2 *@
                                                        <th style="text-align:center; min-width:130px;">m/c</th> @* 3 *@
                                                        <th style="text-align:center; min-width:130px;">Machine Result</th> @* 4 *@
                                                        <th style="text-align:center">Regression Result</th> @* 5 *@
                                                        <th style="text-align:center">COQ Adjust</th> @* 6 *@
                                                        <th style="text-align:center">Specification</th> @* 7 *@
                                                        <th style="text-align:center">Grade</th> @* 8 *@
                                                        <th style="text-align:center" hidden>Type Ind</th> @* 9 *@
                                                        <th style="text-align:center">Main Properties</th> @* 10 *@
                                                        <th style="text-align:center">Type</th> @* 11 *@
                                                        <th style="text-align:center" hidden>Regress Ind</th> @* 12 *@
                                                        <th style="text-align:center" hidden>Regress Formula</th> @* 13 *@
                                                        <th style="text-align:center" hidden>COQ Ind</th> @* 14 *@
                                                        <th style="text-align:center" hidden>ID</th> @* 15 *@
                                                        <th style="text-align:center">Mandatory</th> @* 16 *@
                                                        <th style="text-align:center;"></th> @* 17    --- SegL Mold*@
                                                        <th style="text-align:center" hidden>ExtraInd</th> @* 18 *@
                                                        <th style="text-align:center">Status</th> @* 19 *@
                                                        <th style="text-align:center;">Main Reading</th> @* 20 *@
                                                        <th style="text-align:center;">Max Count</th> @* 21 *@
                                                        <th style="text-align:center; display:none;">Reading 1</th> @* 22 *@
                                                        <th style="text-align:center; display:none;"> </th> @* 23 *@
                                                        <th style="text-align:center; display:none;">Reading 2</th>@* 24 *@
                                                        <th style="text-align:center; display:none;"> </th> @* 25 *@
                                                        <th style="text-align:center; display:none;">Reading 3</th> @* 26 *@
                                                        <th style="text-align:center; display:none;"> </th> @* 27 *@
                                                        <th style="text-align:center; display:none;">Reading 4</th> @* 28 *@
                                                        <th style="text-align:center; display:none;"> </th> @* 29 *@
                                                        <th style="text-align:center; display:none;">Reading 5</th> @* 30 *@
                                                        <th style="text-align:center; display:none;"> </th> @* 31 *@
                                                        <th style="text-align:center; display:none;">Reading 6</th> @* 32 *@
                                                        <th style="text-align:center; display:none;"> </th> @* 33 *@
                                                    </tr>
                                                </thead>

                                                <tbody>

                                                    @for (int i = 0; i < Model.ModelObj.MoldingList.Count; i++)
                                                    {
                                                        <tr>
                                                            <td></td> @* 0 *@
                                                            <td style="text-align:center">@Model.ModelObj.MoldingList[i].PropItem</td>@* 1 *@
                                                            <td style="text-align:center">@Model.ModelObj.MoldingList[i].Unit</td>@* 2 *@
                                                            @if (Model.ModelObj.MoldingList[i].TypeInd == "E") //* 3 & 4 *@
                                                            {
                                                                <td style="vertical-align:middle; width:18%; padding-right: 5px; padding-left:5px">

                                                                    @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].MachineName, new { @class = "form-control", @id = "mc", @disabled = true })
                                                                    @Html.ValidationMessageFor(a => a.ModelObj.MoldingList[i].MachineName, "", new { @class = "red", @style = "color:red" })
                                                                </td>
                                                                <td style="vertical-align:middle; width:10%; padding-right: 5px; padding-left:5px">
                                                                    <div class="input-group">
                                                                        @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].Average, new { @class = "form-control txtmcahineresult edittext", @id = "txtmcahineresult", @disabled = "true", @readonly = "readonly" })
                                                                        @Html.ValidationMessageFor(m => m.ModelObj.MoldingList[i].Average, "", new { @class = "red", @style = "color:red" })
                                                                        <button type="button" class="btn btn-info input-group-text editonly" data-bs-toggle="modal" data-bs-id="@Model.ModelObj.MoldingList[i].Properties" data-bs-prodtype="@Model.ModelObj.MoldingList[i].prodtype" data-bs-typeind="@Model.ModelObj.MoldingList[i].TypeInd"
                                                                                data-bs-lotno="@Model.ModelObj.LOTNO" data-bs-propitem="@Model.ModelObj.MoldingList[i].PropItem" data-bs-prodgroup="@Model.ModelObj.MoldingList[i].ProdGroup" data-bs-target="#PP_FishEye" title="Choose Product Type">
                                                                            ....
                                                                        </button>

                                                                    </div>
                                                                </td>
                                                            }
                                                            else if (Model.ModelObj.MoldingList[i].TypeInd == "P")
                                                            {
                                                                <td style="vertical-align:middle; width:18%; padding-right: 5px; padding-left:5px">
                                                                    @*<td>*@
                                                                    @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].MachineName, new { @class = "form-control", @id = "mc", @disabled = true })
                                                                    @Html.ValidationMessageFor(a => a.ModelObj.MoldingList[i].MachineName, "", new { @class = "red", @style = "color:red" })
                                                                </td>
                                                                <td style="vertical-align:middle; width:10%; padding-right: 5px; padding-left:5px">
                                                                    <div class="input-group">
                                                                        @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].Average, new { @class = "form-control txtmcahineresult edittext", @id = "txtmcahineresult", @disabled = "true", @readonly = "readonly" })
                                                                        @Html.ValidationMessageFor(m => m.ModelObj.MoldingList[i].Average, "", new { @class = "red", @style = "color:red" })
                                                                        <button type="button" class="btn btn-info input-group-text editonly" data-toggle="modal" data-id="@Model.ModelObj.MoldingList[i].Properties" data-prodtype="@Model.ModelObj.MoldingList[i].prodtype" data-target="#PP_PassFail" title="Choose Product Type">....</button>
                                                                    </div>
                                                                </td>
                                                            }
                                                            else if (Model.ModelObj.MoldingList[i].TypeInd == "M")
                                                            {

                                                                <td style="vertical-align:middle; width:10%; padding-right: 5px; padding-left:5px">
                                                                    <div class="input-group">
                                                                        @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].MachineName, new { @class = "form-control C_machinename edittext", @id = "mc", @disabled = "true" })
                                                                        @Html.ValidationMessageFor(m => m.ModelObj.MoldingList[i].MachineName, "", new { @class = "red", @style = "color:red" })
                                                                        <button type="button" class="btn btn-info input-group-text openModal editonly" data-toggle="modal" data-id="@Model.ModelObj.MoldingList[i].PropItem" data-prodtype="@Model.ModelObj.MoldingList[i].prodtype" data-lotno="@Model.ModelObj.LOTNO"
                                                                                data-idsd="@Model.ModelObj.MoldingList[i].ID_IDS_D" data-prodgroup="@Model.ModelObj.MoldingList[i].ProdGroup" data-target="#PP_MMIDS" title="Choose Product Type">
                                                                            ....
                                                                        </button>
                                                                    </div>
                                                                </td>
                                                                <td style="vertical-align:middle; width:18%; padding-right: 5px; padding-left:5px">
                                                                    @*<td>*@
                                                                    @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].Average, new { @class = "form-control txtmcahineresult", @id = "txtmcahineresult", @disabled = true, @readonly = "readonly" })
                                                                    @Html.ValidationMessageFor(a => a.ModelObj.MoldingList[i].Average, "", new { @class = "red", @style = "color:red" })
                                                                </td>
                                                            }
                                                            else
                                                            {
                                                                <td style="vertical-align:middle; width:18%; padding-right: 5px; padding-left:5px">
                                                                    @*<td>*@
                                                                    @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].MachineName, new { @class = "form-control", @id = "mc", @disabled = true })
                                                                    @Html.ValidationMessageFor(a => a.ModelObj.MoldingList[i].MachineName, "", new { @class = "red", @style = "color:red" })
                                                                </td>
                                                                <td style="vertical-align:middle; width:10%; padding-right: 5px; padding-left:5px">
                                                                    <div class="input-group">
                                                                        @Html.TextBoxFor(m => m.ModelObj.MoldingList[i].Average, new { @class = "form-control txtmcahineresult edittext", @id = "txtmcahineresult", @disabled = true, @readonly = "readonly" })
                                                                        @Html.ValidationMessageFor(m => m.ModelObj.MoldingList[i].Average, "", new { @class = "red", @style = "color:red" })
                                                                        <button type="button" class="btn btn-info input-group-text editonly" data-bs-toggle="modal" data-bs-id="@Model.ModelObj.MoldingList[i].Properties" data-bs-idsd="@Model.ModelObj.MoldingList[i].ID_IDS_D" data-bs-propitem="@Model.ModelObj.MoldingList[i].PropItem" data-bs-prodtype="@Model.ModelObj.MoldingList[i].prodtype" data-bs-prodgroup="@Model.ModelObj.MoldingList[i].ProdGroup" data-bs-target="#PP_Formula" title="Choose Product Type">....</button>
                                                                    </div>
                                                                </td>
                                                            }

                                                            @{
                                                                string format = "N" + Model.ModelObj.MoldingList[i].rounding.ToString();
                                                                string tmpstr = Model.ModelObj.MoldingList[i].RegressionResult != "" ? Convert.ToDouble(Model.ModelObj.MoldingList[i].RegressionResult).ToString(format) : "";
                                                            }

                                                            <td style="vertical-align:middle; width:18%; padding-right: 5px; padding-left:5px">@Html.TextBoxFor(m => tmpstr, new { @class = "form-control ", @id = "txtregressionresult", @disabled = true }) </td>@* 5 *@
                                                            <td style="text-align:center">@Model.ModelObj.MoldingList[i].COQAdj</td>@* 6 *@
                                                            <td style="text-align:center">@Model.ModelObj.MoldingList[i].Specification</td>@* 7 *@
