                                                            <td style="text-align:center" hidden>@Model.ModelObj.MoldingList[i].TypeInd</td>@* 9 *@
                                                            <td style="text-align:center">@Model.ModelObj.MoldingList[i].Properties</td>@* 10 *@
                                                            <td style="text-align:center">@Model.ModelObj.MoldingList[i].DataChecking</td>@* 11 *@
