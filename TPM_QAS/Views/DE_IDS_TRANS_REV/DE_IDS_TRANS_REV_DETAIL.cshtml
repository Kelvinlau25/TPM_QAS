    <script>

        $("#part_1, #part_2, #part_3").on("change", function () {

            var CE = $('#part_1').is(':checked');
            var CAP = $('#part_2').is(':checked');
            var FRACTION = $('#part_3').is(':checked');
            var val = "";

            if (CE) {
                val = "Part 1"
            } else {
                if (CAP) {
                    val = "Part 2"
                } else {
                    if (FRACTION) {
                        val = "Part 3"
                    }
                }
            }

            console.log(val);
            var id_ids_d = $('.id_ids_d').val();
            var propitemSegL = $('.propitemSegL').val();
            var prodtype = $("#txtProdType").val();
            var packeddate2 = $("#txtPackedDate").val();
            var lotno = $("#txtLotNo").val();

            $('#PP_SegL tbody').empty();

            $.ajax({
                type: "GET",
                url: '@Url.Action("GetSegregationL", "DE_IDS_TRANS")',
                contentType: "application/json; charset=utf-8",
                data: { "part": val, "id_ids_d": id_ids_d, "prodtype": prodtype, "propitem": propitemSegL, "packeddate2": packeddate2, "lotno": lotno },
                datatype: "Json",
                success: function (response) {
                    var trHTML = '';
                    $.each(response, function (i, item) {
                        var j = item.gradeInd;
                        trHTML += '<tr><td class="idSegL" style="display:none">' + item.id_ids_segl + '</td>' +
                            +'<td id = "cmpr" class="cmpr" style = "display:none" > ' + item.compare + '</td >';

                        if (item.gradeInd == "0") {
                            trHTML += '<td class="tagSegL" id="tagSegL">' + item.tagno + '</td>';

                        }
                        else {
                            trHTML += '<td class="tagSegL" id="tagSegL" style="padding-left:' + (15 * j) + 'px"><span class="iconify" data-icon="bi:arrow-return-right"></span>' + item.tagno + '</td>';
                        }

                        trHTML += '<td id="tonnageSegL" class="tonnageSegL">' + item.tonnage + '</td >' +
                            '<td><input type="text" id="readingSegL" class="readingSegL form-control" value="' + item.reading + '" /></td>' +
                            '<td id="gradeSegL" class="gradeSegL">' + item.grade + '</td >' +
                            '<td id="gradeIndL" class="GradeIndSegL" style="display:none">' + item.gradeInd + '</td>';


                        if (item.subNG == true) {
                            trHTML += "<td style='text-align:center'><button type='button' class='btn btn-info' data-toggle='modal' data-id='" + item.tagno + "," + item.gradeInd + "," + item.reading + "," + val + "," + lotno + "," + id_ids_d + "' data-target='#PP_SubSegL'>NG</button></td></tr >'";
                        }
                        else {
                            trHTML += '<td></td></tr > ';
                        }
                        //alert(item.tagno + "'-'" + item.gradeInd + "'-'" + item.reading + "'-'" + val + "'-'" + lotno + "'-'" + id_ids_d  )
                    });
                    $('#PP_SegL tbody').append(trHTML);
                    OpenModalSegL();
                    $(".partSegL").val(val);
                    $('.propitemSegL').val(propitemSegL);
                    $('.id_ids_d').val(id_ids_d);
                },
                error: function (ex) {
                    console.log(ex);
                }
            });

        });
    function OpenModalSegL() {
        $('#PP_SegL').modal('show');
    }
    </script>

