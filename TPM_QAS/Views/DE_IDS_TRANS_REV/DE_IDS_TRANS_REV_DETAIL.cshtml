@using TPM_QAS.Models
@model TPM_QAS.Models.CommonModel<DailyIDSTransVM, DailyIDSTransVM>

@{
    ViewBag.Title = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var g = 0;
    var y = 0;
    var gyi = 0;
}
<style>

    .tblAppearance {
        /*width: 1000px !important;*/
        margin: 20px 0 !important;
        display: block;
        overflow: auto;
    }

    .divuse {
        border: 2px solid green;
        margin-bottom: 20px;
    }

    u {
        text-decoration: underline;
        font-weight: bold;
    }
</style>

<div class="row g-0 px-3 tr-listing-header">
    <div class="col-sm-6 align-self-center">
        <p class="text-muted m-0 tr-listing-header-title main-title">View Form - @ViewBag.Title</p>
    </div>
    <div class="col-sm-6 text-end align-self-center">
        <div class="d-flex justify-content-end">
            <div id="customDTButton"></div>
        </div>
    </div>
</div>

<div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

<div class="page-container px-3 overflow-auto">
    <div class="tr-btm-btn-margin">
        <div class="card mt-3 mb-2 card-height">
            <div class="card-body">

