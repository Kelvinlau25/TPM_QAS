                    <div class="col"><h6 class="card-title text-muted">Inspection Data Sheet (IDS)</h6></div>
                    @if (Model.ModelObj.STATUS == "Completed" || Model.ModelObj.STATUS == "Rejected")
                    {
                        <div class="col text-end"> </div>
                    }
                    else
                    {
                        @*<div class="col-md-12">
                                <a href="@Url.Action("DE_IDS_TRANS_EDIT", "DE_IDS_TRANS", new { id = Model.ModelObj.ID_IDS_H })" onclick="loadings();" class="btn btn-primary">Edit</a>
                            </div>*@
                        <div class="col text-end"><button class="btn btn-sm btn-primary" id="btnEdit" type="button" data-behaviour="toggle">Edit</button></div>
                    }

                </div>

                <hr />
                <nav class="tr-tab">
                    <div class="nav nav-tabs" id="nav-tab" role="tablist">
                        <button class="nav-link active" id="nav-summary-tab" data-bs-toggle="tab" data-bs-target="#nav-summary" type="button" role="tab" aria-controls="nav-summary" aria-selected="true">Summary</button>
                        <button class="nav-link" id="nav-mold-tab" data-bs-toggle="tab" data-bs-target="#nav-mold" type="button" role="tab" aria-controls="nav-mold" aria-selected="false">Molding & Property</button>
                        <button class="nav-link" id="nav-appr-tab" data-bs-toggle="tab" data-bs-target="#nav-appr" type="button" role="tab" aria-controls="nav-appr" aria-selected="false">Appearance</button>
                    </div>
                </nav>
                <div class="tab-content p-2" id="nav-tabContent" style="border: 4px solid #EBF3FF;">
