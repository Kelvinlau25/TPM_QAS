    <script>
        function checkrepeatbtn() {
            $('#MoldingTable tbody tr').each(function (row, tr) {
                var propItem = $(tr).find('td').eq(1).html();
                var properties = $(tr).find('td').eq(10).html();

                var prodtype = '@Model.ModelObj.PRODTYPE';
                var lotno = '@Model.ModelObj.LOTNO';
                var ididsh = '@Model.ModelObj.ID_IDS_H';

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("GetDataChk2", "DE_IDS_TRANS")',
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify({ "properties": properties, "propitem": propItem, "lotno": lotno, "prodtype": prodtype, "id_ids_h": ididsh }),
                    datatype: "Json",
                    success: function (response) {
                        var data2 = JSON.parse(response);
                        if (data2.length > 0) {
                            data2.forEach(item => {
                                var ididsd = $("td").filter(function () {
                                    return $(this).text().trim() == item.PROPITEM;
                                }).closest("tr").find(".ididsd");

                                var avgcnt = $("td").filter(function () {
                                    return $(this).text().trim() == item.PROPITEM;
                                }).closest("tr").find(".avgcnt");

                                var btnppfisheye = $("#MoldingTable td").filter(function () {
                                    return $(this).text().trim() == item.PROPITEM;
                                }).closest("tr").find("#btnrepeat");
                                if (item.ID_IDS_D == $(ididsd).text()) {
                                    if (item.TTLCNT >= $(avgcnt).text()) {
                                        btnppfisheye.hide();
                                    }
                                }
                            });
                        }
                    },
                    error: function (ex) {
                        console.log(ex);
                    }
                });
            });
        }
    </script>

