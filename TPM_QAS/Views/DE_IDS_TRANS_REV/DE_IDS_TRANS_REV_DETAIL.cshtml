    <script>
    //Grab data and map to Input field
        function getMachineData(bseg) {
            var model = {
                LOTNO: $("#txtLotNo").val(),
            };
            $.ajax({
                url: '@Url.Action("GetMachineData", "DE_IDS_TRANS")',
                type: 'POST',
                datatype: 'json',
                contentType: 'application/json',
                data: JSON.stringify(model),
                success: function (data) {
                    var tmp = JSON.stringify(data);
                    var tmp1 = JSON.parse(tmp);
                    var txtbox = document.getElementsByClassName("yireadd");
                    var txtbox1 = document.getElementsByClassName("readingSeg");
                    var tonseg = document.getElementsByClassName("tonseg");
                    var formula = '@ViewBag.yiformula';
                    for (i = 0; i < tmp1.length; i++) {
                        for (j = 0; j < tmp1[i].length; j++) {
                            if (i == 0 && bseg == "before") {
                                for (j = 0; j < tmp1[i].length; j++) {
                                    var ton = document.getElementsByName("yitonnage")[j].innerText;
                                    if (tmp1[i][j].tonnage == ton) {
                                        if (formula != "") {
                                            formula = formula.replace(" ", "");
                                            var formula2 = formula.replace("var1", tmp1[i][j].machineData.toString());
                                            var rval = eval(formula2);
                                            txtbox[j].value = rval;
                                        }
                                        else {
                                            txtbox[j].value = tmp1[i][j].machineData.toString();
                                        }
                                    }
                                }
                            }
                            for (k = 0; k < tonseg.length; k++) {
                                if (i != 0 && bseg == "after") {
                                    for (j = 0; j < tmp1[i].length; j++) {
                                        var ton = document.getElementsByClassName("tonseg")[k].innerText;
                                        if (tmp1[i][j].tonnage == tonseg[k].innerText) {
                                            if (formula != "") {
                                                formula = formula.replace(" ", "");
                                                var formula2 = formula.replace("var1", tmp1[i][j].machineData.toString());
                                                var rval = eval(formula2);
                                                txtbox[k].value = rval;
                                            }
                                            else {
                                                txtbox[k].value = tmp1[i][j].machineData.toString();
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                error: function (e) {
                    console.log(e);
                }
            });
        }

        $("#btnMachineResult").on("click", function () {
            var bseg = $(this).attr("data-bseg");
            getMachineData(bseg);
        });

        $("#btnAverage0").on("click", function () {
            getAverageApp1();
        });

        $("#btnAverage1").on("click", function () {
            getAverageApp1();
        });

        var formula = '@ViewBag.yiformula';
        var num = '';
        var tonnage = '';
        var rresult = ''
        if (formula != "") {
            $(".yireadd").on('keyup', function (event) {
                num = $(this).val();
                tonnage = $(this).closest("tr").find("td:eq(1)").text();
                rresult = $("td").filter(function () {
                    return $(this).text() == tonnage;
                }).closest("tr").find("input.yireadd");
            });

            $(".yireadd").on('focusout', function (event) {
                formula = '@ViewBag.yiformula';
                formula = formula.replace(" ", "");
                var formula2 = formula.replace("var1", num);
                var rval = eval(formula2);

                $(rresult).val(rval);
                getAverageApp1();
            });
        }
    </script>

