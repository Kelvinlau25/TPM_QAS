}
<style>

    .tblAppearance {
        /*width: 1000px !important;*/
        margin: 20px 0 !important;
        display: block;
        overflow: auto;
    }

    .divuse {
        border: 2px solid green;
        margin-bottom: 20px;
    }

    u {
        text-decoration: underline;
        font-weight: bold;
