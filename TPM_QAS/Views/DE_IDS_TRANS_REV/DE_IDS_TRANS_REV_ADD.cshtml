function changeprodgroup() {
    var prodgroup = $('#txtProdGroup').val();
    if (prodgroup != "" && prodgroup != null) {
        if (prodgroup.toString().includes('MABS') == true) {
            $("#mabs").show();
            $("#mabs").removeAttr('disabled');
        }
        else {
            $("#mabs").hide();
            $("#mabs").attr('disabled', 'disabled');
        }
    }
}
