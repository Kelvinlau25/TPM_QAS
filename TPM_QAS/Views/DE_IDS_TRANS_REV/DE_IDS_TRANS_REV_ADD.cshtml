<div class="modal fade" id="ProdType" tabindex="-1" role="dialog" data-backdrop="false">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="float:left;">Product Type Listing</h5>
            </div>
            <hr />
            <div class="modal-body" id="searchSourceBody">
