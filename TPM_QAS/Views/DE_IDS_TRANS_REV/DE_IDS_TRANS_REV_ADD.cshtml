    $('#PP_Formula').on('show.bs.modal', function (event) {
        var propitem = $(event.relatedTarget).data('bsPropitem');
        var prodtype = $(event.relatedTarget).data('bsProdtype');

        $(this).find(".modal-title").text(propitem);

        formulainput = 0;
        $.ajax({
            type: "GET",
            url: '@Url.Action("GetCalcFormula", "DE_IDS_TRANS_REV")',
            contentType: "application/json; charset=utf-8",
            data: { "propitem": propitem },
            datatype: "Json",
            success: function (response) {
                var list = JSON.parse(response);
                var varcnt = list[0].FORMULA.split('var');
                $('#txtcformula').text(list[0].FORMULA);
                $("#varc").empty();
                $("#cresult").text("Result will be ");
                formulainput = varcnt.length - 1;
                for (var i = 1; i <= varcnt.length - 1; i++) {
                    var row = $("<tr>");
                    var lbl = "Var" + i;
                    var lable = $("<td>").html(lbl);
                    var txtbox = $("<td>").html('<input class="form-control" id="' + lbl + '" style="height:30px; background-color:white" type="text" value="">');
                    row.append(lable);
                    row.append(txtbox);
                    $("#varc").append(row);
                }
            }
        });

        $("#btncformula").off("click").on("click", function (event) {
            var formula = $('#txtcformula').text();
            var input = [];
            $('#varc input[type="text"]').each(function (value, j) {
                input.push($(this).val());
            });

            for (var i = 1; i <= input.length; i++) {
                formula = formula.replace("var" + i, input[i - 1]);
            }
            var result = eval(formula);
            $("#cresult").text("Result will be " + result.toFixed(8));
            $("#txtfresult").text(result.toFixed(8));
        });

        $("#btnconfirm-formula").off("click").on("click", function (event) {
            loadings();
            var model = {
                AverageMold: document.getElementById("txtfresult").innerText,
                prodtype: prodtype,
                PropItem: propitem,
                TypeInd: document.getElementById("typeinds").value,
            }

            $.ajax({
                url: '@Url.Action("MoldingTab", "DE_IDS_TRANS_REV")',
                type: 'POST',
                datatype: 'application/json',
                contentType: 'application/json',
                data: JSON.stringify(model),
                success: function (response) {
                    var a = response.averageMold;
                    var b = response.Grade;

                    var mach = $("td").filter(function () {
                        return $(this).text() == response.PropItem;
                    }).closest("tr").find(".txtmcahineresult");
                    $(mach).val(a.toString());

                    var grd = $("td").filter(function () {
                        return $(this).text() == response.PropItem;
                    }).closest("tr").find("td#txtGrade");
                    $(grd).html(b.toString());
                },
                error: function () {
                    alert("Error occured");
                },
                complete: function () {
                    loadings(false);
                }
            });
        });
    });

    $('#PP_PassFail').on('show.bs.modal', function (event) {
        var pi = $(event.relatedTarget).data('bsId');
        $(this).find(".modal-title").text(pi);
        $(this).find(".propitempass").val(pi);

        var pt = $(event.relatedTarget).data('bsProdtypepass');
        $(this).find(".prodtypepass").val(pt);

    });

});

