@using TPM_QAS.Models
@model ProdGroupModel
@{
    ViewBag.Title = "PRODUCT GROUP MM - Add";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@using (Html.BeginForm("MM_PROD_GROUP_ADD", "MM_PROD_GROUP", FormMethod.Post, new { encType = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <div class="row g-0 px-3 tr-listing-header">
        <div class="col-sm-6 align-self-center">
            <p class="text-muted m-0 tr-listing-header-title">New Form - Product Group</p>
        </div>
    </div>

    <div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

    <div class="page-container px-3 overflow-auto">
        <div class="tr-btm-btn-margin">
            <div class="card mt-3 mb-2 card-height height-override">
                <div class="card-body">
                    <div class="row align-items-baseline">
                        <div class="col"><h6 class="card-title text-muted">Product Group</h6></div>
                        <div class="col text-end"></div>
                    </div>

                    <hr />

                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Product Group <span class="text-danger">*</span><span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-5">
                            @Html.TextBoxFor(Model => Model.PROD_GROUP, new { @class = "form-control required-field", id = "txtprodgroup", @maxlength = "100" })
                        </div>
                    </div>

                    <div class="row row-cols-2 mt-4">
                        <div class="col-2 align-self-center">
                            <h6 class="text-muted" style="float: left">Product Type Listing</h6>
                        </div>
                        <div class="col-3">
                            <div class="input-group">
                                <div class="input-group-text tr-input-group" id="searchProdType" onclick="popupProdType()">
                                    <a href="#" class="text-reset vm tr-disabled"><i class="fa-solid fa-ellipsis" aria-hidden="true" style="color: #fff"></i></a>
                                </div>
                            </div>
                        </div>
                        <div class="col-7">
                            <div class="row row-cols-auto justify-content-end g-1">
                                <div class="col">
                                    <button class="btn btn-sm btn-md btn-danger" id="removeBtn" type="button">
                                        Remove
                                    </button>
                                </div>
                                <div class="col">
                                    <button class="btn btn-sm btn-md btn-primary" id="addBtn" onclick="popupProdType()" type="button">
                                        Add
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-2 mx-1">
                        <table id="item-table" class="detailTable" style="width:100%">
                            <thead>
                                <tr class="toolbar-row">
                                    <th style="width: 3%; text-align: center;">
                                        <input id="trCheckbox" type="checkbox" class="dt-checkboxes select-all form-check-input" style="margin-top:5.5px; display:none">
                                    </th>
                                    <th>Product Type Items</th>
                                    <th>Company Group</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var count = 0; }
                                @if (Model.ProdTypeModel != null && Model.ProdTypeModel.Count > 0)
                                {
                                    foreach (var item in Model.ProdTypeModel)
                                    {
                                        count++;
                                        <tr id="R_@count" data-did="@count">
                                            <td class="text-center">
                                                <input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_@count" onClick="handleCheckboxClick(this)">
                                            </td>
                                            <td>
                                                <input type="text" class="form-control" id="item_prodtype_@count" value="@item.PROD_TYPE" placeholder="" disabled>
                                            </td>
                                            <td>
                                                <input type="text" class="form-control" id="item_comp_@count" value="@item.COMP_GROUP" placeholder="" disabled>
                                            </td>
                                            <td class="d-none">
                                                <input type="text" class="form-control" id="item_stat_@count" value="0">
                                                <input type="text" class="form-control" id="item_dbid_@count" value="@item.MM_PRODGROUP_D_ID">
                                                <input type="text" class="form-control" id="item_prodid_@count" value="@item.MM_PRODTYPE_H_ID">
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        <input type="hidden" id="item-count" value="@count" />
                    </div>
                </div>
            </div>

            <div class="row row-cols-auto justify-content-end g-1 tr-btm-btn-area" style="padding-right: 20px">
                <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary mx-1 my-button" data-bs-toggle="modal" data-bs-target="#back-confirmation-modal">Back</button></div>
                <div class="col"><button hidden id="btnDraft" type="button" class="btn btn-sm btn-primary">Save As Draft</button></div>
                <div class="col"><button id="btnSubmit" type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#submit-confirmation-modal">Submit</button></div>
            </div>
        </div>
    </div>



}


<script>
    var idh = '@Model.MM_PRODGROUP_H_ID' != 0 ? '@Model.MM_PRODGROUP_H_ID' : 0;

    $(document).ready(function () {
        checkboxChecking();

        var listingURL = appBasePath + 'MM_PROD_GROUP/MM_PROD_GROUP_LST';

        //REMOVE D
        $('#removeBtn').on('click', function () {
            $('#item-table tbody input[type=checkbox]:checked').each(function (idx, ele) {
                var row = $(ele).closest('tr');
                var itemStatInput = row.find('input[id^="item_stat_"]');
                var item_stat = itemStatInput.val();

                if (item_stat != '1') {
                    itemStatInput.val('5');
                    row.hide();
                } else {
                    row.remove();
                }
            });

            checkboxChecking();
        });

        //SUBMIT
        $('#btnConfirmSubmit').on('click', function () {
            $('.invalid-feedback').remove();
            $('.is-invalid').removeClass('is-invalid');

            var cont = true;
            var message = "";

            var txtprodgroup = $("#txtprodgroup").val();

            if (txtprodgroup == undefined || txtprodgroup == null || txtprodgroup == "") {
                cont = false;
                message += 'Product Group field cannot empty. <br>';
            }

            $('.required-field').each(function (e) {
                var input_val = $(this).val().trim();
                if (input_val == null || input_val == undefined || input_val === "") {
                    cont = false;
                    $(this).addClass('is-invalid');
                    inputError(this);
                }
            });

            var hasItem = false;
            var hasError = false;
            var hasDuplicate = false;
            var existedItem = [];

            var list = [];

            $("#item-table tbody tr").each(function () {
                var did = $(this).data("did");
                if (did != '' && did != null && did != undefined) {
                    var item_stat = $('#item_stat_' + did).val();
                    var item_dbid = $('#item_dbid_' + did).val();

                    var item_prodtype = $('#item_prodtype_' + did).val();
                    var item_prodid = $('#item_prodid_' + did).val();

                    if (item_stat != '5') {
                        if (item_prodid !== "" && item_prodid != '0') {
                            hasItem = true;
                            if (existedItem.includes(item_prodid)) {
                                hasDuplicate = true;
                                return false;
                            } else {
                                existedItem.push(item_prodid);
                            }
                        } else {
                            hasError = true;
                        }
                    }

                    list.push({
                        'MM_PRODGROUP_D_ID': item_dbid,
                        'RECORD_TYP': item_stat,

                        'PROD_TYPE': item_prodtype,
                        'MM_PRODTYPE_H_ID': item_prodid
                    });
                }
            });

            if (cont && !hasItem) {
                cont = false;
                message = "Please add at least one Product Type Listing.";
            }
            if (cont && hasError) {
                cont = false;
                message = "Please make sure field in Product Type Listing is not empty.";
            }
            if (cont && hasDuplicate) {
                cont = false;
                message = "Duplicate product type items selected.";
            }

            if (cont) {

                var model = {
                    MM_PRODGROUP_H_ID: idh,
                    RECORD_TYP: '1',

                    PROD_GROUP: txtprodgroup,
                    ProdTypeModel: list
                };

                $.ajax({
                    url: appBasePath + "MM_PROD_GROUP/InsertUpdateProductGroup",
                    type: 'POST',
                    data: {
                        model: model
                    },
                    beforeSend: function () {
                        loadings();
                    },
                    success: function (response) {
                        loadings(false);
                        if (response.success) {
                            displayToast("s", "Data save successfully");

                            setTimeout(function () {
                                window.location.href = listingURL;
                            }, 2000);

                        } else {
                            displayToast("error", response.message)
                        }
                    },
                    error: function () {
                        displayToast("error", response.responseText)
                    }
                });

            } else {
                if (message != "") {
                    displayToast("error", message)
                }
            }

        });

        //DRAFT
        $('#btnDraft').on('click', function () {
            var cont = true;
            var message = "";

            var txtprodgroup = $("#txtprodgroup").val();

            if (txtprodgroup == undefined || txtprodgroup == null || txtprodgroup == "") {
                cont = false;
                message += 'Product Group field cannot empty. <br>';
            }

            //var hasItem = false;
            //var hasError = false;
            var hasDuplicate = false;
            var existedItem = [];

            var list = [];

            $("#item-table tbody tr").each(function () {
                var did = $(this).data("did");
                if (did != '' && did != null && did != undefined) {
                    var item_stat = $('#item_stat_' + did).val();
                    var item_dbid = $('#item_dbid_' + did).val();

                    var item_prodtype = $('#item_prodtype_' + did).val();
                    var item_prodid = $('#item_prodid_' + did).val();

                    if (item_stat != '5') {
                        item_stat = "8";
                        if (item_prodid !== "" && item_prodid != '0') {
                            //hasItem = true;
                            if (existedItem.includes(item_prodid)) {
                                hasDuplicate = true;
                                return false;
                            } else {
                                existedItem.push(item_prodid);
                            }
                        }
                        //else {
                        //    hasError = true;
                        //}
                    }

                    list.push({
                        'MM_PRODGROUP_D_ID': item_dbid,
                        'RECORD_TYP': item_stat,

                        'PROD_TYPE': item_prodtype,
                        'MM_PRODTYPE_H_ID': item_prodid
                    });
                }
            });

            //if (cont && !hasItem) {
            //    cont = false;
            //    message = "Please add at least one Product Type Listing.";
            //}

            //if (cont && hasError) {
            //    cont = false;
            //    message = "Please make sure field in Product Type Listing is not empty.";
            //}

            if (cont && hasDuplicate) {
                cont = false;
                message = "Duplicate product type items selected.";
            }

            if (cont) {

                var model = {
                    MM_PRODGROUP_H_ID: idh,
                    RECORD_TYP: '8',

                    PROD_GROUP: txtprodgroup,
                    ProdTypeModel: list
                };

                console.log(model)

                $.ajax({
                    url: appBasePath + "MM_PROD_GROUP/DraftProductGroup",
                    type: 'POST',
                    data: {
                        model: model
                    },
                    beforeSend: function () {
                        loadings();
                    },
                    success: function (response) {
                        loadings(false);
                        if (response.success) {
                            displayToast("s", "Data save as draft successfully");

                            setTimeout(function () {
                                window.location.href = listingURL;
                            }, 2000);

                        } else {
                            displayToast("error", response.message)
                        }
                    },
                    error: function () {
                        displayToast("error", response.responseText)
                    }
                });

            } else {
                if (message != "") {
                    displayToast("error", message)
                }
            }
        });

        $('#btnConfirmBack').on('click', function () {
            window.location.href = listingURL;
        });

    });


    //ADD PRODUCT TYPE LIST
    function addProdTypeList(data) {
        var cont = true;
        var message = "";

        var hasDuplicate = false;
        for (var i = 0; i < data.length; i++) {

            var rowIdx = $('#item-count').val();

            if (rowIdx != '0') {

                var tlength = $('#item-table tbody tr').length;

                if (tlength != 0) {
                    $("#item-table tbody tr").each(function () {
                        var prodid = data[i].MM_PRODTYPE_H_ID;

                        var did = $(this).data('did');
                        if (did != '' && did != null && did != undefined) {
                            var item_stat = $('#item_stat_' + did).val();
                            var item_prodid = $('#item_prodid_' + did).val();

                            if (data[i].INSERT != 'N') {
                                if (item_stat != '5' && item_prodid == prodid) {
                                    hasDuplicate = true;
                                    data[i].INSERT = 'N';
                                } else {
                                    data[i].INSERT = 'Y';
                                }
                            }

                        }
                    });
                } else {
                    data[i].INSERT = 'Y';
                }

            } else {
                data[i].INSERT = 'Y';
            }


        }

        //if (cont && hasDuplicate) {
        //    cont = false;
        //    message = "Duplicate product type items selected.";
        //}

        if (cont) {
            var rowIdx = $('#item-count').val();

            for (var i = 0; i < data.length; i++) {

                if (data[i].INSERT == 'Y') {
                    rowIdx++;
                    $('#item-count').val(rowIdx);

                    $("#item-table tbody").append(`
                    <tr id="R_${rowIdx}" data-did="${rowIdx}">
                        <td class="text-center"><input class="dt-checkboxes form-check-input" type="checkbox" value="" id="chk_${rowIdx}" onClick="handleCheckboxClick(this)"></td>
                        <td><input type="text" class="form-control" value="${data[i].PROD_TYPE}" id="item_prodtype_${rowIdx}" placeholder="" disabled></td>
                        <td><input type="text" class="form-control" value="${data[i].COMP_GROUP}" id="item_comp_${rowIdx}" placeholder="" disabled></td>
                        <td class="d-none">
                            <input type="text" id="item_stat_${rowIdx}" value="1">
                            <input type="text" id="item_dbid_${rowIdx}" value="0">
                            <input type="text" id="item_prodid_${rowIdx}" value="${data[i].MM_PRODTYPE_H_ID}">
                        </td>
                    </tr>`);

                    checkboxChecking();
                }
            }

        } else {
            if (message != "") {
                displayToast("error", message)
            }
        }
    }

    //POPUP
    function popupProdType() {
        var id = idh;
        var popup;
        var url = '@Url.Action("MM_PROD_GROUP_PRODTYPE_POPOUT", "MM_PROD_GROUP")';

        url = url + '?id=' + id;
        popup = window.open(url, "Popup", "directories=no,titlebar=no,toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=no,width=800,height=800");
        popup.focus();
    }

</script>